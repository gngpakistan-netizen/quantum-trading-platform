    table.cell(mob, 0, 1, "Composite Score",    text_color=_txtMuted, text_size=size.small, bgcolor=color.new(#0F172A, 0), text_halign=text.align_left)
    table.cell(mob, 1, 1, str.tostring(compositeScore) + " / 100", text_color=compositeColor, text_size=size.normal, bgcolor=color.new(#0F172A, 0), text_halign=text.align_right)

    table.cell(mob, 0, 2, "Grade",    text_color=_txtMuted, text_size=size.small, bgcolor=color.new(#0A0F1E, 0), text_halign=text.align_left)
    table.cell(mob, 1, 2, compositeGrade, text_color=_gradeFg, text_size=size.normal, bgcolor=_gradeBg, text_halign=text.align_right)

    table.cell(mob, 0, 3, "Regime",   text_color=_txtMuted, text_size=size.small, bgcolor=color.new(#0F172A, 0), text_halign=text.align_left)
    table.cell(mob, 1, 3, _regimeStrip, text_color=regimeColor20, text_size=size.small, bgcolor=color.new(#0F172A, 0), text_halign=text.align_right)

    table.cell(mob, 0, 4, "Bias Confidence", text_color=_txtMuted, text_size=size.small, bgcolor=color.new(#0A0F1E, 0), text_halign=text.align_left)
    table.cell(mob, 1, 4, biasConfLevel, text_color=biasConfColor, text_size=size.normal, bgcolor=color.new(#0A0F1E, 0), text_halign=text.align_right)

    table.cell(mob, 0, 5, "Most Likely",  text_color=_txtMuted, text_size=size.small, bgcolor=color.new(#0F172A, 0), text_halign=text.align_left)
    table.cell(mob, 1, 5, _mloStrip,  text_color=_mloFg,  text_size=size.small, bgcolor=_mloBg, text_halign=text.align_right)

    table.cell(mob, 0, 6, "Execution",     text_color=_txtMuted, text_size=size.small, bgcolor=color.new(#0A0F1E, 0), text_halign=text.align_left)
    table.cell(mob, 1, 6, execGrade_v19 + "  |  " + _statusStrip, text_color=_statFg, text_size=size.normal, bgcolor=color.new(#0A0F1E, 0), text_halign=text.align_right)

    table.cell(mob, 0, 7, "Recommended Risk",   text_color=_txtMuted, text_size=size.small, bgcolor=color.new(#0F172A, 0), text_halign=text.align_left)
    table.cell(mob, 1, 7, str.tostring(recommendedRisk_v19, "#.#") + "%", text_color=_riskClr, text_size=size.normal, bgcolor=color.new(#0F172A, 0), text_halign=text.align_right)

//=====================================================================
// CROSS-ASSET CONFIRMATION PANEL (Optional, top-right, default OFF)
// Enable with showMacroExpanded = true
//=====================================================================

var table asset = table.new(
     position.top_right, 7, 2,
     bgcolor=color.new(#0A0F1E, 0),
     frame_color=color.new(#334155, 0), frame_width=1,
     border_color=color.new(#1E293B, 0), border_width=1)

var bool assetInitialized = false
var int  _lastAssetUpdate = -999
bool assetRefresh = barstate.islast and (not assetInitialized or bar_index - _lastAssetUpdate >= 5)

if showMacroExpanded and showDashboard and assetRefresh and not mobileMode
    _lastAssetUpdate := bar_index
    assetInitialized := true

    table.cell(asset, 0, 0, "Dollar",  text_color=_txtMuted, text_size=size.small, bgcolor=color.new(#0D1526,0), text_halign=text.align_center)
    table.cell(asset, 1, 0, "Yields",  text_color=_txtMuted, text_size=size.small, bgcolor=color.new(#0D1526,0), text_halign=text.align_center)
    table.cell(asset, 2, 0, "Bitcoin", text_color=_txtMuted, text_size=size.small, bgcolor=color.new(#0D1526,0), text_halign=text.align_center)
    table.cell(asset, 3, 0, "S&P 500", text_color=_txtMuted, text_size=size.small, bgcolor=color.new(#0D1526,0), text_halign=text.align_center)
    table.cell(asset, 4, 0, "Silver",  text_color=_txtMuted, text_size=size.small, bgcolor=color.new(#0D1526,0), text_halign=text.align_center)
    table.cell(asset, 5, 0, "Euro",    text_color=_txtMuted, text_size=size.small, bgcolor=color.new(#0D1526,0), text_halign=text.align_center)
    table.cell(asset, 6, 0, "Real Yield", text_color=_txtMuted, text_size=size.small, bgcolor=color.new(#0D1526,0), text_halign=text.align_center)

    _dxyDir = dxyBull ? "▲" : dxyBear ? "▼" : "—"
    _dxyVal = dxyBull ? "Bullish" : dxyBear ? "Bearish" : "Neutral"
    _dxyClr2 = dxyBull ? _acBull : dxyBear ? _acBear : _txtDim

    _yldDir = yieldRising ? "▲" : yieldFalling ? "▼" : "—"
    _yldVal = yieldRising ? "Rising" : yieldFalling ? "Falling" : "Flat"
    _yldClr2 = yieldRising ? _acBear : yieldFalling ? _acBull : _txtDim

    _btcDir = btcBull ? "▲" : btcBear ? "▼" : "—"
    _btcVal = btcBull ? "Bullish" : btcBear ? "Bearish" : "Neutral"
    _btcClr2 = btcBull ? _acBull : btcBear ? _acBear : _txtDim

    _spxDir = spxBull ? "▲" : spxBear ? "▼" : "—"
    _spxVal = spxBull ? "Bullish" : spxBear ? "Bearish" : "Neutral"
    _spxClr2 = spxBull ? _acBull : spxBear ? _acBear : _txtDim

    _slvDir2 = silverClose > silverEMA ? "▲" : "▼"
    _slvVal2 = silverClose > silverEMA ? "Bullish" : "Bearish"
    _slvClr3 = silverClose > silverEMA ? _acBull : _acBear

    _eurDir = eurusdBull ? "▲" : eurusdBear ? "▼" : "—"
    _eurVal = eurusdBull ? "Bullish" : eurusdBear ? "Bearish" : "Neutral"
    _eurClr2 = eurusdBull ? _acBull : eurusdBear ? _acBear : _txtDim

    _ryDir = realYieldRising ? "▲" : realYieldFalling ? "▼" : "—"
    _ryVal = realYieldRising ? "Rising" : realYieldFalling ? "Falling" : "Flat"
    _ryClr2 = realYieldRising ? _acBear : realYieldFalling ? _acBull : _txtDim

    table.cell(asset, 0, 1, _dxyDir + " " + _dxyVal, text_color=_dxyClr2, text_size=size.small, bgcolor=color.new(#0A0F1E,0), text_halign=text.align_center)
    table.cell(asset, 1, 1, _yldDir + " " + _yldVal, text_color=_yldClr2, text_size=size.small, bgcolor=color.new(#0A0F1E,0), text_halign=text.align_center)
    table.cell(asset, 2, 1, _btcDir + " " + _btcVal, text_color=_btcClr2, text_size=size.small, bgcolor=color.new(#0A0F1E,0), text_halign=text.align_center)
    table.cell(asset, 3, 1, _spxDir + " " + _spxVal, text_color=_spxClr2, text_size=size.small, bgcolor=color.new(#0A0F1E,0), text_halign=text.align_center)
    table.cell(asset, 4, 1, _slvDir2 + " " + _slvVal2, text_color=_slvClr3, text_size=size.small, bgcolor=color.new(#0A0F1E,0), text_halign=text.align_center)
    table.cell(asset, 5, 1, _eurDir + " " + _eurVal, text_color=_eurClr2, text_size=size.small, bgcolor=color.new(#0A0F1E,0), text_halign=text.align_center)
    table.cell(asset, 6, 1, _ryDir + " " + _ryVal, text_color=_ryClr2, text_size=size.small, bgcolor=color.new(#0A0F1E,0), text_halign=text.align_center)

//=====================================================================
// CORRELATION MATRIX — Optional, middle-left, default OFF
// Enable with showCorrMatrix = true in V19 ULTIMATE ENHANCEMENTS
//=====================================================================

var table corrDash = table.new(
     position.middle_left, 5, 9,
     bgcolor=color.new(#0A0F1E, 0),
     frame_color=color.new(#334155, 0), frame_width=1,
     border_color=color.new(#1E293B, 0), border_width=1)

var bool corrInitialized = false
var int  _lastCorrUpdate = -999
bool corrRefresh = barstate.islast and (not corrInitialized or bar_index - _lastCorrUpdate >= 10)

if showCorrMatrix and showDashboard and corrRefresh and not mobileMode
    _lastCorrUpdate := bar_index
    corrInitialized := true

    _chBg = color.new(#0A0F1E, 0)
    table.cell(corrDash, 0, 0, "Asset",       text_color=_acPurple, text_size=size.small, bgcolor=_chBg)
    table.cell(corrDash, 1, 0, "30 Bar",      text_color=_txtMuted,   text_size=size.small, bgcolor=_chBg)
    table.cell(corrDash, 2, 0, "60 Bar",      text_color=_txtMuted,   text_size=size.small, bgcolor=_chBg)
    table.cell(corrDash, 3, 0, "120 Bar",     text_color=_txtMuted,   text_size=size.small, bgcolor=_chBg)
    table.cell(corrDash, 4, 0, "Stability",   text_color=_txtMuted,   text_size=size.small, bgcolor=_chBg)

    var array<string> _corrNames = array.from("DXY", "Yield", "Silver", "BTC", "Oil", "SPX", "EUR", "JPY")
    c30  = array.from(corrGoldDXY_30, corrGoldYld_30, corrGoldSlv_30, corrGoldBTC_30, corrGoldOil_30, corrGoldSPX_30, corrGoldEUR_30, corrGoldJpy_30)
    c60  = array.from(corrGoldDXY_60, corrGoldYld_60, corrGoldSlv_60, corrGoldBTC_60, corrGoldOil_60, corrGoldSPX_60, corrGoldEUR_60, corrGoldJpy_60)
    c120 = array.from(corrGoldDXY_120, corrGoldYld_120, corrGoldSlv_120, corrGoldBTC_120, corrGoldOil_120, corrGoldSPX_120, corrGoldEUR_120, corrGoldJpy_120)
    stabs = array.from(stabDXY, stabYld, stabSlv, stabBTC, stabOil, stabSPX, stabEUR, stabJpy)

    for i = 0 to 7
        _rowBg = i % 2 == 0 ? color.new(#0A0F1E, 0) : color.new(#0D1526, 0)
        _c30v  = nz(array.get(c30,i))
        _c60v  = nz(array.get(c60,i))
        _c120v = nz(array.get(c120,i))
        _stabv = nz(array.get(stabs,i))
        table.cell(corrDash, 0, i+1, array.get(_corrNames, i), text_color=_txtPrimary, text_size=size.small, bgcolor=_rowBg, text_halign=text.align_left)
        table.cell(corrDash, 1, i+1, str.tostring(_c30v, "#.##"),
             text_color=_c30v > 0 ? _acBull : _acBear, text_size=size.small, bgcolor=_rowBg)
        table.cell(corrDash, 2, i+1, str.tostring(_c60v, "#.##"),
             text_color=_c60v > 0 ? _acBull : _acBear, text_size=size.small, bgcolor=_rowBg)
        table.cell(corrDash, 3, i+1, str.tostring(_c120v, "#.##"),
             text_color=_c120v > 0 ? _acBull : _acBear, text_size=size.small, bgcolor=_rowBg)
        table.cell(corrDash, 4, i+1,
             _stabv < 0.2 ? "Stable" : _stabv < 0.4 ? "Moderate" : "Unstable",
             text_color=_stabv < 0.2 ? _acBull : _stabv < 0.4 ? _acWarning : _acBear,
             text_size=size.small, bgcolor=_rowBg)

//=====================================================================
// ALERTS — use FIX 3 final filtered vars
//=====================================================================

alertcondition(alertBullS_fp and finalApprovedBull, title="v25: S-Grade Long",  message="GOLD v25 S-GRADE LONG. Final quality gates passed.")
alertcondition(alertBearS_fp and finalApprovedBear, title="v25: S-Grade Short", message="GOLD v25 S-GRADE SHORT. Final quality gates passed.")
alertcondition(alertBullA_fp and finalApprovedBull, title="v25: A-Grade Long",  message="GOLD v25 A-GRADE LONG. Final quality gates passed.")
alertcondition(alertBearA_fp and finalApprovedBear, title="v25: A-Grade Short", message="GOLD v25 A-GRADE SHORT. Final quality gates passed.")
alertcondition(alertBullB_fp and finalApprovedBull, title="v25: B-Grade Long",  message="GOLD v25 B-GRADE LONG. Final quality gates passed.")
alertcondition(alertBearB_fp and finalApprovedBear, title="v25: B-Grade Short", message="GOLD v25 B-GRADE SHORT. Final quality gates passed.")
alertcondition(finalApprovedBull, title="v25: High Confidence Long",  message="GOLD v25 HIGH CONFIDENCE LONG. Check chart.")
alertcondition(finalApprovedBear, title="v25: High Confidence Short", message="GOLD v25 HIGH CONFIDENCE SHORT. Check chart.")

if finalApprovedBull
    _tier = alertBullS_fp ? "S" : alertBullA_fp ? "A" : "B"
    alert("GOLD v25.1 " + _tier + "-GRADE LONG | Composite: " + compositeGrade + " " + str.tostring(compositeScore) + "/100 | Bias BULL " + str.tostring(math.round(probBull)) + "% BEAR " + str.tostring(math.round(probBear)) + "% RNG " + str.tostring(math.round(probRange)) + "% | Target: " + str.tostring(pathTarget, "#.##") + " | Invalidation: " + str.tostring(invalidationLevel, "#.##") + " | News: " + newsRiskText + " | Rec Risk: " + str.tostring(recommendedRisk_v19, "#.##") + "% | Exec: " + execGrade_v19 + " | Stop: " + str.tostring(longStopLoss, "#.##") + " | TP: " + str.tostring(longTakeProfit, "#.##"), alert.freq_once_per_bar_close)

if finalApprovedBear
    _tier = alertBearS_fp ? "S" : alertBearA_fp ? "A" : "B"
    alert("GOLD v25.1 " + _tier + "-GRADE SHORT | Composite: " + compositeGrade + " " + str.tostring(compositeScore) + "/100 | Bias BULL " + str.tostring(math.round(probBull)) + "% BEAR " + str.tostring(math.round(probBear)) + "% RNG " + str.tostring(math.round(probRange)) + "% | Target: " + str.tostring(pathTarget, "#.##") + " | Invalidation: " + str.tostring(invalidationLevel, "#.##") + " | News: " + newsRiskText + " | Rec Risk: " + str.tostring(recommendedRisk_v19, "#.##") + "% | Exec: " + execGrade_v19 + " | Stop: " + str.tostring(shortStopLoss, "#.##") + " | TP: " + str.tostring(shortTakeProfit, "#.##"), alert.freq_once_per_bar_close)

// END OF v25 — AUDIT FIXES APPLIED
