    _mobFg = alertBullHigh ? _acBull : alertBearHigh ? _acBear : _txtMuted

    table.cell(mob, 0, 0, "Signal",    text_color=_txtMuted, text_size=size.small, bgcolor=color.new(#0A0F1E, 0), text_halign=text.align_left)
