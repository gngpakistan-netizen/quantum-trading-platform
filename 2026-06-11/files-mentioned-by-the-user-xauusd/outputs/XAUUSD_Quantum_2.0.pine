        table.cell(tblA, 5, 7, "DD" + ddStr, text_color=ddCol, text_size=size.small, width=8)
        table.cell(tblA, 6, 7, "PF" + pfStr, text_color=pfCol, text_size=size.small, width=8)
    else
        // ── DEFAULT: 7 cols × 8 rows, compact matrix ──
        // Row 0 - Header
        table.cell(tblA, 0, 0, "SIG", text_color=cGray, text_size=size.tiny, width=12)
        table.cell(tblA, 1, 0, "PROB", text_color=cGray, text_size=size.tiny, width=12)
        table.cell(tblA, 2, 0, "MTF", text_color=cGray, text_size=size.tiny, width=12)
        table.cell(tblA, 3, 0, "STRUCT", text_color=cGray, text_size=size.tiny, width=12)
        table.cell(tblA, 4, 0, "MACRO", text_color=cGray, text_size=size.tiny, width=12)
        table.cell(tblA, 5, 0, "LIQUID", text_color=cGray, text_size=size.tiny, width=12)
        table.cell(tblA, 6, 0, "TRADE", text_color=cGray, text_size=size.tiny, width=12)
        // Row 1 - Signal Summary
        table.cell(tblA, 0, 1, _execShort + " " + confStr, text_color=_execShortCol, text_size=size.small, width=12)
        table.cell(tblA, 1, 1, _biasLabel, text_color=_biasCol, text_size=size.small, width=12)
        table.cell(tblA, 2, 1, macroBias, text_color=macroCol, text_size=size.small, width=12)
        table.cell(tblA, 3, 1, "R" + str.tostring(regimeScore), text_color=cInfo, text_size=size.small, width=12)
        table.cell(tblA, 4, 1, sessionLabel + " " + str.tostring(int(sessionQuality)), text_color=cInfo, text_size=size.small, width=12)
        table.cell(tblA, 5, 1, liqDestLabel, text_color=liqDistCol, text_size=size.small, width=12)
        table.cell(tblA, 6, 1, symbolStr + " " + chgStr, text_color=chgCol, text_size=size.small, width=12)
        // Row 2 - MTF Alignment
        table.cell(tblA, 0, 2, "5M" + _5mArw, text_color=cInfo, text_size=size.small, width=12)
        table.cell(tblA, 1, 2, "15M" + _15mArw, text_color=cInfo, text_size=size.small, width=12)
        table.cell(tblA, 2, 2, "1H" + _1hArw, text_color=cInfo, text_size=size.small, width=12)
        table.cell(tblA, 3, 2, "4H" + _4hArw, text_color=cInfo, text_size=size.small, width=12)
        table.cell(tblA, 4, 2, "D" + _dArw, text_color=cInfo, text_size=size.small, width=12)
        table.cell(tblA, 5, 2, "AN" + str.tostring(_alnCount) + "/5", text_color=_alignCol, text_size=size.small, width=12)
        table.cell(tblA, 6, 2, "B" + _bosArw + " C" + _chochArw + " M" + _mssArw, text_color=cForecast, text_size=size.small, width=12)
        // Row 3 - Probabilities / Forecast
        table.cell(tblA, 0, 3, "H" + _histDir + " " + str.tostring(int(_histProb)), text_color=cForecast, text_size=size.small, width=12)
        table.cell(tblA, 1, 3, "F" + _futDir + " " + str.tostring(int(_futProb)), text_color=cForecast, text_size=size.small, width=12)
        table.cell(tblA, 2, 3, "WR" + wrStr, text_color=cForecast, text_size=size.small, width=12)
        table.cell(tblA, 3, 3, evStr != "—" ? "EV" + evStr : "EV—", text_color=evCol, text_size=size.small, width=12)
        table.cell(tblA, 4, 3, "KF" + kellyStr, text_color=kellyCol, text_size=size.small, width=12)
        table.cell(tblA, 5, 3, nStr, text_color=cForecast, text_size=size.small, width=12)
        table.cell(tblA, 6, 3, calDisp, text_color=calC, text_size=size.small, width=12)
        // Row 4 - Macro Context
        table.cell(tblA, 0, 4, "DXY" + _dxyArrow, text_color=cInfo, text_size=size.small, width=12)
        table.cell(tblA, 1, 4, "10Y" + _yldArrow, text_color=cInfo, text_size=size.small, width=12)
        table.cell(tblA, 2, 4, "XAG" + _xagArrow, text_color=cInfo, text_size=size.small, width=12)
        table.cell(tblA, 3, 4, "EUR" + _eurArrow, text_color=cInfo, text_size=size.small, width=12)
        table.cell(tblA, 4, 4, "SPX" + _spxArrow, text_color=cInfo, text_size=size.small, width=12)
        table.cell(tblA, 5, 4, "CR" + str.tostring(int(avgCorrHealth)), text_color=cForecast, text_size=size.small, width=12)
        table.cell(tblA, 6, 4, "MR" + _mrDisp + " " + vdStr, text_color=mrCol, text_size=size.small, width=12)
        // Row 5 - Liquidity Levels
        table.cell(tblA, 0, 5, _pdhSym, text_color=#00D084, text_size=size.small, width=12)
        table.cell(tblA, 1, 5, _pwhSym, text_color=#A855F7, text_size=size.small, width=12)
        table.cell(tblA, 2, 5, _pmhSym, text_color=#FF8C00, text_size=size.small, width=12)
        table.cell(tblA, 3, 5, _pdlSym, text_color=#FF4D4D, text_size=size.small, width=12)
        table.cell(tblA, 4, 5, _pwlSym, text_color=#A855F7, text_size=size.small, width=12)
        table.cell(tblA, 5, 5, _pmlSym, text_color=#FF8C00, text_size=size.small, width=12)
        table.cell(tblA, 6, 5, "LQ" + liqHealthLabel + " " + _eqhSym, text_color=_liqHealthCol, text_size=size.small, width=12)
        // Row 6 - Volume Profile
        table.cell(tblA, 0, 6, vpStr, text_color=#00C2FF, text_size=size.small, width=12)
        table.cell(tblA, 1, 6, vhStr, text_color=#A0A0A0, text_size=size.small, width=12)
        table.cell(tblA, 2, 6, vlStr, text_color=#A0A0A0, text_size=size.small, width=12)
        table.cell(tblA, 3, 6, vaStr, text_color=cInfo, text_size=size.small, width=12)
        table.cell(tblA, 4, 6, psStr, text_color=cForecast, text_size=size.small, width=12)
        table.cell(tblA, 5, 6, "FV" + _fvgStr + " OB" + _obStr, text_color=cForecast, text_size=size.small, width=12)
        table.cell(tblA, 6, 6, "VD" + vdStr, text_color=volDelta50 >= 0 ? #00D084 : #FF4D4D, text_size=size.small, width=12)
        // Row 7 - Trade Plan & Performance
        table.cell(tblA, 0, 7, "E" + tpEntryStr, text_color=cInfo, text_size=size.small, width=12)
        table.cell(tblA, 1, 7, "SL" + tpSLStr, text_color=cGray, text_size=size.small, width=12)
        table.cell(tblA, 2, 7, "TP" + tp1Str, text_color=tpCol, text_size=size.small, width=12)
        table.cell(tblA, 3, 7, "RR1:" + str.tostring(tpRR1, ".1"), text_color=cGray, text_size=size.small, width=12)
        table.cell(tblA, 4, 7, "SR" + sharpeStr, text_color=sharpeCol, text_size=size.small, width=12)
        table.cell(tblA, 5, 7, "DD" + ddStr, text_color=ddCol, text_size=size.small, width=12)
        table.cell(tblA, 6, 7, "PF" + pfStr + " IS" + _isStr + " OO" + _oosStr, text_color=pfCol, text_size=size.small, width=12)

if showDashboard and barstate.islast
    if na(tblA)
        if layoutMode == "Mobile"
            tblA := table.new(position.top_right, 4, 7, bgcolor=cBgBox, border_width=0, frame_width=0)
        else if layoutMode == "Compact"
            tblA := table.new(position.top_right, 7, 8, bgcolor=cBgBox, border_width=0, frame_width=0)
        else
            tblA := table.new(position.top_right, 7, 8, bgcolor=cBgBox, border_width=0, frame_width=0)
    renderDashboard()

//=====================================================================
// VISUAL INDICATORS - Conditions
//=====================================================================

// ---- Internal Liquidity Sweeps ----
internalLiqSweepHigh = equalHighs and high > nz(swingHigh1) and close < nz(swingHigh1)
internalLiqSweepLow  = equalLows  and low  < nz(swingLow1)  and close > nz(swingLow1)

// ---- Asian Session Range ----
float asianLookbackSec = timeframe.in_seconds()
int   asianLookback    = int(asianLookbackSec >= 604800 ? 10 : asianLookbackSec >= 86400 ? 5 : math.max(5, math.round(25200 / asianLookbackSec)))
float asianSessionHigh = ta.highest(high, asianLookback)
float asianSessionLow  = ta.lowest(low,   asianLookback)
bool asianHighSweep = inLondon and high > asianSessionHigh[1] and close < asianSessionHigh[1]
bool asianLowSweep  = inLondon and low  < asianSessionLow[1]  and close > asianSessionLow[1]

// ---- Manipulation Signal ----
manipBearCandle = high > high[1] and close < close[1] and (high - math.max(open, close)) > bodySize * 0.5
manipBullCandle = low < low[1] and close > close[1] and (math.min(open, close) - low) > bodySize * 0.5
manipVolume = not na(volume) and volume > volSma20 * 1.5
manipRangeCond = candleRange > adaptiveATR * manipThreshold
manipScore = (manipBearCandle or manipBullCandle ? 35 : 0) + (manipVolume ? 35 : 0) + (manipRangeCond ? 30 : 0)
manipHigh = manipScore >= 60 and (manipBearCandle or manipBullCandle) and adxVal > 15

// ---- Signal Quality Label Filters ----

// BOS qualified: engine BOS already requires penetration > 0.15 ATR natively
bosQualifiedBull = bullBOS
bosQualifiedBear = bearBOS

// CHOCH qualified: suppress in ranging regime
chochQualifiedBull = chochLabelBull and not regimeRanging
chochQualifiedBear = chochLabelBear and not regimeRanging

// MSS qualified: liq sweep + displacement + MSS + HTF >= 3/5
mssQualifiedBull = mssLabelBull and displacementUp and (liqSweepBull or internalLiqSweepLow) and (htfFullLong >= 3 or htfFullShort >= 3)
mssQualifiedBear = mssLabelBear and displacementDown and (liqSweepBear or internalLiqSweepHigh) and (htfFullLong >= 3 or htfFullShort >= 3)

// Displacement qualified: vol > 1.5x SMA20, bodyPct > 70%
dispQualifiedUp = displacementUp and not na(volume) and volume > volSma20 * 1.5 and bodyPct > 70
dispQualifiedDown = displacementDown and not na(volume) and volume > volSma20 * 1.5 and bodyPct > 70

// EQH/EQL qualified: dist <= 0.15 ATR, hide after sweep, min 5-bar separation
var int minBarsBetweenEQ = 5
var bool eqhSwept = false
var bool eqlSwept = false
if not na(swingHigh1) and high > swingHigh1
    eqhSwept := true
if not na(swingLow1) and low < swingLow1
    eqlSwept := true
bool eqhMinBars = swingHigh1Bar >= 0 and swingHigh2Bar >= 0 and (swingHigh1Bar - swingHigh2Bar) >= minBarsBetweenEQ
bool eqlMinBars = swingLow1Bar >= 0 and swingLow2Bar >= 0 and (swingLow1Bar - swingLow2Bar) >= minBarsBetweenEQ
eqhQualified = equalHighs and math.abs(swingHigh1 - swingHigh2) <= adaptiveATR * 0.15 and not eqhSwept and eqhMinBars
eqlQualified = equalLows and math.abs(swingLow1 - swingLow2) <= adaptiveATR * 0.15 and not eqlSwept and eqlMinBars
if not equalHighs
    eqhSwept := false
if not equalLows
    eqlSwept := false

// Global filters
globalFilterSuppressBOS = adxVal < 15 or rangeProb > 60
globalFilterSuppressCHOCH = adxVal < 15 or rangeProb > 60
globalFilterSuppressMSS = adxVal < 15 or rangeProb > 60
globalFilterLowConf = htfFullLong < 3 and htfFullShort < 3

//=====================================================================
// PLOTS
//=====================================================================

// ---- EMAs ----
plot(showEMAs and recentBars and not cleanInstitutional ? ema20 : na, "EMA 20", ema20Color, 1, plot.style_line, display=display.all)
plot(showEMAs and recentBars and not cleanInstitutional ? ema100 : na, "EMA 100", ema100Color, 1, plot.style_line, display=display.all)
plot(showEMAs and recentBars and not cleanInstitutional ? ema200 : na, "EMA 200", ema200Color, 1, plot.style_line, display=display.all)

// ---- VWAP ----
plot(showVWAP and recentBars and not cleanInstitutional ? vwapVal : na, "VWAP", color.new(cVwap, 40), 1, plot.style_line, display=display.all)

// ---- ADX (minimal opacity) ----
plot(not perfMode and showADX and recentBars and not cleanInstitutional and not professionalMode ? adxVal : na, "ADX", cAdxC, 1, plot.style_histogram, display=display.all)
hline(perfMode ? na : showADX and not cleanInstitutional ? adxThreshold : na, "ADX Thresh", color.new(#FF4D4D, 50), hline.style_dashed, display=display.none)

// ---- Order Block Visuals (phase 1) ----
var line bullOBLowLine  = na
var line bullOBHighLine = na
var line bearOBLowLine  = na
var line bearOBHighLine = na
var label bullOBLabel = na
var label bearOBLabel = na
bool obVisible = showOB and not cleanInstitutional
if barstate.islast
    if obBullActive and obVisible
        if na(bullOBLowLine)
            bullOBLowLine  := line.new(na, na, na, na, color=color.new(#00D084, 30), width=1, style=line.style_solid, xloc=xloc.bar_index, extend=extend.none)
        if na(bullOBHighLine)
            bullOBHighLine := line.new(na, na, na, na, color=color.new(#00D084, 30), width=1, style=line.style_solid, xloc=xloc.bar_index, extend=extend.none)
        if na(bullOBLabel)
            bullOBLabel := label.new(na, na, "", style=label.style_label_left, color=color.new(#0F172A, 100), textcolor=color.new(#00D084, 70), size=size.tiny, textalign=text.align_left, xloc=xloc.bar_index)
        if layoutMode != "Compact"
            label.set_size(bullOBLabel, size.normal)
            label.set_color(bullOBLabel, color.new(#0F172A, 30))
            line.set_width(bullOBLowLine, 2)
            line.set_width(bullOBHighLine, 2)
        int obStart = math.max(bar_index - 50, 0)
        line.set_xy1(bullOBLowLine, obStart, obBullLow)
        line.set_xy2(bullOBLowLine, bar_index, obBullLow)
        line.set_xy1(bullOBHighLine, obStart, obBullHigh)
        line.set_xy2(bullOBHighLine, bar_index, obBullHigh)
        label.set_xy(bullOBLabel, bar_index, obBullHigh)
        label.set_text(bullOBLabel, "BULL OB " + str.tostring(obBullHigh, "#.##"))
    else
        if not na(bullOBLowLine)
            line.delete(bullOBLowLine)
            bullOBLowLine := na
        if not na(bullOBHighLine)
            line.delete(bullOBHighLine)
            bullOBHighLine := na
        if not na(bullOBLabel)
            label.delete(bullOBLabel)
            bullOBLabel := na
    if obBearActive and obVisible
        if na(bearOBLowLine)
            bearOBLowLine  := line.new(na, na, na, na, color=color.new(#FF4D4D, 30), width=1, style=line.style_solid, xloc=xloc.bar_index, extend=extend.none)
        if na(bearOBHighLine)
            bearOBHighLine := line.new(na, na, na, na, color=color.new(#FF4D4D, 30), width=1, style=line.style_solid, xloc=xloc.bar_index, extend=extend.none)
        if na(bearOBLabel)
            bearOBLabel := label.new(na, na, "", style=label.style_label_left, color=color.new(#0F172A, 100), textcolor=color.new(#FF4D4D, 70), size=size.tiny, textalign=text.align_left, xloc=xloc.bar_index)
        if layoutMode != "Compact"
            label.set_size(bearOBLabel, size.normal)
            label.set_color(bearOBLabel, color.new(#0F172A, 30))
            line.set_width(bearOBLowLine, 2)
            line.set_width(bearOBHighLine, 2)
        int obStart = math.max(bar_index - 50, 0)
        line.set_xy1(bearOBLowLine, obStart, obBearLow)
        line.set_xy2(bearOBLowLine, bar_index, obBearLow)
        line.set_xy1(bearOBHighLine, obStart, obBearHigh)
        line.set_xy2(bearOBHighLine, bar_index, obBearHigh)
        label.set_xy(bearOBLabel, bar_index, obBearHigh)
        label.set_text(bearOBLabel, "BEAR OB " + str.tostring(obBearHigh, "#.##"))
    else
        if not na(bearOBLowLine)
            line.delete(bearOBLowLine)
            bearOBLowLine := na
        if not na(bearOBHighLine)
            line.delete(bearOBHighLine)
            bearOBHighLine := na
        if not na(bearOBLabel)
            label.delete(bearOBLabel)
            bearOBLabel := na

fill(plot(obBullActive and showOB and not cleanInstitutional ? obBullLow  : na, display=display.none),
     plot(obBullActive and showOB and not cleanInstitutional ? obBullHigh : na, display=display.none),
     color.new(#00D084, 90), title="Bull OB Fill")
fill(plot(obBearActive and showOB and not cleanInstitutional ? obBearLow  : na, display=display.none),
     plot(obBearActive and showOB and not cleanInstitutional ? obBearHigh : na, display=display.none),
     color.new(#FF4D4D, 90), title="Bear OB Fill")

// ---- FVG Quality Filter (max 3 active) ----
int fvgActiveCount = 0
if barstate.islast
    for i = 1 to math.min(30, bar_index)
        if fvgActive[i] and not fvgMitigated[i]
            fvgActiveCount += 1
bool fvgShowQuality = fvgActiveCount <= 3 or not showFVG

// ---- FVG Visuals (quality-filtered) ----
bool fvgPlotOk = fvgActive and showFVG and fvgShowQuality and not cleanInstitutional
var line fvgUpperLineObj = na
var line fvgLowerLineObj = na
var label fvgLabel = na
if barstate.islast and fvgPlotOk
    if na(fvgUpperLineObj)
        fvgUpperLineObj := line.new(na, na, na, na, color=color.new(#00C2FF, 20), width=1, style=line.style_solid, xloc=xloc.bar_index, extend=extend.none)
    if na(fvgLowerLineObj)
        fvgLowerLineObj := line.new(na, na, na, na, color=color.new(#00C2FF, 20), width=1, style=line.style_solid, xloc=xloc.bar_index, extend=extend.none)
    if na(fvgLabel)
        fvgLabel := label.new(na, na, "", style=label.style_label_left, color=color.new(#0F172A, 100), textcolor=color.new(#00C2FF, 70), size=size.tiny, textalign=text.align_left, xloc=xloc.bar_index)
    if layoutMode != "Compact"
        label.set_size(fvgLabel, size.normal)
        label.set_color(fvgLabel, color.new(#0F172A, 30))
        line.set_width(fvgUpperLineObj, 2)
        line.set_width(fvgLowerLineObj, 2)
    int fvgStart = math.max(bar_index - 50, 0)
    line.set_xy1(fvgUpperLineObj, fvgStart, fvgUpperLine)
    line.set_xy2(fvgUpperLineObj, bar_index, fvgUpperLine)
    line.set_xy1(fvgLowerLineObj, fvgStart, fvgLowerLine)
    line.set_xy2(fvgLowerLineObj, bar_index, fvgLowerLine)
    label.set_xy(fvgLabel, bar_index, fvgUpperLine)
    label.set_text(fvgLabel, "FVG " + str.tostring(fvgUpperLine, "#.##") + "/" + str.tostring(fvgLowerLine, "#.##"))
else if barstate.islast
    if not na(fvgUpperLineObj)
        line.delete(fvgUpperLineObj)
        fvgUpperLineObj := na
    if not na(fvgLowerLineObj)
        line.delete(fvgLowerLineObj)
        fvgLowerLineObj := na
    if not na(fvgLabel)
        label.delete(fvgLabel)
        fvgLabel := na
fill(plot(fvgPlotOk ? fvgUpperLine : na, display=display.none),
     plot(fvgPlotOk ? fvgLowerLine : na, display=display.none),
     color.new(#00C2FF, 88), title="FVG Fill")


// ---- Macro Strength Score as subplot ----
plot(showMacro and macroIntelValid and recentBars and showMacroPanel and not cleanInstitutional and not professionalMode ? macroStrengthScore : na, "Macro", color.new(#FF8C00, 50), 2, plot.style_histogram, display=display.all)

// ---- Corr Breakdown ----
plot(showCorrHealth and corrBreakdown and recentBars and not cleanInstitutional and not professionalMode ? close : na, "Corr Break", color.new(#FF4D4D, 60), 3, plot.style_line, display=display.all)

// ---- Signal Quality Labels (standardized: red/coral=HIGH, amber=MED, gray=LOW) ----
var label[] bosLabels = array.new_label()
var int[] bosLabelBars = array.new_int()
var int lastBOSBar = -1
var label[] chochLabels = array.new_label()
var int[] chochLabelBars = array.new_int()
var int lastCHOCHBar = -1
var label[] mssLabels = array.new_label()
var int[] mssLabelBars = array.new_int()
var int lastMSSBar = -1
var label[] displabels = array.new_label()
var int[] dispLabelBars = array.new_int()
var int lastDispBar = -1
var label[] eqhLabels = array.new_label()
var int[] eqhLabelBars = array.new_int()
var int lastEQHBar = -1
var label[] eqlLabels = array.new_label()
var int[] eqlLabelBars = array.new_int()
var int lastEQLBar = -1
var label[] manipLabels = array.new_label()
var int[] manipLabelBars = array.new_int()
var int lastManipBar = -1
var label[] smtLabels = array.new_label()
var int[] smtLabelBars = array.new_int()
var int lastSMTBar = -1

// Shared label cleaner helper
cleanLabels(label[] arr, int[] bars, int maxAge) =>
    if array.size(arr) > 0
        for i = array.size(arr) - 1 to 0
            if bar_index - array.get(bars, i) >= maxAge
                label.delete(array.get(arr, i))
                array.remove(arr, i)
                array.remove(bars, i)

// Min bar spacing between same SMC label type
int minSMCSpacing = 5

// ---- BOS (HIGH priority — red/coral, medium size, max 3 concurrent) ----
if barstate.isconfirmed
    cleanLabels(bosLabels, bosLabelBars, 15)
    if showSignals and recentBars and (bosQualifiedBull or bosQualifiedBear) and not globalFilterSuppressBOS and not globalFilterLowConf and bar_index > lastBOSBar + minSMCSpacing and array.size(bosLabels) < 3
        label nl = label.new(bar_index, bosQualifiedBull ? low - adaptiveATR * 0.3 : high + adaptiveATR * 0.3, "BOS", style=label.style_label_center, color=color.new(bosQualifiedBull ? #FF6B6B : #FF4D4D, 50), textcolor=#FFFFFF, size=size.normal, textalign=text.align_center, xloc=xloc.bar_index)
        array.push(bosLabels, nl)
        array.push(bosLabelBars, bar_index)
        lastBOSBar := bar_index

// ---- CHOCH (HIGH priority — amber, medium size, max 3 concurrent) ----
if barstate.isconfirmed
    cleanLabels(chochLabels, chochLabelBars, 15)
    if showSignals and recentBars and (chochQualifiedBull or chochQualifiedBear) and not globalFilterSuppressCHOCH and not globalFilterLowConf and bar_index > lastCHOCHBar + minSMCSpacing and array.size(chochLabels) < 3
        label nl = label.new(bar_index, chochQualifiedBull ? low - adaptiveATR * 0.3 : high + adaptiveATR * 0.3, "CHOCH", style=label.style_label_center, color=color.new(#FF8C00, 55), textcolor=#FFFFFF, size=size.normal, textalign=text.align_center, xloc=xloc.bar_index)
        array.push(chochLabels, nl)
        array.push(chochLabelBars, bar_index)
        lastCHOCHBar := bar_index

// ---- MSS (MEDIUM priority — amber, small size, max 3 concurrent) ----
if barstate.isconfirmed
    cleanLabels(mssLabels, mssLabelBars, 18)
    if showSignals and recentBars and (mssQualifiedBull or mssQualifiedBear) and not globalFilterSuppressMSS and bar_index > lastMSSBar + minSMCSpacing and array.size(mssLabels) < 3
        label nl = label.new(bar_index, mssQualifiedBull ? low - adaptiveATR * 0.4 : high + adaptiveATR * 0.4, "MSS", style=label.style_label_center, color=color.new(mssQualifiedBull ? #FFB84D : #FF8C00, 60), textcolor=#FFFFFF, size=size.small, textalign=text.align_center, xloc=xloc.bar_index)
        array.push(mssLabels, nl)
        array.push(mssLabelBars, bar_index)
        lastMSSBar := bar_index

// ---- SMT Divergence (amber, small size, max 3 concurrent) ----
if barstate.isconfirmed
    cleanLabels(smtLabels, smtLabelBars, 15)
    if showSignals and recentBars and (smtBullPair or smtBearPair) and bar_index > lastSMTBar + minSMCSpacing and array.size(smtLabels) < 3
        string smtText = smtBullPair ? "SMT+" : "SMT−"
        float smtY = smtBullPair ? low - adaptiveATR * 0.4 : high + adaptiveATR * 0.4
        label nl = label.new(bar_index, smtY, smtText, style=label.style_label_center, color=color.new(#FF8C00, 60), textcolor=#FFFFFF, size=size.small, textalign=text.align_center, xloc=xloc.bar_index)
        array.push(smtLabels, nl)
        array.push(smtLabelBars, bar_index)
        lastSMTBar := bar_index

// ---- Liquidity Sweep (MEDIUM priority — amber, small size, min 5-bar gap) ----
var label liqSweepLabel = na
var int liqSweepBar = -999
if (liqSweepBear or liqSweepBull) and barstate.isconfirmed and bar_index > liqSweepBar + minSMCSpacing and not cleanInstitutional and not professionalMode
    string swpText = "Liq Sweep"
    color  swpCol  = liqSweepBear ? #FFB84D : #FF8C00
    float  swpY    = liqSweepBear ? low - adaptiveATR * 0.5 : high + adaptiveATR * 0.5
    if not na(liqSweepLabel)
        label.delete(liqSweepLabel)
    liqSweepLabel := label.new(bar_index, swpY, swpText, style=label.style_label_center, color=color.new(swpCol, 70), textcolor=#FFFFFF, size=size.small, textalign=text.align_center, xloc=xloc.bar_index)
    liqSweepBar := bar_index
if not liqSweepBear and not liqSweepBull and not na(liqSweepLabel) and bar_index > liqSweepBar + 5
    label.delete(liqSweepLabel)
    liqSweepLabel := na

// ---- Asian Sweep Labels (min 5-bar gap) ----
var label asianSweepLabel = na
var int asianSweepBar = -999
if showAsianSweeps and (asianHighSweep or asianLowSweep) and barstate.isconfirmed and bar_index > asianSweepBar + minSMCSpacing
    string asiText = "Asia Sweep"
    color  asiCol  = asianHighSweep ? #FF4D4D : #00D084
    float  asiY    = asianHighSweep ? high + adaptiveATR * 0.3 : low - adaptiveATR * 0.3
    if not na(asianSweepLabel)
        label.delete(asianSweepLabel)
    asianSweepLabel := label.new(bar_index, asiY, asiText, style=label.style_label_center, color=color.new(asiCol, 70), textcolor=#FFFFFF, size=size.small, textalign=text.align_center, xloc=xloc.bar_index)
    asianSweepBar := bar_index
if not asianHighSweep and not asianLowSweep and not na(asianSweepLabel) and bar_index > asianSweepBar + 5
    label.delete(asianSweepLabel)
    asianSweepLabel := na

// ---- Displacement Labels (amber, small, max 3 concurrent) ----
if barstate.isconfirmed
    cleanLabels(displabels, dispLabelBars, 15)
    if recentBars and (dispQualifiedUp or dispQualifiedDown) and bar_index > lastDispBar + minSMCSpacing and array.size(displabels) < 3
        label nl = label.new(bar_index, dispQualifiedUp ? low - adaptiveATR * 0.3 : high + adaptiveATR * 0.3, "Disp", style=label.style_label_center, color=color.new(dispQualifiedUp ? #00D084 : #FF4D4D, 50), textcolor=#FFFFFF, size=size.small, textalign=text.align_center, xloc=xloc.bar_index)
        array.push(displabels, nl)
        array.push(dispLabelBars, bar_index)
        lastDispBar := bar_index

// ---- Equal High / Low Labels (amber, small, max 5 concurrent each) ----
if barstate.isconfirmed
    cleanLabels(eqhLabels, eqhLabelBars, 15)
    if recentBars and eqhQualified and bar_index > lastEQHBar + minSMCSpacing and array.size(eqhLabels) < 5
        label nl = label.new(bar_index, high + adaptiveATR * 0.25, "EQH", style=label.style_label_center, color=color.new(#FF8C00, 50), textcolor=#FFFFFF, size=size.small, textalign=text.align_center, xloc=xloc.bar_index)
        array.push(eqhLabels, nl)
        array.push(eqhLabelBars, bar_index)
        lastEQHBar := bar_index
    cleanLabels(eqlLabels, eqlLabelBars, 15)
    if recentBars and eqlQualified and bar_index > lastEQLBar + minSMCSpacing and array.size(eqlLabels) < 5
        label nl = label.new(bar_index, low - adaptiveATR * 0.25, "EQL", style=label.style_label_center, color=color.new(#FF8C00, 50), textcolor=#FFFFFF, size=size.small, textalign=text.align_center, xloc=xloc.bar_index)
        array.push(eqlLabels, nl)
        array.push(eqlLabelBars, bar_index)
        lastEQLBar := bar_index

// ---- Manipulation Labels (LOW priority — gray, small, max 2 concurrent) ----
if barstate.isconfirmed
    cleanLabels(manipLabels, manipLabelBars, 14)
    if showManipulation and recentBars and manipHigh and bar_index > lastManipBar + minSMCSpacing and array.size(manipLabels) < 2
        label nl = label.new(bar_index, manipBearCandle ? high + adaptiveATR * 0.3 : low - adaptiveATR * 0.3, "Manip", style=label.style_label_center, color=color.new(#A0A0A0, 70), textcolor=#FFFFFF, size=size.small, textalign=text.align_center, xloc=xloc.bar_index)
        array.push(manipLabels, nl)
        array.push(manipLabelBars, bar_index)
        lastManipBar := bar_index

//=====================================================================
// KEY LEVELS — PDH/PDL (amber, 40%) + PWH/PWL (purple, 40%)
// Lines span period start → current bar. Label once at right end.
//=====================================================================

// Period start bars (computed on every bar for consistency)
int dayBarsSince = nz(ta.barssince(timeframe.change("D")), 0)
int dayStartBar = bar_index - dayBarsSince
int weekBarsSince = nz(ta.barssince(timeframe.change("W")), 0)
int weekStartBar = bar_index - weekBarsSince
int monthBarsSince = nz(ta.barssince(timeframe.change("M")), 0)
int monthStartBar = bar_index - monthBarsSince

// CDH / CDL dashed lines (update on every bar, not just islast)
var line cdhLine = na
var line cdlLine = na
var label cdhLabel = na
var label cdlLabel = na
if barstate.islast and showKeyLevels and showLiqPools and not cleanInstitutional
    if na(cdhLine)
        cdhLine := line.new(na, na, na, na, color=color.new(#60A5FA, 70), width=1, style=line.style_dashed, xloc=xloc.bar_index, extend=extend.none)
    if na(cdlLine)
        cdlLine := line.new(na, na, na, na, color=color.new(#60A5FA, 70), width=1, style=line.style_dashed, xloc=xloc.bar_index, extend=extend.none)
    if na(cdhLabel)
        cdhLabel := label.new(na, na, "", style=label.style_label_left, color=color.new(#0F172A, 100), textcolor=#60A5FA, size=size.tiny, textalign=text.align_left, xloc=xloc.bar_index)
    if na(cdlLabel)
        cdlLabel := label.new(na, na, "", style=label.style_label_left, color=color.new(#0F172A, 100), textcolor=#60A5FA, size=size.tiny, textalign=text.align_left, xloc=xloc.bar_index)
    if layoutMode != "Compact"
        label.set_size(cdhLabel, size.normal)
        label.set_color(cdhLabel, color.new(#0F172A, 30))
        line.set_width(cdhLine, 2)
        label.set_size(cdlLabel, size.normal)
        label.set_color(cdlLabel, color.new(#0F172A, 30))
        line.set_width(cdlLine, 2)
    line.set_xy1(cdhLine, dayStartBar, cdh)
    line.set_xy2(cdhLine, bar_index, cdh)
    line.set_xy1(cdlLine, dayStartBar, cdl)
    line.set_xy2(cdlLine, bar_index, cdl)
    label.set_xy(cdhLabel, bar_index, cdh)
    label.set_text(cdhLabel, "CDH • " + str.tostring(cdh, "#.##"))
    label.set_xy(cdlLabel, bar_index, cdl)
    label.set_text(cdlLabel, "CDL • " + str.tostring(cdl, "#.##"))
else if barstate.islast
    if not na(cdhLine)
        line.delete(cdhLine)
        cdhLine := na
    if not na(cdlLine)
        line.delete(cdlLine)
        cdlLine := na
    if not na(cdhLabel)
        label.delete(cdhLabel)
        cdhLabel := na
    if not na(cdlLabel)
        label.delete(cdlLabel)
        cdlLabel := na

// Min spacing for key level labels to prevent overlap
float minKeyDist = ta.atr(14) * 0.15

// Helper: apply vertical offset if too close to another level
f_offsetLabel(baseY, ref1, ref2, ref3, dist) =>
    float yy = baseY
    if not na(ref1) and math.abs(baseY - ref1) < dist
        yy := yy + dist
    if not na(ref2) and math.abs(yy - ref2) < dist
        yy := yy + dist
    if not na(ref3) and math.abs(yy - ref3) < dist
        yy := yy + dist
    yy

if barstate.islast
    // Current price line + label (always visible)
    var priceLine  = line.new(na, na, na, na, color=color.new(#F1F5F9, 70), width=1, style=line.style_dotted, xloc=xloc.bar_index, extend=extend.right)
    var priceLabel = label.new(na, na, "", style=label.style_label_right, color=color.new(#0F172A, 100), textcolor=#F1F5F9, size=size.small, textalign=text.align_left, xloc=xloc.bar_index)
    line.set_xy1(priceLine, bar_index - 2, close)
    line.set_xy2(priceLine, bar_index, close)
    label.set_xy(priceLabel, bar_index, close)
    label.set_text(priceLabel, str.tostring(close, "#.##"))

    // EMA overlay lines + labels
    if showEMAs and not cleanInstitutional
        var ema20Line  = line.new(na, na, na, na, color=color.new(cEma20, 70), width=1, style=line.style_dotted, xloc=xloc.bar_index, extend=extend.right)
        var ema20Label = label.new(na, na, "", style=label.style_label_right, color=color.new(#0F172A, 100), textcolor=cEma20, size=size.small, textalign=text.align_left)
        var ema100Line  = line.new(na, na, na, na, color=color.new(cEma100, 70), width=1, style=line.style_dotted, xloc=xloc.bar_index, extend=extend.right)
        var ema100Label = label.new(na, na, "", style=label.style_label_right, color=color.new(#0F172A, 100), textcolor=cEma100, size=size.small, textalign=text.align_left)
        var ema200Line  = line.new(na, na, na, na, color=color.new(cEma200, 80), width=2, style=line.style_dotted, xloc=xloc.bar_index, extend=extend.right)
        var ema200Label = label.new(na, na, "", style=label.style_label_right, color=color.new(#0F172A, 100), textcolor=cEma200, size=size.small, textalign=text.align_left)
        line.set_xy1(ema20Line, bar_index - 2, ema20)
        line.set_xy2(ema20Line, bar_index, ema20)
        label.set_xy(ema20Label, bar_index, ema20)
        label.set_text(ema20Label, "EMA20 " + str.tostring(ema20, "#.##"))
        line.set_xy1(ema100Line, bar_index - 2, ema100)
        line.set_xy2(ema100Line, bar_index, ema100)
        label.set_xy(ema100Label, bar_index, ema100)
        label.set_text(ema100Label, "EMA100 " + str.tostring(ema100, "#.##"))
        line.set_xy1(ema200Line, bar_index - 2, ema200)
        line.set_xy2(ema200Line, bar_index, ema200)
        label.set_xy(ema200Label, bar_index, ema200)
        label.set_text(ema200Label, "EMA200 " + str.tostring(ema200, "#.##"))

    // VWAP overlay line + label
    if showVWAP and not cleanInstitutional
        var vwapLine  = line.new(na, na, na, na, color=color.new(cVwap, 60), width=1, style=line.style_dotted, xloc=xloc.bar_index, extend=extend.right)
        var vwapLabel = label.new(na, na, "", style=label.style_label_right, color=color.new(#0F172A, 100), textcolor=cVwap, size=size.small, textalign=text.align_left)
        line.set_xy1(vwapLine, bar_index - 2, vwapVal)
        line.set_xy2(vwapLine, bar_index, vwapVal)
        label.set_xy(vwapLabel, bar_index, vwapVal)
        label.set_text(vwapLabel, "VWAP " + str.tostring(vwapVal, "#.##"))

    // Trade plan horizontal levels (chart lines only — values in Table B)
    if showTradePlan
        var entryLine = line.new(na, na, na, na, color=color.new(#3B82F6, 70), width=1, style=line.style_dashed, xloc=xloc.bar_index, extend=extend.right)
        var stopLine  = line.new(na, na, na, na, color=color.new(#EF4444, 60), width=1, style=line.style_dashed, xloc=xloc.bar_index, extend=extend.right)
        var tpLine    = line.new(na, na, na, na, color=color.new(#22C55E, 70), width=1, style=line.style_dashed, xloc=xloc.bar_index, extend=extend.right)
        line.set_xy1(entryLine, bar_index - 2, tpEntry)
        line.set_xy2(entryLine, bar_index, tpEntry)
        line.set_xy1(stopLine, bar_index - 2, tpSL)
        line.set_xy2(stopLine, bar_index, tpSL)
        line.set_xy1(tpLine, bar_index - 2, tp1)
        line.set_xy2(tpLine, bar_index, tp1)

// Key level line/label objects (declared outside conditional for proper scoping)
var pdhLine  = line.new(na, na, na, na, color=color.new(#FF8C00, 60), width=1, style=line.style_dotted, xloc=xloc.bar_index, extend=extend.right)
var pdhLabel = label.new(na, na, "", style=label.style_label_left, color=color.new(#0F172A, 100), textcolor=#FF8C00, size=size.tiny, textalign=text.align_left, xloc=xloc.bar_index)
var pdlLine  = line.new(na, na, na, na, color=color.new(#FF8C00, 60), width=1, style=line.style_dotted, xloc=xloc.bar_index, extend=extend.right)
var pdlLabel = label.new(na, na, "", style=label.style_label_left, color=color.new(#0F172A, 100), textcolor=#FF8C00, size=size.tiny, textalign=text.align_left, xloc=xloc.bar_index)
var pwhLine  = line.new(na, na, na, na, color=color.new(#A855F7, 60), width=1, style=line.style_dotted, xloc=xloc.bar_index, extend=extend.right)
var pwhLabel = label.new(na, na, "", style=label.style_label_left, color=color.new(#0F172A, 100), textcolor=#A855F7, size=size.tiny, textalign=text.align_left, xloc=xloc.bar_index)
var pwlLine  = line.new(na, na, na, na, color=color.new(#A855F7, 60), width=1, style=line.style_dotted, xloc=xloc.bar_index, extend=extend.right)
var pwlLabel = label.new(na, na, "", style=label.style_label_left, color=color.new(#0F172A, 100), textcolor=#A855F7, size=size.tiny, textalign=text.align_left, xloc=xloc.bar_index)
var pmhLine  = line.new(na, na, na, na, color=color.new(#00C2FF, 60), width=1, style=line.style_dotted, xloc=xloc.bar_index, extend=extend.right)
var pmhLabel = label.new(na, na, "", style=label.style_label_left, color=color.new(#0F172A, 100), textcolor=#00C2FF, size=size.tiny, textalign=text.align_left, xloc=xloc.bar_index)
var pmlLine  = line.new(na, na, na, na, color=color.new(#00C2FF, 60), width=1, style=line.style_dotted, xloc=xloc.bar_index, extend=extend.right)
var pmlLabel = label.new(na, na, "", style=label.style_label_left, color=color.new(#0F172A, 100), textcolor=#00C2FF, size=size.tiny, textalign=text.align_left, xloc=xloc.bar_index)

if barstate.islast and showKeyLevels and showLiqPools and not cleanInstitutional
    // Collect values for collision detection
    float rawPdh = na(poolPdH) ? na : poolPdH
    float rawPdl = na(poolPdL) ? na : poolPdL
    float rawPwh = na(poolPwH) ? na : poolPwH
    float rawPwl = na(poolPwL) ? na : poolPwL
    float rawPmh = na(poolPmH) ? na : poolPmH
    float rawPml = na(poolPmL) ? na : poolPmL

    if layoutMode != "Compact"
        // Enhanced chart labels for Full-Width and Mobile layouts
        label.set_size(pdhLabel, size.normal)
        label.set_color(pdhLabel, color.new(#0F172A, 30))
        line.set_width(pdhLine, 2)
        label.set_size(pdlLabel, size.normal)
        label.set_color(pdlLabel, color.new(#0F172A, 30))
        line.set_width(pdlLine, 2)
        label.set_size(pwhLabel, size.normal)
        label.set_color(pwhLabel, color.new(#0F172A, 30))
        line.set_width(pwhLine, 2)
        label.set_size(pwlLabel, size.normal)
        label.set_color(pwlLabel, color.new(#0F172A, 30))
        line.set_width(pwlLine, 2)
        label.set_size(pmhLabel, size.normal)
        label.set_color(pmhLabel, color.new(#0F172A, 30))
        line.set_width(pmhLine, 2)
        label.set_size(pmlLabel, size.normal)
        label.set_color(pmlLabel, color.new(#0F172A, 30))
        line.set_width(pmlLine, 2)
    // PDH — amber, 40% (daily)
    if showPDH and not na(rawPdh)
        float pdhOff = f_offsetLabel(rawPdh, rawPdl, rawPwh, rawPwl, minKeyDist)
        line.set_xy1(pdhLine, dayStartBar, rawPdh)
        line.set_xy2(pdhLine, bar_index, rawPdh)
        label.set_xy(pdhLabel, bar_index, pdhOff)
        label.set_text(pdhLabel, "PDH • " + str.tostring(rawPdh, "#.##"))
    // PDL — amber, 40% (daily)
    if showPDL and not na(rawPdl)
        float pdlOff = f_offsetLabel(rawPdl, rawPdh, rawPwh, rawPwl, minKeyDist)
        line.set_xy1(pdlLine, dayStartBar, rawPdl)
        line.set_xy2(pdlLine, bar_index, rawPdl)
        label.set_xy(pdlLabel, bar_index, pdlOff)
        label.set_text(pdlLabel, "PDL • " + str.tostring(rawPdl, "#.##"))

    // PWH — purple, 40% (weekly)
    if showPWH and not na(rawPwh)
        float pwhOff = f_offsetLabel(rawPwh, rawPdh, rawPdl, rawPwl, minKeyDist)
        line.set_xy1(pwhLine, weekStartBar, rawPwh)
        line.set_xy2(pwhLine, bar_index, rawPwh)
        label.set_xy(pwhLabel, bar_index, pwhOff)
        label.set_text(pwhLabel, "PWH • " + str.tostring(rawPwh, "#.##"))
    // PWL — purple, 40% (weekly)
    if showPWL and not na(rawPwl)
        float pwlOff = f_offsetLabel(rawPwl, rawPdh, rawPdl, rawPwh, minKeyDist)
        line.set_xy1(pwlLine, weekStartBar, rawPwl)
        line.set_xy2(pwlLine, bar_index, rawPwl)
        label.set_xy(pwlLabel, bar_index, pwlOff)
        label.set_text(pwlLabel, "PWL • " + str.tostring(rawPwl, "#.##"))

    // PMH — cyan, 40% (monthly)
    if not na(rawPmh)
        float pmhOff = f_offsetLabel(rawPmh, rawPml, rawPwh, rawPwl, minKeyDist)
        line.set_xy1(pmhLine, monthStartBar, rawPmh)
        line.set_xy2(pmhLine, bar_index, rawPmh)
        label.set_xy(pmhLabel, bar_index, pmhOff)
        label.set_text(pmhLabel, "PMH • " + str.tostring(rawPmh, "#.##"))
    // PML — cyan, 40% (monthly)
    if not na(rawPml)
        float pmlOff = f_offsetLabel(rawPml, rawPmh, rawPwh, rawPwl, minKeyDist)
        line.set_xy1(pmlLine, monthStartBar, rawPml)
        line.set_xy2(pmlLine, bar_index, rawPml)
        label.set_xy(pmlLabel, bar_index, pmlOff)
        label.set_text(pmlLabel, "PML • " + str.tostring(rawPml, "#.##"))

//=====================================================================
// SMART ALERT FRAMEWORK - analysis only, no trade execution
//=====================================================================

alertcondition(shouldBuy,  title="Nexus Buy Signal",  message="XAUUSD: Buy signal @ {{close}} | Bias: {{biasLabel}} | Conf: {{regimeConfidence}}% | Session: {{sessionLabel}}")
alertcondition(shouldSell, title="Nexus Sell Signal", message="XAUUSD: Sell signal @ {{close}} | Bias: {{biasLabel}} | Conf: {{regimeConfidence}}% | Session: {{sessionLabel}}")

if shouldBuy and barstate.isconfirmed and not perfMode
    alert("XAUUSD NEXUS BUY @ " + str.tostring(close, "#.##"), alert.freq_once_per_bar)
if shouldSell and barstate.isconfirmed and not perfMode
    alert("XAUUSD NEXUS SELL @ " + str.tostring(close, "#.##"), alert.freq_once_per_bar)

alertcondition(showSignals and barstate.isconfirmed and bullBOS, "Bull BOS", "XAUUSD Bull BOS @ {{close}}")
alertcondition(showSignals and barstate.isconfirmed and bearBOS, "Bear BOS", "XAUUSD Bear BOS @ {{close}}")

//=====================================================================
// PREMIUM / DISCOUNT ZONE SHADING
// Premium = above intraday dealing range midpoint (bearish zone)
// Discount = below midpoint (bullish zone)
// Shown only on recent bars with subtle transparency
//=====================================================================
float dealingRangeMid = (ta.highest(high, 20) + ta.lowest(low, 20)) / 2
color premiumColor = color.new(#FF4D4D, 95)
color discountColor = color.new(#00D084, 95)

var line premiumLine = na
var line discountLine = na
var box premiumBox = na
var box discountBox = na
var label premiumLabel = na
var label discountLabel = na
float chartTopRaw = ta.highest(high, 100)
float chartBotRaw = ta.lowest(low, 100)
if showPremiumDisc and barstate.islast and recentBars and not cleanInstitutional and not professionalMode
    if na(premiumLine)
        premiumLine := line.new(na, na, na, na, color=premiumColor, width=1, style=line.style_solid, xloc=xloc.bar_index, extend=extend.none)
    if na(discountLine)
        discountLine := line.new(na, na, na, na, color=discountColor, width=1, style=line.style_solid, xloc=xloc.bar_index, extend=extend.none)
    if na(premiumLabel)
        premiumLabel := label.new(na, na, "", style=label.style_label_left, color=color.new(#0F172A, 100), textcolor=color.new(#FF4D4D, 95), size=size.tiny, textalign=text.align_left, xloc=xloc.bar_index)
    if na(discountLabel)
        discountLabel := label.new(na, na, "", style=label.style_label_left, color=color.new(#0F172A, 100), textcolor=color.new(#00D084, 95), size=size.tiny, textalign=text.align_left, xloc=xloc.bar_index)
    if na(premiumBox)
        premiumBox := box.new(na, na, na, na, bgcolor=premiumColor, border_color=na, xloc=xloc.bar_index, extend=extend.none)
    if na(discountBox)
        discountBox := box.new(na, na, na, na, bgcolor=discountColor, border_color=na, xloc=xloc.bar_index, extend=extend.none)
    float chartTop = chartTopRaw * 1.02
    float chartBot = chartBotRaw * 0.98
    line.set_xy1(premiumLine, bar_index - 5, dealingRangeMid)
    line.set_xy2(premiumLine, bar_index, dealingRangeMid)
    label.set_xy(premiumLabel, bar_index, dealingRangeMid)
    label.set_text(premiumLabel, "PREM " + str.tostring(dealingRangeMid, "#.##"))
    line.set_xy1(discountLine, bar_index - 5, dealingRangeMid)
    line.set_xy2(discountLine, bar_index, dealingRangeMid)
    label.set_xy(discountLabel, bar_index, dealingRangeMid - minKeyDist)
    label.set_text(discountLabel, "DISC " + str.tostring(dealingRangeMid, "#.##"))
    box.set_lefttop(premiumBox, bar_index - 5, chartTop)
    box.set_rightbottom(premiumBox, bar_index, dealingRangeMid)
    box.set_lefttop(discountBox, bar_index - 5, dealingRangeMid)
    box.set_rightbottom(discountBox, bar_index, chartBot)
else if barstate.islast
    if not na(premiumLine)
        line.delete(premiumLine)
        premiumLine := na
    if not na(discountLine)
        line.delete(discountLine)
        discountLine := na
    if not na(premiumLabel)
        label.delete(premiumLabel)
        premiumLabel := na
    if not na(discountLabel)
        label.delete(discountLabel)
        discountLabel := na
    if not na(premiumBox)
        box.delete(premiumBox)
        premiumBox := na
    if not na(discountBox)
        box.delete(discountBox)
        discountBox := na

//=====================================================================
// FORECAST CONE — M12-powered projection with confidence bands
// Combines Historical Analog + Trend Persistence + Liq Destination + Regime
//=====================================================================

if barstate.islast and showForecastCone and not cleanInstitutional and not professionalMode
    // Determine cone direction from M12 forecast probabilities
    string coneLabel = "RNG"
    float coneDir = 0.0
    float coneProb = fRng
    if fBull >= fBear and fBull >= fRng
        coneLabel := "BULL"
        coneDir := 1.0
        coneProb := fBull
    else if fBear >= fBull and fBear >= fRng
        coneLabel := "BEAR"
        coneDir := -1.0
        coneProb := fBear
    // Slope magnitude scales with probability conviction and ATR
    float coneSlope = adaptiveATR * (coneProb - 50.0) / 100.0 * coneDir * 0.5
    float centerEnd = close + coneSlope * forecastBars
    float startBand = (math.max(adaptiveATR, atr) / 2.0) * (forecastZ / 2.0)
    float endBand   = startBand * math.sqrt(math.max(forecastBars, 1))

    var line fcCenter = line.new(na, na, na, na, color=color.new(#00C2FF, 70), width=1, style=line.style_solid, xloc=xloc.bar_index, extend=extend.none)
    var line fcUpper  = line.new(na, na, na, na, color=color.new(#00C2FF, 30), width=1, style=line.style_dashed, xloc=xloc.bar_index, extend=extend.none)
    var line fcLower  = line.new(na, na, na, na, color=color.new(#00C2FF, 30), width=1, style=line.style_dashed, xloc=xloc.bar_index, extend=extend.none)
    var label fcLabel = label.new(na, na, "", style=label.style_label_center, color=color.new(#0F172A, 100), textcolor=#00C2FF, size=size.tiny, textalign=text.align_center, xloc=xloc.bar_index)

    line.set_xy1(fcCenter, bar_index, close)
    line.set_xy2(fcCenter, bar_index + forecastBars, centerEnd)
    line.set_xy1(fcUpper, bar_index, close + startBand)
    line.set_xy2(fcUpper, bar_index + forecastBars, centerEnd + endBand)
    line.set_xy1(fcLower, bar_index, close - startBand)
    line.set_xy2(fcLower, bar_index + forecastBars, centerEnd - endBand)
    label.set_xy(fcLabel, bar_index + forecastBars + 1, centerEnd)
    label.set_text(fcLabel, coneLabel + " " + str.tostring(int(coneProb)) + "%")

//=====================================================================
// END OF INDICATOR
//=====================================================================
