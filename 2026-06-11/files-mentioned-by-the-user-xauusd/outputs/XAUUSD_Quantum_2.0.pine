        table.cell(tblA, 3, 4, "EUR" + _eurArrow, text_color=cInfo, text_size=size.small, width=8)
        table.cell(tblA, 4, 4, "SPX" + _spxArrow, text_color=cInfo, text_size=size.small, width=8)
        table.cell(tblA, 5, 4, "CR" + str.tostring(int(avgCorrHealth)), text_color=cForecast, text_size=size.small, width=8)
        table.cell(tblA, 6, 4, "MR" + _mrDisp, text_color=mrCol, text_size=size.small, width=8)
        table.cell(tblA, 0, 5, _pdhSym, text_color=#00D084, text_size=size.small, width=8)
        table.cell(tblA, 1, 5, _pwhSym, text_color=#A855F7, text_size=size.small, width=8)
        table.cell(tblA, 2, 5, _pmhSym, text_color=#FF8C00, text_size=size.small, width=8)
        table.cell(tblA, 3, 5, _pdlSym, text_color=#FF4D4D, text_size=size.small, width=8)
        table.cell(tblA, 4, 5, _pwlSym, text_color=#A855F7, text_size=size.small, width=8)
        table.cell(tblA, 5, 5, _pmlSym, text_color=#FF8C00, text_size=size.small, width=8)
        table.cell(tblA, 6, 5, _eqhSym, text_color=cForecast, text_size=size.small, width=8)
        table.cell(tblA, 0, 6, vpStr, text_color=#00C2FF, text_size=size.small, width=8)
        table.cell(tblA, 1, 6, vhStr, text_color=#A0A0A0, text_size=size.small, width=8)
        table.cell(tblA, 2, 6, vlStr, text_color=#A0A0A0, text_size=size.small, width=8)
        table.cell(tblA, 3, 6, vaStr, text_color=cInfo, text_size=size.small, width=8)
        table.cell(tblA, 4, 6, psStr, text_color=cForecast, text_size=size.small, width=8)
        table.cell(tblA, 5, 6, "FV" + _fvgStr + " O" + _obStr, text_color=cForecast, text_size=size.small, width=8)
        table.cell(tblA, 6, 6, "LQ" + liqHealthLabel, text_color=_liqHealthCol, text_size=size.small, width=8)
        table.cell(tblA, 0, 7, "E" + tpEntryStr, text_color=cInfo, text_size=size.small, width=8)
        table.cell(tblA, 1, 7, "SL" + tpSLStr, text_color=cGray, text_size=size.small, width=8)
