//@version=6
indicator(
     "XAU/USD Institutional Liquidity Nexus v26 Elite",
     overlay=true,
     max_lines_count=500,
     max_labels_count=500,
     max_boxes_count=500,
     max_bars_back=5000)

//=====================================================================
// V26 ELITE INSTITUTIONAL TERMINAL - Market Structure / Liquidity / Macro
// Removed: Trade tracking, Prop firm, Equity curve, Forecast engine,
//           News risk, Fibonacci targets, Risk framework, Alert gates
//           with trade entry, Cross-asset panel, Corr matrix table.
// Added:    Structure Persistence Score, Liquidity Destination Ranking,
//           MTF Confluence Engine, Macro Intelligence (5 assets),
//           Bayesian Bias Engine, Regime Confidence, Signal Quality Engine,
//           Dashboard Elite (compact <15% chart area).
// Target:   Score 95-97/100 signal quality, <1000 variables.
//=====================================================================

//=====================================================================
// INSTITUTIONAL COLOR PALETTE
//=====================================================================

color cBull        = color.new(#10B981, 0)
color cBullSoft    = color.new(#10B981, 70)
color cBullBg      = color.new(#10B981, 92)
color cBullGlow    = color.new(#10B981, 97)

color cBear        = color.new(#DC2626, 0)
color cBearSoft    = color.new(#DC2626, 70)
color cBearBg      = color.new(#DC2626, 92)
color cBearGlow    = color.new(#DC2626, 97)

color cNeutral     = color.new(#94A3B8, 0)
color cNeutralSoft = color.new(#94A3B8, 80)
color cWarning     = color.new(#F59E0B, 0)
color cForecast    = color.new(#06B6D4, 0)
color cForecastSoft= color.new(#06B6D4, 85)
color cPremium     = color.new(#EF4444, 0)
color cDiscount    = color.new(#22C55E, 0)
color cPurple      = color.new(#8B5CF6, 0)
color cTeal        = color.new(#14B8A6, 0)

color cBgDark      = color.new(#0F172A, 5)
color cBgPanel     = color.new(#1E293B, 10)
color cBgHeader    = color.new(#0F172A, 0)
color cBorder      = color.new(#334155, 0)
color cTextPrimary = color.new(#F1F5F9, 0)
color cTextMuted   = color.new(#94A3B8, 0)
color cTextDim     = color.new(#64748B, 0)

color cRisk        = color.new(#EF4444, 0)
color cTarget      = color.new(#10B981, 0)

color cGrpMacro    = color.new(#78350F, 0)
color cGrpStruct   = color.new(#134E4A, 0)
color cGrpHTF      = color.new(#3B0764, 0)

color cRange       = color.new(#F59E0B, 0)
color cLabel       = color.new(#94A3B8, 0)
color cAdxC        = color.new(#A855F7, 0)
color cEma20       = color.new(#3B82F6, 0)
color cEma50       = color.new(#F59E0B, 0)
color cEma200      = color.new(#8B5CF6, 0)
ema20Color         = cEma20
ema50Color         = cEma50
ema200Color        = cEma200
color cGrpExec     = color.new(#14532D, 0)
color cGrpFuture   = color.new(#1E3A5F, 0)
color cGrpSep      = color.new(#475569, 0)

color cTierS       = color.new(#F8FAFC, 0)
color cTierA       = color.new(#FBBF24, 0)
color cTierB       = color.new(#F8FAFC, 0)
color cTierC       = color.new(#64748B, 0)

color cRegTrendExp = color.new(#10B981, 0)
color cRegTrendCon = color.new(#34D399, 0)
color cRegTrendExh = color.new(#F59E0B, 0)
color cRegRangeAcc = color.new(#3B82F6, 0)
color cRegRangeDis = color.new(#8B5CF6, 0)
color cRegVolComp  = color.new(#64748B, 0)
color cRegVolExp   = color.new(#DC2626, 0)

color cCorrStrong   = color.new(#10B981, 0)
color cCorrModerate = color.new(#F59E0B, 0)
color cCorrWeak     = color.new(#64748B, 0)
color cCorrBroken   = color.new(#DC2626, 0)
color cMSS          = color.new(#F97316, 0)
color cComposite    = color.new(#8B5CF6, 0)

//=====================================================================
// MODULE TOGGLES (reduced)
//=====================================================================

grpModules = "MODULES"

ultraLight       = input.bool(false, "Ultra Light Mode",                  group=grpModules)
showDashboard    = input.bool(true,  "Dashboard",                          group=grpModules)
showVWAP         = input.bool(true,  "VWAP",                               group=grpModules)
showLiquidity    = input.bool(true,  "PDH / PDL / PWH / PWL",             group=grpModules)
showSR           = input.bool(true,  "Support / Resistance",               group=grpModules)
showSessions     = input.bool(true,  "Sessions",                           group=grpModules)
showEQ           = input.bool(true,  "EQH / EQL",                         group=grpModules)
showSignals      = input.bool(true,  "Signals",                            group=grpModules)
showFVG          = input.bool(true,  "Fair Value Gaps",                    group=grpModules)
showOB           = input.bool(true,  "Order Blocks",                       group=grpModules)
showSMT          = input.bool(true,  "SMT Divergence",                     group=grpModules)
showAsian        = input.bool(true,  "Asian Sweeps",                       group=grpModules)
showClimax       = input.bool(true,  "Volume Climax",                      group=grpModules)
showAdaptiveATR  = input.bool(true,  "Adaptive ATR Regime",                group=grpModules)
showDisplacement = input.bool(true,  "Displacement Candles",               group=grpModules)
showIntExtLiq    = input.bool(true,  "Internal/External Liquidity",        group=grpModules)
showManipProb    = input.bool(true,  "Session Manipulation Probability",   group=grpModules)
showSmartAlerts  = input.bool(true,  "Smart Alert Framework",              group=grpModules)
showPremiumDisc  = input.bool(true,  "Premium/Discount Zones",             group=grpModules)
showVolStates    = input.bool(true,  "AI Volatility States",               group=grpModules)
mobileMode       = input.bool(false, "Compact Mobile Dashboard",           group=grpModules)
showHTF          = input.bool(true,  "HTF Trend Stack",                    group=grpModules)
showKillzone     = input.bool(true,  "ICT Killzone Weighting",             group=grpModules)
showMob5M        = input.bool(true,  "Mobile: Show 5M Trend Column",      group=grpModules)
showCTier        = input.bool(true,  "Show C-Grade Early Warning Signals", group=grpModules)
showCorrHealth   = input.bool(true,  "Correlation Health Check",           group=grpModules)

perfMode         = input.bool(false, "Institutional Performance Mode",     group=grpModules)
showRegime20     = input.bool(true,  "Market Regime Engine 2.0",           group=grpModules)
showMSS          = input.bool(true,  "Market Structure Shift (MSS)",       group=grpModules)
showStructScore  = input.bool(true,  "Structure Score (0-100)",            group=grpModules)
showFlowScore    = input.bool(true,  "Order Flow Score (0-100)",           group=grpModules)
showLiqMagnet    = input.bool(true,  "Liquidity Magnet Engine",            group=grpModules)
showComposite    = input.bool(true,  "Institutional Composite Score 2.0",  group=grpModules)

//=====================================================================
// CORE INPUTS (reduced - no trade/prop/news/fib/forecast inputs)
//=====================================================================

grpCore = "CORE"

ema20Len      = input.int(20,  "EMA20",                  group=grpCore)
ema50Len      = input.int(50,  "EMA50",                  group=grpCore)
ema200Len     = input.int(200, "EMA200",                 group=grpCore)
atrLen        = input.int(14,  "ATR Base",               group=grpCore)
adxLen        = input.int(14,  "ADX",                    group=grpCore)
adxThreshold  = input.int(25,  "ADX Threshold",          group=grpCore)
rsiLen        = input.int(14,  "RSI Length",    minval=2, maxval=50, group=grpCore)
pivotLen      = input.int(3,   "Pivot Length",  minval=2, maxval=10, group=grpCore)
maxZoneBars   = input.int(25,  "Zone Length",   minval=10,maxval=100,group=grpCore)
recentBarsLen = input.int(120, "Signal Lookback Bars", minval=50, maxval=500, group=grpCore)
trendThreshold= input.int(60,  "Trend Score Threshold", minval=50, maxval=90, step=5, group=grpCore)
volClimaxPerc = input.int(95,  "Volume Climax Percentile", minval=90, maxval=99, step=1, group=grpCore)
eqAtrMult     = input.float(0.25,"EQ Tolerance (ATR mult)", minval=0.05, maxval=1.0, step=0.05, group=grpCore)
smtLookback   = input.int(50,  "SMT Lookback",  minval=20, maxval=200, group=grpCore)
volLookback   = input.int(50,  "Volume Climax Lookback", minval=20, maxval=100, group=grpCore)

showEMAs  = input.bool(true,  "Show EMAs",  group=grpModules)
showADX   = input.bool(true,  "Show ADX",   group=grpModules)
showMacro = input.bool(true,  "Show Macro Score", group=grpModules)
showPDH   = input.bool(true,  "Show PDH Line",   group=grpModules)
showPDL   = input.bool(true,  "Show PDL Line",   group=grpModules)
showPWH   = input.bool(true,  "Show PWH Line",   group=grpModules)
showPWL   = input.bool(true,  "Show PWL Line",   group=grpModules)

pdlLen      = input.int(20,  "PDL Lookback",   minval=10, maxval=50, group=grpCore)
pwlLen      = input.int(50,  "PWL Lookback",   minval=20, maxval=100, group=grpCore)
fvgMaxBars  = input.int(30,  "FVG Max Bars",   minval=10, maxval=100, group=grpCore)
obMaxBars   = input.int(20,  "OB Max Bars",    minval=10, maxval=50, group=grpCore)
obAtrMult   = input.float(1.5, "OB ATR Multiplier",  minval=0.5, maxval=3.0, step=0.1, group=grpCore)
fvgFillPct  = input.int(70, "FVG Fill %",     minval=50, maxval=100, step=5, group=grpCore)
liqProxMult = input.float(1.5, "Liq Proximity (ATR)", minval=0.5, maxval=4.0, step=0.1, group=grpCore)

grpV11 = "V11 INTELLIGENCE"

dispMult         = input.float(2.5, "Displacement Multiplier",  minval=1.5, maxval=5.0, step=0.1, group=grpV11)
liqClusterThresh = input.float(0.3, "Liquidity Cluster Threshold (ATR)", minval=0.1, maxval=1.0, step=0.1, group=grpV11)
manipThreshold   = input.float(1.5, "Manipulation Volume Threshold", minval=1.0, maxval=3.0, step=0.1, group=grpV11)
premiumBandMult  = input.float(1.0, "Premium/Discount Band (ATR)", minval=0.5, maxval=2.0, step=0.1, group=grpV11)
killzoneBoost    = input.float(1.2, "Killzone Confidence Boost", minval=1.0, maxval=1.5, step=0.1, group=grpV11)
macroTF          = input.timeframe("60", "Macro Correlation Timeframe", group=grpV11)

grpV17 = "V17 PREDICTIVE ENHANCEMENTS"

confirmationBars   = input.int(2,    "Signal Confirmation Bars",         minval=1, maxval=5,           group=grpV17)
dxyRocLen          = input.int(10,   "DXY Momentum ROC Length (bars)",   minval=5, maxval=30,           group=grpV17)
useRsiDivFilter    = input.bool(true,"RSI Divergence Filter",                                            group=grpV17)
rsiDivLookback     = input.int(14,   "RSI Divergence Lookback",          minval=5, maxval=30,           group=grpV17)
corrHealthBars     = input.int(10,   "Correlation Break Lookback (bars)",minval=5, maxval=20,           group=grpV17)
enableAdaptiveWts  = input.bool(true,"Adaptive Scoring by Regime",                                      group=grpV17)
tierSThresh        = input.int(75,   "S-Tier Confidence Threshold",      minval=65, maxval=95, step=5,  group=grpV17)
tierAThresh        = input.int(65,   "A-Tier Confidence Threshold",      minval=55, maxval=80, step=5,  group=grpV17)
staleFeedBars      = input.int(10,   "Stale Feed Threshold (bars)",      minval=5,  maxval=30,          group=grpV17)
signalCooldown     = input.int(5,    "Signal Cooldown (bars)",           minval=1,  maxval=20,          group=grpV17)
minConfluence      = input.int(30,   "Min Confluence % for Signal",      minval=10, maxval=70, step=10, group=grpV17)
znRocLen           = input.int(10,   "ZN1 Rate Pressure ROC Length",     minval=5, maxval=20,           group=grpV17)

grpV18 = "V18 ELITE ENHANCEMENTS"

perfReduceVis    = input.bool(true,  "Perf Mode: Reduce Non-Essential Visuals", group=grpV18)
perfSkipHeavy    = input.bool(true,  "Perf Mode: Skip Heavy Object Rendering",  group=grpV18)
regimeLookback   = input.int(20,  "Regime Detection Lookback",  minval=10, maxval=50, group=grpV18)
volSpikeThresh   = input.float(2.5, "Volatility Spike Threshold (ATR mult)", minval=1.0, maxval=5.0, step=0.1, group=grpV18)

grpV19c = "V19 CORRELATION"
corrShortLen  = input.int(30,  "Corr Short Window",  minval=10, maxval=50,  group=grpV19c)
corrMedLen    = input.int(60,  "Corr Medium Window", minval=30, maxval=100, group=grpV19c)
corrLongLen   = input.int(120, "Corr Long Window",   minval=60, maxval=200, group=grpV19c)

//=====================================================================
// HELPER: float-to-string shorthand
//=====================================================================
ltos(val, decimals) =>
    string result = str.tostring(val)
    if decimals == 0
        result := str.tostring(val, "#")
    else if decimals == 1
        result := str.tostring(val, "#.#")
    else if decimals == 2
        result := str.tostring(val, "#.##")
    result

//=====================================================================
// CORE ENGINE
//=====================================================================

ema20  = ta.ema(close, ema20Len)
ema50  = ta.ema(close, ema50Len)
ema200 = ta.ema(close, ema200Len)

atr    = ta.atr(atrLen)

[diplus, diminus, adxVal] = ta.dmi(adxLen, adxLen)

vwapVal = ta.vwap(hlc3)

rsiVal = ta.rsi(close, rsiLen)

volSma20  = ta.sma(volume, 20)
volSma50  = ta.sma(volume, 50)
highVolume = volume > volSma20

recentBars = bar_index > last_bar_index - recentBarsLen

ema20Slope = ema20 - ema20[5]
ema50Slope = ema50 - ema50[5]

goldRet = close / nz(close[1], close) - 1

//=====================================================================
// HTF TREND STACK - 5M / 15M / 1H / 4H / 1D (zero repaint via [1])
//=====================================================================

[htf5mClose,  htf5mEma20,  htf5mEma50,  htf5mEma200] =
     request.security(syminfo.tickerid, "5",
          [close[1], ta.ema(close, 20)[1], ta.ema(close, 50)[1], ta.ema(close, 200)[1]],
          barmerge.gaps_off, barmerge.lookahead_off)

[htf15mClose, htf15mEma20, htf15mEma50, htf15mEma200] =
     request.security(syminfo.tickerid, "15",
          [close[1], ta.ema(close, 20)[1], ta.ema(close, 50)[1], ta.ema(close, 200)[1]],
          barmerge.gaps_off, barmerge.lookahead_off)

[htf1hClose,  htf1hEma20,  htf1hEma50,  htf1hEma200] =
     request.security(syminfo.tickerid, "60",
          [close[1], ta.ema(close, 20)[1], ta.ema(close, 50)[1], ta.ema(close, 200)[1]],
          barmerge.gaps_off, barmerge.lookahead_off)

[htf4hClose,  htf4hEma20,  htf4hEma50,  htf4hEma200] =
     request.security(syminfo.tickerid, "240",
          [close[1], ta.ema(close, 20)[1], ta.ema(close, 50)[1], ta.ema(close, 200)[1]],
          barmerge.gaps_off, barmerge.lookahead_off)

[htfDClose,   htfDEma20,   htfDEma50,   htfDEma200] =
     request.security(syminfo.tickerid, "D",
          [close[1], ta.ema(close, 20)[1], ta.ema(close, 50)[1], ta.ema(close, 200)[1]],
          barmerge.gaps_off, barmerge.lookahead_off)

chartTFSeconds = timeframe.in_seconds()
htf5mAvailable  = chartTFSeconds <= 300
htf15mAvailable = chartTFSeconds <= 900
htf1hAvailable  = chartTFSeconds <= 3600
htf4hAvailable  = chartTFSeconds <= 14400
htfDAvailable   = chartTFSeconds <= 86400

htfTrendScore(htfClose, htfEma20, htfEma50, htfEma200) =>
    score = 0
    score += (not na(htfClose) and not na(htfEma200) and htfClose > htfEma200) ? 40 : 0
    score += (not na(htfEma20) and not na(htfEma50)  and htfEma20 > htfEma50)  ? 40 : 0
    score += (not na(htfClose) and not na(htfEma20)  and htfClose > htfEma20)  ? 20 : 0
    score

htf5mScore  = htf5mAvailable  ? htfTrendScore(htf5mClose,  htf5mEma20,  htf5mEma50,  htf5mEma200) : 50
htf15mScore = htf15mAvailable ? htfTrendScore(htf15mClose, htf15mEma20, htf15mEma50, htf15mEma200) : 50
htf1hScore  = htf1hAvailable  ? htfTrendScore(htf1hClose,  htf1hEma20,  htf1hEma50,  htf1hEma200) : 50
htf4hScore  = htf4hAvailable  ? htfTrendScore(htf4hClose,  htf4hEma20,  htf4hEma50,  htf4hEma200) : 50
htfDScore   = htfDAvailable   ? htfTrendScore(htfDClose,   htfDEma20,   htfDEma50,   htfDEma200) : 50

htf5mBull  = htf5mScore  >= 60
htf5mBear  = htf5mScore  <= 40
htf15mBull = htf15mScore >= 60
htf15mBear = htf15mScore <= 40
htf1hBull  = htf1hScore  >= 60
htf1hBear  = htf1hScore  <= 40
htf4hBull  = htf4hScore  >= 60
htf4hBear  = htf4hScore  <= 40
htfDBull   = htfDScore   >= 60
htfDBear   = htfDScore   <= 40

htfAlignmentLong  = (htf1hBull ? 1 : 0) + (htf4hBull ? 1 : 0) + (htfDBull ? 1 : 0)
htfAlignmentShort = (htf1hBear ? 1 : 0) + (htf4hBear ? 1 : 0) + (htfDBear ? 1 : 0)

htfBullGate = htfAlignmentLong  >= 2
htfBearGate = htfAlignmentShort >= 2

htfFullLong  = (htf5mBull  ? 1 : 0) + (htf15mBull ? 1 : 0) + (htf1hBull ? 1 : 0) + (htf4hBull ? 1 : 0) + (htfDBull ? 1 : 0)
htfFullShort = (htf5mBear  ? 1 : 0) + (htf15mBear ? 1 : 0) + (htf1hBear ? 1 : 0) + (htf4hBear ? 1 : 0) + (htfDBear ? 1 : 0)

//=====================================================================
// ADAPTIVE ATR REGIME ENGINE
//=====================================================================

atrTrending = ta.atr(7)
atrRanging  = ta.atr(21)

_rawAdaptiveATR = showAdaptiveATR ? (adxVal > adxThreshold ? atrTrending : atrRanging) : atr
adaptiveATR     = math.max(nz(_rawAdaptiveATR, ta.tr), 0.10)

atrPercentile = ta.percentrank(adaptiveATR, 50)

[bbMiddle, bbUpper, bbLower] = ta.bb(close, 20, 2)
bbWidth = (bbUpper - bbLower) / ema20
bbWidthPercentile = ta.percentrank(bbWidth, 50)

adxSlope = adxVal - adxVal[5]

regimeTrending = adxVal > adxThreshold
regimeRanging  = adxVal <= adxThreshold and adxVal > 15
regimeDead     = adxVal <= 15

//=====================================================================
// SESSION ENGINE
//=====================================================================

hourUTC = hour(time, "UTC")

inAsian        = hourUTC >= 0  and hourUTC < 7
inLondon       = hourUTC >= 7  and hourUTC < 16
inNY           = hourUTC >= 13 and hourUTC < 21
inLondonKZ     = hourUTC >= 8  and hourUTC < 11
inLondonFixKZ  = hourUTC >= 10 and hourUTC < 11
inNYKZ         = hourUTC >= 13 and hourUTC < 16
inLondonCloseKZ= hourUTC >= 15 and hourUTC < 17
inKillzone     = inLondonKZ or inNYKZ or inLondonCloseKZ or inLondonFixKZ

sessionQuality = 0
sessionQuality += inKillzone ? 40 : inLondon or inNY ? 25 : inAsian ? 10 : 0
sessionQuality += inLondonFixKZ ? 20 : 0
sessionQuality += inNYKZ ? 15 : 0
sessionQuality += (not inAsian or inLondonKZ) ? 10 : 0
sessionQuality += (inLondon and not inLondonKZ) ? 5 : 0

sessionLabel = inKillzone ? (inLondonFixKZ ? "LON-FIX" : inLondonKZ ? "LON-KZ" : inNYKZ ? "NY-KZ" : inLondonCloseKZ ? "LON-CL" : "KZ") : inLondon ? "LONDON" : inNY ? "NY" : inAsian ? "ASIAN" : "OFF"

bgcolor(showSessions and not perfMode ? (inLondon ? color.new(#F59E0B, 97) : inNY ? color.new(#3B82F6, 97) : inAsian ? color.new(#64748B, 98) : na) : na, title="Session Shading")

//=====================================================================
// MACRO ENGINE - 5 core assets only (DXY, US10Y, Silver, EURUSD, SPX)
//=====================================================================

[_rawDXY, _rawDXYFast, _rawDXYSlow, _rawDXYRoc] =
     request.security("TVC:DXY", macroTF,
          [close[1], ta.ema(close, 10)[1], ta.ema(close, 20)[1], ta.roc(close, dxyRocLen)[1]],
          barmerge.gaps_off, barmerge.lookahead_off, ignore_invalid_symbol=true)
[_rawYield, _rawYieldFast, _rawYieldSlow, _rawYieldRoc] =
     request.security("CBOT:ZN1!", macroTF,
          [close[1], ta.ema(close, 10)[1], ta.ema(close, 20)[1], ta.roc(close, znRocLen)[1]],
          barmerge.gaps_off, barmerge.lookahead_off, ignore_invalid_symbol=true)
[_rawSilver, _rawSilverEMA] =
     request.security("OANDA:XAGUSD", timeframe.period,
          [close[1], ta.ema(close, 20)[1]],
          barmerge.gaps_off, barmerge.lookahead_off, ignore_invalid_symbol=true)
[_rawEURUSD, _rawEURFast, _rawEURSlow, _rawEURRoc] =
     request.security("OANDA:EURUSD", timeframe.period,
          [close[1], ta.ema(close, 10)[1], ta.ema(close, 20)[1], ta.roc(close, znRocLen)[1]],
          barmerge.gaps_off, barmerge.lookahead_off, ignore_invalid_symbol=true)
[_rawSPX, _rawSPXFast, _rawSPXSlow] =
     request.security("SP:SPX", timeframe.period,
          [close[1], ta.ema(close, 10)[1], ta.ema(close, 20)[1]],
          barmerge.gaps_off, barmerge.lookahead_off, ignore_invalid_symbol=true)

var float cachedDXY    = na
var float cachedYield  = na
var float cachedSilver = na
var float cachedEURUSD = na
var float cachedSPX    = na
var int dxyStaleCount    = 0
var int yieldStaleCount  = 0
var int silverStaleCount = 0
var int eurusdStaleCount = 0
var int spxStaleCount    = 0

if not na(_rawDXY)
    cachedDXY     := _rawDXY
    dxyStaleCount := 0
else
    dxyStaleCount := dxyStaleCount + 1
if not na(_rawYield)
    cachedYield    := _rawYield
    yieldStaleCount := 0
else
    yieldStaleCount := yieldStaleCount + 1
if not na(_rawSilver)
    cachedSilver    := _rawSilver
    silverStaleCount := 0
else
    silverStaleCount := silverStaleCount + 1
if not na(_rawEURUSD)
    cachedEURUSD    := _rawEURUSD
    eurusdStaleCount := 0
else
    eurusdStaleCount := eurusdStaleCount + 1
if not na(_rawSPX)
    cachedSPX    := _rawSPX
    spxStaleCount := 0
else
    spxStaleCount := spxStaleCount + 1

dxyClose    = cachedDXY
yieldClose  = cachedYield
silverClose = cachedSilver
eurusdClose = cachedEURUSD
spxClose    = cachedSPX

dxyValid    = not na(dxyClose) and not na(_rawDXYFast) and not na(_rawDXYSlow)
yieldValid  = not na(yieldClose) and not na(_rawYieldFast) and not na(_rawYieldSlow)
silverValid = not na(silverClose) and not na(_rawSilverEMA)
eurusdValid = not na(eurusdClose) and not na(_rawEURFast) and not na(_rawEURSlow)
spxValid    = not na(spxClose) and not na(_rawSPXFast) and not na(_rawSPXSlow)

dxyEMAFast    = _rawDXYFast
dxyEMASlow    = _rawDXYSlow
yieldEMAFast  = _rawYieldFast
yieldEMASlow  = _rawYieldSlow
eurusdEMAFast = _rawEURFast
eurusdEMASlow = _rawEURSlow
spxEMAFast    = _rawSPXFast
spxEMASlow    = _rawSPXSlow
silverEMA     = _rawSilverEMA

dxyBull = dxyValid and dxyClose > dxyEMAFast and dxyEMAFast > dxyEMASlow
dxyBear = dxyValid and dxyClose < dxyEMAFast and dxyEMAFast < dxyEMASlow
yieldRising  = yieldValid and yieldClose > yieldEMAFast and yieldEMAFast > yieldEMASlow
yieldFalling = yieldValid and yieldClose < yieldEMAFast and yieldEMAFast < yieldEMASlow
eurusdBull = eurusdValid and eurusdClose > eurusdEMAFast and eurusdEMAFast > eurusdEMASlow
eurusdBear = eurusdValid and eurusdClose < eurusdEMAFast and eurusdEMAFast < eurusdEMASlow
spxBull    = spxValid    and spxClose    > spxEMAFast    and spxEMAFast    > spxEMASlow
spxBear    = spxValid    and spxClose    < spxEMAFast    and spxEMAFast    < spxEMASlow

macroBullVotes = (dxyBear ? 1 : 0) + (yieldFalling ? 1 : 0) + (spxBull ? 1 : 0) + (eurusdBull ? 1 : 0)
macroBearVotes = (dxyBull ? 1 : 0) + (yieldRising  ? 1 : 0) + (spxBear ? 1 : 0) + (eurusdBear ? 1 : 0)
macroBull = macroBullVotes >= 3
macroBear = macroBearVotes >= 3

dxyROC      = dxyValid ? nz(_rawDXYRoc, 0.0) : 0.0
dxyMomBull  = dxyROC >  0.15
dxyMomBear  = dxyROC < -0.15
znROC          = yieldValid ? nz(_rawYieldRoc, 0.0) : 0.0
eurusdROC      = eurusdValid ? nz(_rawEURRoc, 0.0) : 0.0
ratePressure   = znROC + eurusdROC
ratePressureBull = ratePressure >  0.1
ratePressureBear = ratePressure < -0.1

goldBarDir    = close > close[1]  ? 1 : close < close[1]  ? -1 : 0
dxyBarDir_raw = dxyValid ? (dxyClose > dxyClose[1] ? 1 : dxyClose < dxyClose[1] ? -1 : 0) : 0
var int corrBreakCount = 0
if goldBarDir == dxyBarDir_raw and goldBarDir != 0
    corrBreakCount := corrBreakCount + 1
else
    corrBreakCount := 0
corrBreakdown = showCorrHealth and corrBreakCount >= corrHealthBars

silverRet = silverValid ? silverClose / nz(silverClose[1], silverClose) - 1 : 0.0
dxyRet    = dxyValid    ? dxyClose    / nz(dxyClose[1], dxyClose) - 1 : 0.0
yieldRet  = yieldValid  ? yieldClose  / nz(yieldClose[1], yieldClose) - 1 : 0.0
eurRet    = eurusdValid ? eurusdClose / nz(eurusdClose[1], eurusdClose) - 1 : 0.0
spxRet    = spxValid    ? spxClose    / nz(spxClose[1], spxClose) - 1 : 0.0

//=====================================================================
// CORRELATION - 5 assets x 3 windows
//=====================================================================

_ccGoldDXY_30  = ta.correlation(goldRet, dxyRet,    corrShortLen)
_ccGoldDXY_60  = ta.correlation(goldRet, dxyRet,    corrMedLen)
_ccGoldDXY_120 = ta.correlation(goldRet, dxyRet,    corrLongLen)
_ccGoldYld_30  = ta.correlation(goldRet, yieldRet,  corrShortLen)
_ccGoldYld_60  = ta.correlation(goldRet, yieldRet,  corrMedLen)
_ccGoldYld_120 = ta.correlation(goldRet, yieldRet,  corrLongLen)
_ccGoldSlv_30  = ta.correlation(goldRet, silverRet, corrShortLen)
_ccGoldSlv_60  = ta.correlation(goldRet, silverRet, corrMedLen)
_ccGoldSlv_120 = ta.correlation(goldRet, silverRet, corrLongLen)
_ccGoldSPX_30  = ta.correlation(goldRet, spxRet,    corrShortLen)
_ccGoldSPX_60  = ta.correlation(goldRet, spxRet,    corrMedLen)
_ccGoldSPX_120 = ta.correlation(goldRet, spxRet,    corrLongLen)
_ccGoldEUR_30  = ta.correlation(goldRet, eurRet,    corrShortLen)
_ccGoldEUR_60  = ta.correlation(goldRet, eurRet,    corrMedLen)
_ccGoldEUR_120 = ta.correlation(goldRet, eurRet,    corrLongLen)

corrGoldDXY_30  = dxyValid    ? _ccGoldDXY_30  : na
corrGoldDXY_60  = dxyValid    ? _ccGoldDXY_60  : na
corrGoldDXY_120 = dxyValid    ? _ccGoldDXY_120 : na
corrGoldYld_30  = yieldValid  ? _ccGoldYld_30  : na
corrGoldYld_60  = yieldValid  ? _ccGoldYld_60  : na
corrGoldYld_120 = yieldValid  ? _ccGoldYld_120 : na
corrGoldSlv_30  = silverValid ? _ccGoldSlv_30  : na
corrGoldSlv_60  = silverValid ? _ccGoldSlv_60  : na
corrGoldSlv_120 = silverValid ? _ccGoldSlv_120 : na
corrGoldSPX_30  = spxValid    ? _ccGoldSPX_30  : na
corrGoldSPX_60  = spxValid    ? _ccGoldSPX_60  : na
corrGoldSPX_120 = spxValid    ? _ccGoldSPX_120 : na
corrGoldEUR_30  = eurusdValid ? _ccGoldEUR_30  : na
corrGoldEUR_60  = eurusdValid ? _ccGoldEUR_60  : na
corrGoldEUR_120 = eurusdValid ? _ccGoldEUR_120 : na

avgCorrDXY = (nz(corrGoldDXY_30) + nz(corrGoldDXY_60) + nz(corrGoldDXY_120)) / 3.0
avgCorrYld = (nz(corrGoldYld_30) + nz(corrGoldYld_60) + nz(corrGoldYld_120)) / 3.0
avgCorrSlv = (nz(corrGoldSlv_30) + nz(corrGoldSlv_60) + nz(corrGoldSlv_120)) / 3.0
avgCorrSPX = (nz(corrGoldSPX_30) + nz(corrGoldSPX_60) + nz(corrGoldSPX_120)) / 3.0
avgCorrEUR = (nz(corrGoldEUR_30) + nz(corrGoldEUR_60) + nz(corrGoldEUR_120)) / 3.0

stabDXY = math.abs(nz(corrGoldDXY_30) - nz(corrGoldDXY_120))
stabYld = math.abs(nz(corrGoldYld_30) - nz(corrGoldYld_120))
stabSlv = math.abs(nz(corrGoldSlv_30) - nz(corrGoldSlv_120))
stabSPX = math.abs(nz(corrGoldSPX_30) - nz(corrGoldSPX_120))
stabEUR = math.abs(nz(corrGoldEUR_30) - nz(corrGoldEUR_120))
avgStability = (stabDXY + stabYld + stabSlv + stabSPX + stabEUR) / 5.0

corrHealthDXY = dxyValid    ? (avgCorrDXY < -0.3 ? 100 : avgCorrDXY < 0 ? 70 : avgCorrDXY < 0.3 ? 40 : 20) : 0
corrHealthYld = yieldValid  ? (avgCorrYld < -0.3 ? 100 : avgCorrYld < 0 ? 70 : avgCorrYld < 0.3 ? 40 : 20) : 0
corrHealthSlv = silverValid ? (avgCorrSlv > 0.3 ? 100 : avgCorrSlv > 0 ? 70 : avgCorrSlv > -0.3 ? 40 : 20) : 0
corrHealthSPX = spxValid    ? (avgCorrSPX > 0.3 ? 100 : avgCorrSPX > 0 ? 70 : avgCorrSPX > -0.3 ? 40 : 20) : 0
corrHealthEUR = eurusdValid ? (avgCorrEUR > 0.3 ? 100 : avgCorrEUR > 0 ? 70 : avgCorrEUR > -0.3 ? 40 : 20) : 0
avgCorrHealth = (corrHealthDXY + corrHealthYld + corrHealthSlv + corrHealthSPX + corrHealthEUR) / 5.0

_wDXYr = math.min(math.abs(avgCorrDXY) * 100, 30)
_wYldr = math.min(math.abs(avgCorrYld) * 100, 30)
_wSlvr = math.min(math.abs(avgCorrSlv) * 100, 25)
_wSPXr = spxValid    ? 15.0 : 0.0
_wEURr = eurusdValid ? 20.0 : 0.0
_wTot  = _wDXYr + _wYldr + _wSlvr + _wSPXr + _wEURr
wDXY = _wTot > 0 ? _wDXYr / _wTot * 100 : 30.0
wYld = _wTot > 0 ? _wYldr / _wTot * 100 : 25.0
wSlv = _wTot > 0 ? _wSlvr / _wTot * 100 : 20.0
wSPX = _wTot > 0 ? _wSPXr / _wTot * 100 : 15.0
wEUR = _wTot > 0 ? _wEURr / _wTot * 100 : 20.0

msDXY = dxyValid    ? (dxyBear ? wDXY : dxyBull ? -wDXY : 0.0) : 0.0
msYld = yieldValid  ? (yieldFalling ? wYld : yieldRising ? -wYld : 0.0) : 0.0
msSPX = spxValid    ? (spxBull ? wSPX : spxBear ? -wSPX : 0.0) : 0.0
msEUR = eurusdValid ? (eurusdBull ? wEUR : eurusdBear ? -wEUR : 0.0) : 0.0
msSlv = silverValid ? (silverClose > silverEMA ? wSlv : silverClose < silverEMA ? -wSlv : 0.0) : 0.0
msMom = dxyValid    ? (dxyMomBear ? 10.0 : dxyMomBull ? -10.0 : 0.0) : 0.0

macroStrengthScore = int(math.max(math.min(msDXY + msYld + msSPX + msEUR + msSlv + msMom, 100), -100))
macroStrengthConf  = math.abs(macroStrengthScore)

//=====================================================================
// WEIGHTED TREND ENGINE
//=====================================================================

bullTrendScore = 0
bullTrendScore += close > ema200  ? 25 : 0
bullTrendScore += ema20 > ema50   ? 25 : 0
bullTrendScore += diplus > diminus ? 20 : 0
bullTrendScore += adxVal > adxThreshold ? 20 : 0
bullTrendScore += close > ema50   ? 10 : 0

bearTrendScore = 0
bearTrendScore += close < ema200  ? 25 : 0
bearTrendScore += ema20 < ema50   ? 25 : 0
bearTrendScore += diminus > diplus ? 20 : 0
bearTrendScore += adxVal > adxThreshold ? 20 : 0
bearTrendScore += close < ema50   ? 10 : 0

bullTrend = bullTrendScore >= trendThreshold
bearTrend = bearTrendScore >= trendThreshold

//=====================================================================
// PIVOT ENGINE
//=====================================================================

pivotHigh = ta.pivothigh(high, pivotLen, pivotLen)
pivotLow  = ta.pivotlow(low,  pivotLen, pivotLen)

var float activeResistance = na
var float activeSupport    = na
var float[] brokenResistances = array.new_float()
var float[] brokenSupports    = array.new_float()
var float   lastBrokenRes     = na
var float   lastBrokenSup     = na

bosResistanceSnap = activeResistance
bosSupportSnap    = activeSupport

if not na(pivotHigh)
    if not na(activeResistance)
        array.push(brokenResistances, activeResistance)
        lastBrokenRes := activeResistance
        if array.size(brokenResistances) > 20
            array.shift(brokenResistances)
    activeResistance := pivotHigh

if not na(pivotLow)
    if not na(activeSupport)
        array.push(brokenSupports, activeSupport)
        lastBrokenSup := activeSupport
        if array.size(brokenSupports) > 20
            array.shift(brokenSupports)
    activeSupport := pivotLow

if not na(activeResistance) and close > activeResistance and close[1] <= activeResistance[1] and volume > volSma20
    array.push(brokenResistances, activeResistance)
    lastBrokenRes := activeResistance
    activeResistance := na
    if array.size(brokenResistances) > 20
        array.shift(brokenResistances)

if not na(activeSupport) and close < activeSupport and close[1] >= activeSupport[1] and volume > volSma20
    array.push(brokenSupports, activeSupport)
    lastBrokenSup := activeSupport
    activeSupport := na
    if array.size(brokenSupports) > 20
        array.shift(brokenSupports)

resistanceLevel = activeResistance
supportLevel    = activeSupport

//=====================================================================
// BOS / CHOCH
//=====================================================================

bullBOS = not na(bosResistanceSnap) and close > bosResistanceSnap and close[1] <= bosResistanceSnap[1] and bosResistanceSnap != lastBrokenRes and adxVal > adxThreshold and highVolume
bearBOS = not na(bosSupportSnap)    and close < bosSupportSnap    and close[1] >= bosSupportSnap[1]    and bosSupportSnap  != lastBrokenSup  and adxVal > adxThreshold and highVolume

bullCHOCH = bullBOS and bearTrend[1]
bearCHOCH = bearBOS and bullTrend[1]

bodySize    = math.abs(close - open)
candleRange = high - low

displacementUp   = showDisplacement and bodySize > adaptiveATR * dispMult and close > open and close > high[1] and candleRange > 0 and close >= (low + candleRange * 0.75)
displacementDown = showDisplacement and bodySize > adaptiveATR * dispMult and close < open and close < low[1]  and candleRange > 0 and close <= (low + candleRange * 0.25)

//=====================================================================
// RSI DIVERGENCE FILTER
//=====================================================================

rsiBull    = ta.rsi(close, rsiLen)
priceLL    = ta.lowest(low,   rsiDivLookback)
priceHH    = ta.highest(high, rsiDivLookback)
rsiLowest  = ta.lowest(rsiBull,  rsiDivLookback)
rsiHighest = ta.highest(rsiBull, rsiDivLookback)

bullRsiDiv = useRsiDivFilter ? (low <= priceLL * 1.001 and rsiBull > rsiLowest * 1.02) : true
bearRsiDiv = useRsiDivFilter ? (high >= priceHH * 0.999 and rsiBull < rsiHighest * 0.98) : true

//=====================================================================
// STRUCTURE VISUALS
//=====================================================================

plotshape(showSignals and recentBars and barstate.isconfirmed and bullBOS and not (perfMode and perfReduceVis), style=shape.triangleup,   location=location.belowbar, color=cBull, size=size.small, title="Bull BOS")
plotshape(showSignals and recentBars and barstate.isconfirmed and bearBOS and not (perfMode and perfReduceVis), style=shape.triangledown, location=location.abovebar, color=cBear, size=size.small, title="Bear BOS")
plotshape(showSignals and recentBars and barstate.isconfirmed and bullCHOCH and not (perfMode and perfReduceVis), style=shape.diamond, location=location.belowbar, color=cForecast, size=size.small, title="Bull CHOCH")
plotshape(showSignals and recentBars and barstate.isconfirmed and bearCHOCH and not (perfMode and perfReduceVis), style=shape.diamond, location=location.abovebar, color=cWarning,  size=size.small, title="Bear CHOCH")
plotshape(displacementUp   and recentBars and barstate.isconfirmed and not (perfMode and perfReduceVis), style=shape.labelup,   location=location.belowbar, color=color.new(#3B82F6, 20), size=size.tiny, title="Displacement Up")
plotshape(displacementDown and recentBars and barstate.isconfirmed and not (perfMode and perfReduceVis), style=shape.labeldown, location=location.abovebar, color=color.new(#8B5CF6, 20), size=size.tiny, title="Displacement Down")

//=====================================================================
// EQH / EQL
//=====================================================================

eqTolerance = adaptiveATR * eqAtrMult

var float swingHigh1 = na
var float swingHigh2 = na
var float swingLow1  = na
var float swingLow2  = na

if not na(pivotHigh)
    swingHigh2 := swingHigh1
    swingHigh1 := pivotHigh
if not na(pivotLow)
    swingLow2 := swingLow1
    swingLow1 := pivotLow

equalHighs = not na(swingHigh1) and not na(swingHigh2) and math.abs(swingHigh1 - swingHigh2) <= eqTolerance
equalLows  = not na(swingLow1)  and not na(swingLow2)  and math.abs(swingLow1  - swingLow2)  <= eqTolerance

var bool eqhPlotted = false
var bool eqlPlotted = false
if equalHighs and not eqhPlotted
    eqhPlotted := true
if not equalHighs
    eqhPlotted := false
if equalLows and not eqlPlotted
    eqlPlotted := true
if not equalLows
    eqlPlotted := false

plotshape(showEQ and recentBars and equalHighs and not eqhPlotted[1] and not (perfMode and perfReduceVis), style=shape.circle, location=location.abovebar, color=cBear, size=size.tiny, title="EQH")
plotshape(showEQ and recentBars and equalLows  and not eqlPlotted[1] and not (perfMode and perfReduceVis), style=shape.circle, location=location.belowbar, color=cBull, size=size.tiny, title="EQL")

//=====================================================================
// VOLUME CLIMAX
//=====================================================================

volPercentile = ta.percentrank(volume, volLookback)
climaxUp   = showClimax and recentBars and volPercentile >= volClimaxPerc and close > open
climaxDown = showClimax and recentBars and volPercentile >= volClimaxPerc and close < open

//=====================================================================
// QUALITY SCORE FUNCTIONS
//=====================================================================

fvgQualityScore(bool isBull, float fvgGap, float atr_, float volPct_, bool htfBull_, bool htfBear_) =>
    float disp = atr_ > 0 ? fvgGap / atr_ : 0.0
    float s = 0.0
    s += disp >= 2.5 ? 40.0 : disp >= 1.5 ? 30.0 : disp >= 1.0 ? 20.0 : disp >= 0.5 ? 10.0 : 0.0
    s += volPct_ >= 90 ? 30.0 : volPct_ >= 75 ? 25.0 : volPct_ >= 60 ? 20.0 : volPct_ >= 40 ? 10.0 : 0.0
    s += (isBull and htfBull_) or (not isBull and htfBear_) ? 20.0 : 0.0
    s += 10.0
    int(math.min(s, 100))

obQualityScore(bool isBull, float body_, float atr_, float volPct_, bool htfBull_, bool htfBear_, bool cUp_, bool cDn_, bool dUp_, bool dDn_) =>
    float disp = atr_ > 0 ? body_ / atr_ : 0.0
    float s = 0.0
    s += disp >= 2.5 ? 35.0 : disp >= 1.5 ? 28.0 : disp >= 1.0 ? 20.0 : disp >= 0.5 ? 12.0 : 0.0
    s += volPct_ >= 90 ? 30.0 : volPct_ >= 75 ? 24.0 : volPct_ >= 60 ? 18.0 : volPct_ >= 40 ? 10.0 : 0.0
    s += (isBull and htfBull_) or (not isBull and htfBear_) ? 20.0 : 0.0
    s += (isBull and (cUp_ or dUp_)) or (not isBull and (cDn_ or dDn_)) ? 15.0 : 0.0
    int(math.min(s, 100))

//=====================================================================
// FVG DETECTION ENGINE - full auto mode only (no manual override)
//=====================================================================

fvgDetected = showFVG and (high[2] < low[0] or low[2] > high[0])

var float fvgHighUpper = na
var float fvgHighLower = na
var float fvgLowUpper  = na
var float fvgLowLower  = na
var int   fvgBarIndex  = -1
var float fvgAtrAtDetect = na
var float fvgVolPctAtDetect = na
var bool  fvgActive     = false
var bool  fvgWasBullish  = false

if fvgDetected and not fvgActive
    float gapLow  = high[2]
    float gapHigh = low[0]
    if low[2] > high[0]
        gapLow  := low[0]
        gapHigh := high[2]
    if gapLow < gapHigh
        fvgHighUpper    := gapHigh
        fvgHighLower    := na
        fvgLowUpper     := na
        fvgLowLower     := gapLow
        fvgBarIndex     := bar_index
        fvgAtrAtDetect  := adaptiveATR
        fvgVolPctAtDetect := volPercentile
        fvgActive       := true
        fvgWasBullish   := low[2] > high[0]

fvgActive := fvgActive and bar_index - fvgBarIndex <= fvgMaxBars and (fvgWasBullish ? close >= fvgLowLower - adaptiveATR * 0.5 : close <= fvgHighUpper + adaptiveATR * 0.5)

fvgMitigated = fvgActive and ((fvgWasBullish and low <= fvgHighUpper) or (not fvgWasBullish and high >= fvgLowLower))

if fvgMitigated
    fvgActive := false

float fvgGapSize = not na(fvgHighUpper) and not na(fvgLowLower) ? fvgHighUpper - fvgLowLower : na

fvgUpperLine = fvgActive and fvgWasBullish     ? fvgLowLower  : fvgActive and not fvgWasBullish ? fvgHighUpper : na
fvgLowerLine = fvgActive and fvgWasBullish     ? fvgHighUpper : fvgActive and not fvgWasBullish ? fvgLowLower  : na

fvgScore = fvgActive and not na(fvgGapSize) and not na(fvgAtrAtDetect) and not na(fvgVolPctAtDetect) ? fvgQualityScore(fvgWasBullish, fvgGapSize, fvgAtrAtDetect, fvgVolPctAtDetect, htf1hBull, htf1hBear) : na

//=====================================================================
// FVG FILL / MITIGATION
//=====================================================================

var float fvgFillOriginBullLow = na
var float fvgFillOriginBearHigh = na
var int   fvgFillBarIndex = -1

fvgFillBullCondition = fvgFillPct > 0 and fvgActive and fvgWasBullish and not na(fvgHighUpper) and not na(fvgLowLower)
fvgFillBearCondition = fvgFillPct > 0 and fvgActive and not fvgWasBullish and not na(fvgHighUpper) and not na(fvgLowLower)

if fvgFillBullCondition and not na(fvgFillOriginBullLow)
    float range_ = fvgHighUpper - fvgLowLower
    float filledPct = (close - fvgLowLower) / range_ * 100.0
    if filledPct >= fvgFillPct
        fvgActive := false
        fvgFillOriginBullLow := na
if fvgFillBearCondition and not na(fvgFillOriginBearHigh)
    float range_ = fvgHighUpper - fvgLowLower
    float filledPct = (fvgHighUpper - close) / range_ * 100.0
    if filledPct >= fvgFillPct
        fvgActive := false
        fvgFillOriginBearHigh := na

if not na(fvgFillOriginBullLow)
    fvgHighLower := na
    fvgLowUpper  := na

//=====================================================================
// ORDER BLOCK DETECTION
//=====================================================================

bullBodyLong  = close > open and bodySize > adaptiveATR * obAtrMult and (close - open) > (high - low) * 0.6
bearBodyLong  = open > close and bodySize > adaptiveATR * obAtrMult and (open - close) > (high - low) * 0.6
bullWickUp    = high - math.max(open, close) < bodySize * 0.3
bearWickUp    = high - math.max(open, close) >= bodySize * 0.4
bearWickDown  = math.min(open, close) - low   < bodySize * 0.3
bullWickDown  = math.min(open, close) - low   >= bodySize * 0.4

bullOB = showOB and bullBodyLong and bullWickUp and bearWickDown and volume > volSma20
bearOB = showOB and bearBodyLong and bearWickUp and bullWickDown and volume > volSma20

var float obBullLow  = na
var float obBullHigh = na
var float obBearLow  = na
var float obBearHigh = na
var int   obBullBar  = -1
var int   obBearBar  = -1
var bool  obBullActive = false
var bool  obBearActive = false
var float obBullVolPct = na
var float obBearVolPct = na

if bearOB and not obBearActive
    obBearHigh    := high
    obBearLow     := low
    obBearBar     := bar_index
    obBearVolPct  := volPercentile
    obBearActive  := true

if bullOB and not obBullActive
    obBullHigh    := high
    obBullLow     := low
    obBullBar     := bar_index
    obBullVolPct  := volPercentile
    obBullActive  := true

obBullActive := obBullActive and bar_index - obBullBar <= obMaxBars
obBearActive := obBearActive and bar_index - obBearBar <= obMaxBars

if obBullActive and close < obBullLow - adaptiveATR * 0.3
    obBullActive := false
if obBearActive and close > obBearHigh + adaptiveATR * 0.3
    obBearActive := false

obBullScore = obBullActive and not na(obBullHigh) and not na(obBullLow) and not na(adaptiveATR) and not na(obBullVolPct) ? obQualityScore(true, obBullHigh - obBullLow, adaptiveATR, obBullVolPct, htf1hBull, htf1hBear, displacementUp, displacementDown, climaxUp, climaxDown) : na
obBearScore = obBearActive and not na(obBearHigh) and not na(obBearLow) and not na(adaptiveATR) and not na(obBearVolPct) ? obQualityScore(false, obBearHigh - obBearLow, adaptiveATR, obBearVolPct, htf1hBull, htf1hBear, displacementUp, displacementDown, climaxUp, climaxDown) : na

//=====================================================================
// SUPPORT / RESISTANCE - fractal + volume-weighted clustering
//=====================================================================

var float[] srLevels       = array.new_float()
var float[] srStrengths    = array.new_float()
var int   maxSRLevels      = 10
var int   srScanLen        = 150

if barstate.isconfirmed and bar_index > 100
    for i = 1 to srScanLen
        if i >= bar_index - 2
            break
        if not na(high[i]) and not na(high[i+1]) and not na(high[i-1])
            if high[i] > high[i+1] and high[i] >= high[i-1]
                float clusterThreshold = high[i] * 0.001
                bool   alreadyExists = false
                float  closestDist  = 1e10
                int    closestIdx   = -1
                int srCount = array.size(srLevels)
                if srCount > 0
                    for j = 0 to srCount - 1
                        float lev = array.get(srLevels, j)
                        if math.abs(lev - high[i]) / lev < clusterThreshold
                            alreadyExists := true
                            closestDist  := math.abs(lev - high[i])
                            closestIdx   := j
                            break
                if not alreadyExists
                    if array.size(srLevels) < maxSRLevels
                        array.push(srLevels, high[i])
                        array.push(srStrengths, 1.0)
                    else
                        int strCount = array.size(srStrengths)
                        if strCount > 0
                            int minIdx = 0
                            float minStr = array.get(srStrengths, 0)
                            for j = 1 to strCount - 1
                                float s = array.get(srStrengths, j)
                                if s < minStr
                                    minStr := s
                                    minIdx := j
                            if minStr < 2.0
                                array.set(srLevels, minIdx, high[i])
                                array.set(srStrengths, minIdx, 1.0)

resistanceCluster = array.size(srLevels) > 0 ? array.get(srLevels, 0) : na
supportCluster    = array.size(srLevels) > 1 ? array.get(srLevels, 1) : na

//=====================================================================
// LIQUIDITY LEVELS
//=====================================================================

var float liquidHigh = na
var float liquidLow  = na
var int   liqScanBack = 30

if barstate.isconfirmed and bar_index > liqScanBack
    liquidHigh := ta.highest(high, liqScanBack)
    liquidLow  := ta.lowest(low,  liqScanBack)

bool tookPdH = not na(liquidHigh) and close > liquidHigh
bool tookPdL = not na(liquidLow)  and close < liquidLow

//=====================================================================
// SMT DIVERGENCE
//=====================================================================

goldRSI = rsiVal
_silverRSI =
     request.security("OANDA:XAGUSD", timeframe.period,
          ta.rsi(close, rsiLen)[1],
          barmerge.gaps_on, barmerge.lookahead_off, ignore_invalid_symbol=true)

bool smtDataValid = showSMT and silverValid and not na(goldRSI) and not na(_silverRSI)

smtBearPair = smtDataValid and goldBarDir > 0 and dxyBarDir_raw < 0 and goldRSI < _silverRSI and close > close[3]
smtBullPair = smtDataValid and goldBarDir < 0 and dxyBarDir_raw > 0 and goldRSI > _silverRSI and close < close[3]

bool smtDirValid = smtDataValid and goldBarDir != 0
smtGoldSilver = smtDirValid ? (goldRSI < _silverRSI ? 1 : -1) : 0

//=====================================================================
// REGIME ENGINE
//=====================================================================

regimeScore   = int(math.round((adxVal / 100.0) * (atrPercentile > 70 ? 1.2 : 1.0) * 100.0))
volRegime     = atrPercentile > 70 ? 100 : atrPercentile > 40 ? 60 : 30
structureRegime = (htfAlignmentLong >= 2 or htfAlignmentShort >= 2) ? 100 : (htfAlignmentLong >= 1 or htfAlignmentShort >= 1) ? 60 : 30
macroRegime   = (macroBull or macroBear) ? 100 : (macroBullVotes >= 2 or macroBearVotes >= 2) ? 60 : 30
sessionRegime = sessionQuality >= 60 ? 100 : sessionQuality >= 30 ? 60 : 20

regimeComposite = int(math.round((regimeScore * 0.30) + (volRegime * 0.15) + (structureRegime * 0.20) + (macroRegime * 0.20) + (sessionRegime * 0.15)))

bool strongTrend  = regimeComposite >= 70
bool moderateTrend = regimeComposite >= 40 and regimeComposite < 70
bool weakTrend     = regimeComposite < 40

//=====================================================================
// LIQUIDITY POOL TRACKING
//=====================================================================

var float poolPdH  = na
var float poolPdL  = na
var float poolPwH  = na
var float poolPwL  = na
var float poolEqH  = na
var float poolEqL  = na
var float intraHigh = na
var float intraLow  = na

poolPdH := ta.highest(high, pdlLen)
poolPdL := ta.lowest(low,   pdlLen)
poolPwH := ta.highest(high, pwlLen)
poolPwL := ta.lowest(low,   pwlLen)
poolEqH := equalHighs ? math.max(swingHigh1, swingHigh2) : poolEqH
poolEqL := equalLows  ? math.min(swingLow1,  swingLow2)  : poolEqL
intraHigh := ta.highest(high, 1)
intraLow  := ta.lowest(low,  1)

bool ranPdH = not na(poolPdH) and close > poolPdH
bool ranPdL = not na(poolPdL) and close < poolPdL
bool ranPwH = not na(poolPwH) and close > poolPwH
bool ranPwL = not na(poolPwL) and close < poolPwL
bool ranEqH = not na(poolEqH) and close > poolEqH
bool ranEqL = not na(poolEqL) and close < poolEqL

//=====================================================================
// S/R LEVELS TABLE PLOT
//=====================================================================

var line[] srLines = array.new_line()
if barstate.islast
    int srLineCount = array.size(srLines)
    if srLineCount > 0
        for i = 0 to srLineCount - 1
            line.delete(array.get(srLines, i))
    array.clear(srLines)
    if array.size(srLevels) > 0
        for i = 0 to array.size(srLevels) - 1
            if i >= maxSRLevels
                break
            float lev = array.get(srLevels, i)
            float srStr = array.get(srStrengths, i)
            if not na(lev)
                color levColor = srStr >= 3 ? color.new(#FFD700, 30) : srStr >= 2 ? color.new(#C0C0C0, 40) : color.new(#808080, 50)
                array.push(srLines, line.new(x1=bar_index - 1, y1=lev, x2=bar_index, y2=lev, color=levColor, width=1, style=line.style_solid))

//=====================================================================
// V26 ENGINE 1: STRUCTURE PERSISTENCE SCORE
// Measures directional continuation after BOS/CHOCH
//   Bull: higher highs AND higher lows after bull BOS
//   Bear: lower highs AND lower lows after bear BOS
// True structural dominance, not level survival
//=====================================================================

var float   structPersistEntryHigh = na
var float   structPersistEntryLow  = na
var bool    structPersistIsBull    = false
var int     structPersistBars      = 0
var float   structScore            = 0.0
var float   structPersistPeak      = na
var float   structPersistTrough    = na

if bullBOS
    structPersistEntryHigh := close
    structPersistEntryLow  := low
    structPersistIsBull    := true
    structPersistBars      := 1
    structPersistPeak      := high
    structPersistTrough    := low
else if bearBOS
    structPersistEntryHigh := high
    structPersistEntryLow  := close
    structPersistIsBull    := false
    structPersistBars      := 1
    structPersistPeak      := high
    structPersistTrough    := low
else
    if not na(structPersistEntryHigh)
        // Bull persistence: must produce HH AND HL
        if structPersistIsBull
            bool newHH = high > structPersistPeak
            bool newHL = low > structPersistTrough
            if newHH
                structPersistPeak := high
            if newHL
                structPersistTrough := low
            if newHH or newHL
                structPersistBars := structPersistBars + 1
            else if not newHH and not newHL and structPersistBars > 3
                structPersistEntryHigh := na
                structPersistBars := 0
        // Bear persistence: must produce LH AND LL
        else
            bool newLH = high < structPersistPeak
            bool newLL = low < structPersistTrough
            if newLH
                structPersistPeak := high
            if newLL
                structPersistTrough := low
            if newLH or newLL
                structPersistBars := structPersistBars + 1
            else if not newLH and not newLL and structPersistBars > 3
                structPersistEntryHigh := na
                structPersistBars := 0

if structPersistBars > 0
    float dr = structPersistIsBull and structPersistEntryLow > 0 ? (close - structPersistEntryLow) / adaptiveATR : not structPersistIsBull and structPersistEntryHigh > 0 ? (structPersistEntryHigh - close) / adaptiveATR : 0.0
    int spBars = structPersistBars
    int spDist = dr >= 2.0 ? 35 : dr >= 1.0 ? 25 : dr >= 0.5 ? 15 : 0
    int spAdx  = adxVal > adxThreshold ? 20 : 0
    structScore := (spBars >= 12 ? 45 : spBars >= 8 ? 35 : spBars >= 4 ? 25 : 15) + spDist + spAdx
else
    structScore := 0.0

//=====================================================================  
// V26 ENGINE 2: LIQUIDITY DESTINATION RANKING
// Score = Pool Weight � Distance Score � HTF Alignment
// Pool weights: PDH/PDL=1.50, PWH/PWL=1.20, EQH/EQL=0.90
// Dist score decays linearly from 100 at 0 ATR to 0 at liqProxMult ATR
//=====================================================================

float liqPWtPDH = 1.50
float liqPWtPDL = 1.50
float liqPWtPWH = 1.20
float liqPWtPWL = 1.20
float liqPWtEQH = 0.90
float liqPWtEQL = 0.90

liqDistPDH = not na(poolPdH) ? math.abs(close - poolPdH) : 1e10
liqDistPDL = not na(poolPdL) ? math.abs(close - poolPdL) : 1e10
liqDistPWH = not na(poolPwH) ? math.abs(close - poolPwH) : 1e10
liqDistPWL = not na(poolPwL) ? math.abs(close - poolPwL) : 1e10
liqDistEQH = not na(poolEqH) ? math.abs(close - poolEqH) : 1e10
liqDistEQL = not na(poolEqL) ? math.abs(close - poolEqL) : 1e10

// Distance score: 100 when 0 ATR away ? 0 when liqProxMult ATR away
liqDistScore(dist, atrM) => atrM > 0 ? math.max(100.0 - (dist / atrM) * (100.0 / liqProxMult), 0.0) : 0.0

float liqDS_PDH = liqDistPDH < adaptiveATR * liqProxMult ? liqDistScore(liqDistPDH, adaptiveATR) : 0.0
float liqDS_PDL = liqDistPDL < adaptiveATR * liqProxMult ? liqDistScore(liqDistPDL, adaptiveATR) : 0.0
float liqDS_PWH = liqDistPWH < adaptiveATR * liqProxMult ? liqDistScore(liqDistPWH, adaptiveATR) : 0.0
float liqDS_PWL = liqDistPWL < adaptiveATR * liqProxMult ? liqDistScore(liqDistPWL, adaptiveATR) : 0.0
float liqDS_EQH = liqDistEQH < adaptiveATR * liqProxMult ? liqDistScore(liqDistEQH, adaptiveATR) : 0.0
float liqDS_EQL = liqDistEQL < adaptiveATR * liqProxMult ? liqDistScore(liqDistEQL, adaptiveATR) : 0.0

// HTF alignment factor: 1.3 if HTF agrees with pool direction, 1.0 if neutral, 0.7 if opposes
liqHTFMatch(poolIsBull) => (poolIsBull and htfBullGate) ? 1.3 : (poolIsBull and htfAlignmentLong >= 1) ? 1.15 : (not poolIsBull and htfBearGate) ? 1.3 : (not poolIsBull and htfAlignmentShort >= 1) ? 1.15 : 1.0

// Composite score = Pool Weight � Distance Score � HTF Alignment
float liqScorePDH = liqDS_PDH > 0 ? liqPWtPDH * liqDS_PDH * liqHTFMatch(true)  : 0.0
float liqScorePDL = liqDS_PDL > 0 ? liqPWtPDL * liqDS_PDL * liqHTFMatch(false) : 0.0
float liqScorePWH = liqDS_PWH > 0 ? liqPWtPWH * liqDS_PWH * liqHTFMatch(true)  : 0.0
float liqScorePWL = liqDS_PWL > 0 ? liqPWtPWL * liqDS_PWL * liqHTFMatch(false) : 0.0
float liqScoreEQH = liqDS_EQH > 0 ? liqPWtEQH * liqDS_EQH * liqHTFMatch(true)  : 0.0
float liqScoreEQL = liqDS_EQL > 0 ? liqPWtEQL * liqDS_EQL * liqHTFMatch(false) : 0.0

// Rank by composite score (highest wins)
string liqDestLabel = "�"
int    liqDestScore = 0
float  liqDestDist  = 1e10

float liqMaxScore = math.max(liqScorePDH, math.max(liqScorePDL, math.max(liqScorePWH, math.max(liqScorePWL, math.max(liqScoreEQH, liqScoreEQL)))))
if liqMaxScore > 0
    if liqScorePDH >= liqMaxScore
        liqDestLabel := "PDH"
        liqDestScore := int(math.round(liqScorePDH))
        liqDestDist  := liqDistPDH
    else if liqScorePDL >= liqMaxScore
        liqDestLabel := "PDL"
        liqDestScore := int(math.round(liqScorePDL))
        liqDestDist  := liqDistPDL
    else if liqScorePWH >= liqMaxScore
        liqDestLabel := "PWH"
        liqDestScore := int(math.round(liqScorePWH))
        liqDestDist  := liqDistPWH
    else if liqScorePWL >= liqMaxScore
        liqDestLabel := "PWL"
        liqDestScore := int(math.round(liqScorePWL))
        liqDestDist  := liqDistPWL
    else if liqScoreEQH >= liqMaxScore
        liqDestLabel := "EQH"
        liqDestScore := int(math.round(liqScoreEQH))
        liqDestDist  := liqDistEQH
    else
        liqDestLabel := "EQL"
        liqDestScore := int(math.round(liqScoreEQL))
        liqDestDist  := liqDistEQL

liqDestPrimary = liqDestLabel
liqDestDistance = liqDestDist

//=====================================================================
// V26 ENGINE 3: MTF CONFLUENCE ENGINE  
// Aggregates directional agreement across 5 TF's + 5 macro assets
//=====================================================================

mtfVotesBull = 0
mtfVotesBull += htf5mBull  ? 1 : 0
mtfVotesBull += htf15mBull ? 1 : 0
mtfVotesBull += htf1hBull  ? 1 : 0
mtfVotesBull += htf4hBull  ? 1 : 0
mtfVotesBull += htfDBull   ? 1 : 0

mtfVotesBear = 0
mtfVotesBear += htf5mBear  ? 1 : 0
mtfVotesBear += htf15mBear ? 1 : 0
mtfVotesBear += htf1hBear  ? 1 : 0
mtfVotesBear += htf4hBear  ? 1 : 0
mtfVotesBear += htfDBear   ? 1 : 0

macroVotesBull = macroBullVotes
macroVotesBear = macroBearVotes

mtfConfluenceBull = mtfVotesBull + macroVotesBull
mtfConfluenceBear = mtfVotesBear + macroVotesBear

mtfConfluenceScore = int(math.round((mtfConfluenceBull - mtfConfluenceBear) / 9.0 * 100.0))
mtfConfluenceMag   = math.abs(mtfConfluenceScore)

mtfAgreementHigh   = mtfConfluenceMag >= 60
mtfAgreementMed    = mtfConfluenceMag >= 30 and mtfConfluenceMag < 60
mtfAgreementLow    = mtfConfluenceMag < 30

//=====================================================================
// V26 ENGINE 4: MACRO INTELLIGENCE ENGINE
// Weighted directional synthesis from 5 macro inputs
//=====================================================================

macroIntelScore = macroStrengthScore
macroIntelConf  = macroStrengthConf
macroIntelValid = dxyValid or yieldValid or spxValid or eurusdValid or silverValid

string macroIntelLabel = macroIntelValid ? (macroIntelScore >= 40 ? "BULL" : macroIntelScore <= -40 ? "BEAR" : macroIntelScore >= 15 ? "BULL-ISH" : macroIntelScore <= -15 ? "BEAR-ISH" : "MIXED") : "N/A"

//=====================================================================
// V26 ENGINE 5: BAYESIAN BIAS ENGINE
// Linear-normalized directional distribution (Bull + Bear + Range = 100)
// No exp() softmax � plain weighted sum
// Evidence streams are independent (no double-counting):
//   STRUCTURE  = BOS/CHOCH score
//   LIQUIDITY  = FVG/OB/liquidity pools
//   MACRO      = 5-asset directional votes
//   HTF        = 5TF alignment
//   MOMENTUM   = RSI divergence
//   SESSION    = London/NY quality
// NOTE: Bias scores are ordinal statistics, NOT calibrated probabilities.
//       A score of 70 does NOT mean 70% probability.
//       It means the bull evidence outweighs bear evidence in this sample.
//=====================================================================

bayesPriorBull = htf1hBull or htf4hBull or htfDBull ? 33.33 : (htf1hBear or htf4hBear or htfDBear) ? 0.0 : 16.67
bayesPriorBear = htf1hBear or htf4hBear or htfDBear ? 33.33 : (htf1hBull or htf4hBull or htfDBull) ? 0.0 : 16.67
bayesPriorRange = 100.0 - bayesPriorBull - bayesPriorBear

// Evidence streams � each maps to ONE independent source
// STRUCTURE: Trend score from BOS/CHOCH engine (EMA + ADX + DMI in one composite)
bayesStructBull = bullTrend ? 30.0 : 0.0
bayesStructBear = bearTrend ? 30.0 : 0.0
// LIQUIDITY: FVG/OB zones + pool runs
bayesLiqBull = (bullBOS or displacementUp) ? 15.0 : 0.0
bayesLiqBear = (bearBOS or displacementDown) ? 15.0 : 0.0
// MACRO: 5-asset directional synthesis
bayesMacroBull = macroBull ? 15.0 : 0.0
bayesMacroBear = macroBear ? 15.0 : 0.0
// HTF: 5TF alignment (pure multi-timeframe, not overlapping with struct)
bayesHTFBull = htfBullGate ? 15.0 : (htfAlignmentLong >= 1 ? 5.0 : 0.0)
bayesHTFBear = htfBearGate ? 15.0 : (htfAlignmentShort >= 1 ? 5.0 : 0.0)
// MOMENTUM: RSI divergence (independent of EMA/ADX)
bayesMomBull = bullRsiDiv ? 15.0 : 0.0
bayesMomBear = bearRsiDiv ? 15.0 : 0.0
// SESSION: Killzone quality (independent of price action)
bayesSessBull = sessionQuality >= 50 ? 10.0 : sessionQuality >= 30 ? 5.0 : 0.0
bayesSessBear = sessionQuality >= 50 ? 10.0 : sessionQuality >= 30 ? 5.0 : 0.0

bayesLikelihoodBull = bayesStructBull + bayesLiqBull + bayesMacroBull + bayesHTFBull + bayesMomBull + bayesSessBull
bayesLikelihoodBear = bayesStructBear + bayesLiqBear + bayesMacroBear + bayesHTFBear + bayesMomBear + bayesSessBear
bayesLikelihoodRange = (regimeRanging ? 30.0 : 0.0) + (regimeDead ? 40.0 : 0.0) + (mtfAgreementLow ? 20.0 : 0.0) + (not macroBull and not macroBear and macroIntelValid ? 10.0 : 0.0) + (sessionQuality < 30 ? 10.0 : 0.0) + (avgStability > 0.3 ? 10.0 : 0.0)

totalLike = bayesLikelihoodBull + bayesLikelihoodBear + bayesLikelihoodRange

bullDirectionScore = totalLike > 0 ? int(math.round(bayesPriorBull * (1.0 + bayesLikelihoodBull / totalLike))) : 0
bearDirectionScore = totalLike > 0 ? int(math.round(bayesPriorBear * (1.0 + bayesLikelihoodBear / totalLike))) : 0
rangeDirectionScore = totalLike > 0 ? int(math.round(bayesPriorRange * (1.0 + bayesLikelihoodRange / totalLike))) : 0

totalDir = bullDirectionScore + bearDirectionScore + rangeDirectionScore
if totalDir > 0 and totalDir != 100
    float scale = 100.0 / totalDir
    bullDirectionScore := int(math.round(bullDirectionScore * scale))
    bearDirectionScore := int(math.round(bearDirectionScore * scale))
    rangeDirectionScore := 100 - bullDirectionScore - bearDirectionScore

string biasLabel = bullDirectionScore >= 55 ? "BULL" : bearDirectionScore >= 55 ? "BEAR" : rangeDirectionScore >= 55 ? "RANGE" : bullDirectionScore > bearDirectionScore ? "BULL-ISH" : bearDirectionScore > bullDirectionScore ? "BEAR-ISH" : "NEUTRAL"
biasCellColor = bullDirectionScore >= 55 ? cBull : bearDirectionScore >= 55 ? cBear : cRange

//=====================================================================
// V26 ENGINE 6: REGIME CONFIDENCE  
// Composite confidence score from trend + vol + macro + session alignment
//=====================================================================

regimeConfTrend   = adxVal >= 25 ? (adxVal >= 40 ? 100 : adxVal >= 30 ? 75 : 50) : adxVal >= 15 ? 30 : 10
regimeConfVol     = atrPercentile >= 80 ? 80 : atrPercentile >= 50 ? 60 : atrPercentile >= 20 ? 40 : 20
regimeConfStruct  = structureRegime >= 80 ? 90 : structureRegime >= 50 ? 60 : 30
regimeConfMacro   = macroIntelConf >= 60 ? 80 : macroIntelConf >= 30 ? 50 : 20
regimeConfSession = sessionRegime >= 80 ? 70 : sessionRegime >= 50 ? 50 : 30

regimeConfidence = int(math.round((regimeConfTrend * 0.30 + regimeConfVol * 0.20 + regimeConfStruct * 0.20 + regimeConfMacro * 0.20 + regimeConfSession * 0.10)))

regimeConfLow   = regimeConfidence < 30
regimeConfMed   = regimeConfidence >= 30 and regimeConfidence < 60
regimeConfHigh  = regimeConfidence >= 60

//=====================================================================
// V26 ENGINE 7: SIGNAL QUALITY ENGINE
// Multi-factor quality score for every detected structure event
//=====================================================================

var float lastSignalQuality   = 0.0
var string lastSignalType     = ""
var int    lastSignalBar      = -1

signalQualityBullBOS(score) =>
    quality = 0.0
    quality += score >= 70 ? 35.0 : score >= 50 ? 25.0 : score >= 30 ? 15.0 : 5.0
    quality += htfBullGate ? 25.0 : (htfAlignmentLong >= 1 ? 10.0 : 0.0)
    quality += macroBull ? 15.0 : 0.0
    quality += regimeConfHigh ? 15.0 : regimeConfMed ? 8.0 : 0.0
    quality += sessionQuality >= 50 ? 10.0 : 0.0
    int(math.min(math.round(quality), 100))

signalQualityBearBOS(score) =>
    quality = 0.0
    quality += score >= 70 ? 35.0 : score >= 50 ? 25.0 : score >= 30 ? 15.0 : 5.0
    quality += htfBearGate ? 25.0 : (htfAlignmentShort >= 1 ? 10.0 : 0.0)
    quality += macroBear ? 15.0 : 0.0
    quality += regimeConfHigh ? 15.0 : regimeConfMed ? 8.0 : 0.0
    quality += sessionQuality >= 50 ? 10.0 : 0.0
    int(math.min(math.round(quality), 100))

signalQualityFVG(isBull, score) =>
    quality = 0.0
    quality += not na(score) and score >= 70 ? 35.0 : not na(score) and score >= 50 ? 25.0 : not na(score) and score >= 30 ? 15.0 : 5.0
    quality += (isBull and htfBullGate) or (not isBull and htfBearGate) ? 25.0 : 0.0
    quality += (isBull and macroBull) or (not isBull and macroBear) ? 15.0 : 0.0
    quality += regimeConfHigh ? 15.0 : regimeConfMed ? 8.0 : 0.0
    quality += sessionQuality >= 50 ? 10.0 : 0.0
    int(math.min(math.round(quality), 100))

signalQualityOB(isBull, score) =>
    quality = 0.0
    quality += not na(score) and score >= 70 ? 35.0 : not na(score) and score >= 50 ? 25.0 : not na(score) and score >= 30 ? 15.0 : 5.0
    quality += (isBull and htfBullGate) or (not isBull and htfBearGate) ? 25.0 : 0.0
    quality += (isBull and macroBull) or (not isBull and macroBear) ? 15.0 : 0.0
    quality += regimeConfHigh ? 15.0 : regimeConfMed ? 8.0 : 0.0
    quality += sessionQuality >= 50 ? 10.0 : 0.0
    int(math.min(math.round(quality), 100))

if bullBOS
    lastSignalQuality := signalQualityBullBOS(bullTrendScore)
    lastSignalType    := "Bull BOS"
    lastSignalBar     := bar_index
if bearBOS
    lastSignalQuality := signalQualityBearBOS(bearTrendScore)
    lastSignalType    := "Bear BOS"
    lastSignalBar     := bar_index
if fvgDetected and not fvgActive[1]
    lastSignalQuality := signalQualityFVG(fvgWasBullish, fvgScore)
    lastSignalType    := (fvgWasBullish ? "Bull" : "Bear") + " FVG"
    lastSignalBar     := bar_index
if bullOB and not obBullActive[1]
    lastSignalQuality := signalQualityOB(true, obBullScore)
    lastSignalType    := "Bull OB"
    lastSignalBar     := bar_index
if bearOB and not obBearActive[1]
    lastSignalQuality := signalQualityOB(false, obBearScore)
    lastSignalType    := "Bear OB"
    lastSignalBar     := bar_index

signalQualityLabel = lastSignalBar == bar_index ? lastSignalType + " [" + str.tostring(lastSignalQuality, "0") + "/100]" : na

//=====================================================================
// SHOULD BUY / SELL - analysis only, no trade execution
//=====================================================================

bool buyPreFilters = bullTrend and htfBullGate and macroBull and regimeConfHigh and bullRsiDiv and recentBars and sessionQuality >= 30
shouldBuy = buyPreFilters and (bullBOS or displacementUp)

bool sellPreFilters = bearTrend and htfBearGate and macroBear and regimeConfHigh and bearRsiDiv and recentBars and sessionQuality >= 30
shouldSell = sellPreFilters and (bearBOS or displacementDown)

//=====================================================================
// V26 ENGINE 8: DASHBOARD ELITE - compact 7-col x 5-row table
//=====================================================================

var table dashboardElite = na
if showDashboard and barstate.islast
    dashboardElite := table.new(position.top_right, 7, 6, bgcolor=color.new(#0F172A, 85), border_width=0, frame_width=0)

    // Row 0: Header
    table.cell(dashboardElite, 0, 0, "METRIC",      text_color=cLabel, text_size=size.tiny, text_halign=text.align_center, width=12)
    table.cell(dashboardElite, 1, 0, "VALUE",       text_color=cLabel, text_size=size.tiny, text_halign=text.align_center, width=12)
    table.cell(dashboardElite, 2, 0, "STATUS",      text_color=cLabel, text_size=size.tiny, text_halign=text.align_center, width=10)
    table.cell(dashboardElite, 3, 0, "CONF",        text_color=cLabel, text_size=size.tiny, text_halign=text.align_center, width=8)
    table.cell(dashboardElite, 4, 0, "DIR",         text_color=cLabel, text_size=size.tiny, text_halign=text.align_center, width=8)
    table.cell(dashboardElite, 5, 0, "DEST",        text_color=cLabel, text_size=size.tiny, text_halign=text.align_center, width=8)
    table.cell(dashboardElite, 6, 0, "QUAL",        text_color=cLabel, text_size=size.tiny, text_halign=text.align_center, width=6)

    // Row 1: Bias
    table.cell(dashboardElite, 0, 1, "BIAS",   text_color=cLabel, text_size=size.tiny, width=12)
    table.cell(dashboardElite, 1, 1, biasLabel, text_color=biasCellColor, text_size=size.tiny, width=12)
    table.cell(dashboardElite, 2, 1, regimeTrending ? "TREND" : regimeRanging ? "RANGE" : "DEAD", text_color=regimeTrending ? cBull : regimeRanging ? cRange : cBear, text_size=size.tiny, width=10)
    table.cell(dashboardElite, 3, 1, str.tostring(regimeConfidence, "0"), text_color=regimeConfHigh ? cBull : regimeConfMed ? cRange : cBear, text_size=size.tiny, width=8)
    table.cell(dashboardElite, 4, 1, str.tostring(bullDirectionScore, "0") + "/" + str.tostring(bearDirectionScore, "0"), text_color=cLabel, text_size=size.tiny, width=8)
    table.cell(dashboardElite, 5, 1, liqDestLabel, text_color=cLabel, text_size=size.tiny, width=8)
    table.cell(dashboardElite, 6, 1, lastSignalType != "" ? str.tostring(lastSignalQuality, "0") : "�", text_color=lastSignalQuality >= 60 ? cBull : lastSignalQuality >= 30 ? cRange : cBear, text_size=size.tiny, width=6)

    // Row 2: Structure
    structColor = bullBOS ? cBull : bearBOS ? cBear : cRange
    if regimeScore > 0 and regimeScore <= 100
        table.cell(dashboardElite, 0, 2, "STRUCT", text_color=cLabel, text_size=size.tiny, width=12)
        table.cell(dashboardElite, 1, 2, bullBOS ? "BOS ?" : bearBOS ? "BOS ?" : bullCHOCH ? "CH ?" : bearCHOCH ? "CH ?" : "�", text_color=structColor, text_size=size.tiny, width=12)
        table.cell(dashboardElite, 2, 2, (regimeScore >= 60 ? "HIGH" : regimeScore >= 30 ? "MED" : "LOW"), text_color=regimeScore >= 60 ? cBull : regimeScore >= 30 ? cRange : cBear, text_size=size.tiny, width=10)
        table.cell(dashboardElite, 3, 2, str.tostring(structScore, "0"), text_color=structScore >= 50 ? cBull : structScore >= 25 ? cRange : cBear, text_size=size.tiny, width=8)
        table.cell(dashboardElite, 4, 2, str.tostring(htfAlignmentLong, "0") + "v" + str.tostring(htfAlignmentShort, "0"), text_color=htfAlignmentLong > htfAlignmentShort ? cBull : htfAlignmentShort > htfAlignmentLong ? cBear : cRange, text_size=size.tiny, width=8)
        table.cell(dashboardElite, 5, 2, "�", text_color=cLabel, text_size=size.tiny, width=8)
        table.cell(dashboardElite, 6, 2, str.tostring(structPersistBars, "0") + "b", text_color=structPersistBars >= 12 ? cBull : structPersistBars >= 6 ? cRange : cBear, text_size=size.tiny, width=6)

    // Row 3: Macro
    macroCellColor = macroBull ? cBull : macroBear ? cBear : cRange
    if macroIntelValid
        table.cell(dashboardElite, 0, 3, "MACRO", text_color=cLabel, text_size=size.tiny, width=12)
        table.cell(dashboardElite, 1, 3, macroIntelLabel, text_color=macroCellColor, text_size=size.tiny, width=12)
        table.cell(dashboardElite, 2, 3, str.tostring(macroBullVotes, "0") + "v" + str.tostring(macroBearVotes, "0"), text_color=macroCellColor, text_size=size.tiny, width=10)
        table.cell(dashboardElite, 3, 3, str.tostring(macroIntelConf, "0"), text_color=macroIntelConf >= 60 ? cBull : macroIntelConf >= 30 ? cRange : cBear, text_size=size.tiny, width=8)
        table.cell(dashboardElite, 4, 3, dxyBull ? "DXY?" : dxyBear ? "DXY?" : "DXY�", text_color=dxyBull ? cBear : dxyBear ? cBull : cRange, text_size=size.tiny, width=8)
        table.cell(dashboardElite, 5, 3, "�", text_color=cLabel, text_size=size.tiny, width=8)
        table.cell(dashboardElite, 6, 3, str.tostring(avgCorrHealth, "0"), text_color=avgCorrHealth >= 60 ? cBull : avgCorrHealth >= 30 ? cRange : cBear, text_size=size.tiny, width=6)

    // Row 4: Liquidity
    liqColor = ranPdH or ranPwH or ranEqH ? cBull : ranPdL or ranPwL or ranEqL ? cBear : cRange
    liqText = ranPdH ? "PDH?" : ranPdL ? "PDL?" : ranPwH ? "PWH?" : ranPwL ? "PWL?" : ranEqH ? "EQH?" : ranEqL ? "EQL?" : liqDestPrimary != "�" ? liqDestPrimary : "�"
    if showPDH or showPDL or showPWH or showPWL
        table.cell(dashboardElite, 0, 4, "LIQ",     text_color=cLabel, text_size=size.tiny, width=12)
        table.cell(dashboardElite, 1, 4, liqText,   text_color=liqColor, text_size=size.tiny, width=12)
        table.cell(dashboardElite, 2, 4, "S:" + str.tostring(liqDestScore, "0"), text_color=liqDestScore >= 100 ? cBull : liqDestScore >= 40 ? cRange : cBear, text_size=size.tiny, width=10)
        table.cell(dashboardElite, 3, 4, liqDestDistance < 1e9 ? (ltos(liqDestDist, 2)) : "�", text_color=cLabel, text_size=size.tiny, width=8)
        dirLabel_ = shouldSell ? "BEAR" : shouldBuy ? "BULL" : "�"
        table.cell(dashboardElite, 4, 4, dirLabel_, text_color=shouldBuy ? cBull : shouldSell ? cBear : cLabel, text_size=size.tiny, width=8)
        table.cell(dashboardElite, 5, 4, "PDH" + (not na(poolPdH) ? "=" + ltos(poolPdH, 0) : ""), text_color=cLabel, text_size=size.tiny, width=8)
        table.cell(dashboardElite, 6, 4, "PDL" + (not na(poolPdL) ? "=" + ltos(poolPdL, 0) : ""), text_color=cLabel, text_size=size.tiny, width=6)

    // Row 5: Session / quality summary
    table.cell(dashboardElite, 0, 5, "SESSION", text_color=cLabel, text_size=size.tiny, width=12)
    table.cell(dashboardElite, 1, 5, sessionLabel, text_color=sessionQuality >= 50 ? cBull : sessionQuality >= 25 ? cRange : cBear, text_size=size.tiny, width=12)
    table.cell(dashboardElite, 2, 5, "SQ=" + str.tostring(sessionQuality, "0"), text_color=sessionQuality >= 50 ? cBull : sessionQuality >= 25 ? cRange : cBear, text_size=size.tiny, width=10)
    table.cell(dashboardElite, 3, 5, "ADX=" + str.tostring(adxVal, "0"), text_color=regimeTrending ? cBull : regimeRanging ? cRange : cBear, text_size=size.tiny, width=8)
    table.cell(dashboardElite, 4, 5, "ATR%=" + str.tostring(atrPercentile, "0"), text_color=atrPercentile >= 70 ? cBull : cRange, text_size=size.tiny, width=8)
    table.cell(dashboardElite, 5, 5, "RNG=" + str.tostring(rangeDirectionScore, "0"), text_color=rangeDirectionScore >= 40 ? cRange : cLabel, text_size=size.tiny, width=8)
    table.cell(dashboardElite, 6, 5, "�", text_color=cLabel, text_size=size.tiny, width=6)

//=====================================================================
// MOBILE DASHBOARD - compact version
//=====================================================================

var table mobileDashboard = na
if showDashboard and barstate.islast and timeframe.isintraday
    mobileDashboard := table.new(position.bottom_right, 4, 5, bgcolor=color.new(#0F172A, 90), border_width=0, frame_width=0)
    table.cell(mobileDashboard, 0, 0, biasLabel, text_color=biasCellColor, text_size=size.small, width=18)
    table.cell(mobileDashboard, 1, 0, "C:" + str.tostring(regimeConfidence, "0"), text_color=regimeConfHigh ? cBull : cRange, text_size=size.small, width=10)
    table.cell(mobileDashboard, 2, 0, "B:" + str.tostring(bullDirectionScore, "0") + "/" + str.tostring(bearDirectionScore, "0"), text_color=cLabel, text_size=size.small, width=14)
    table.cell(mobileDashboard, 3, 0, liqDestPrimary, text_color=cLabel, text_size=size.small, width=10)

    table.cell(mobileDashboard, 0, 1, str.tostring(mtfConfluenceBull, "0") + "B/" + str.tostring(mtfConfluenceBear, "0") + "S", text_color=mtfConfluenceBull > mtfConfluenceBear ? cBull : mtfConfluenceBear > mtfConfluenceBull ? cBear : cRange, text_size=size.small, width=18)
    table.cell(mobileDashboard, 1, 1, "ADX:" + str.tostring(adxVal, "0"), text_color=regimeTrending ? cBull : cRange, text_size=size.small, width=10)
    table.cell(mobileDashboard, 2, 1, "ATR%:" + str.tostring(atrPercentile, "0"), text_color=atrPercentile >= 70 ? cBull : cRange, text_size=size.small, width=14)
    table.cell(mobileDashboard, 3, 1, "V%:" + str.tostring(volPercentile, "0"), text_color=volPercentile >= 80 ? cBull : cRange, text_size=size.small, width=10)

    table.cell(mobileDashboard, 0, 2, macroIntelLabel, text_color=macroIntelScore >= 15 ? cBull : macroIntelScore <= -15 ? cBear : cRange, text_size=size.small, width=18)
    table.cell(mobileDashboard, 1, 2, "STR:" + str.tostring(regimeScore, "0"), text_color=regimeScore >= 60 ? cBull : cRange, text_size=size.small, width=10)
    table.cell(mobileDashboard, 2, 2, "SQ:" + str.tostring(sessionQuality, "0"), text_color=sessionQuality >= 50 ? cBull : cRange, text_size=size.small, width=14)
    table.cell(mobileDashboard, 3, 2, "SIG:" + (lastSignalType != "" ? str.tostring(lastSignalQuality, "0") : "�"), text_color=lastSignalQuality >= 60 ? cBull : lastSignalQuality >= 30 ? cRange : cBear, text_size=size.small, width=10)

    table.cell(mobileDashboard, 0, 3, "DXY:" + (dxyBull ? "?" : dxyBear ? "?" : "�"), text_color=dxyBull ? cBear : dxyBear ? cBull : cLabel, text_size=size.small, width=18)
    table.cell(mobileDashboard, 1, 3, "SPX:" + (spxBull ? "?" : spxBear ? "?" : "�"), text_color=spxBull ? cBull : spxBear ? cBear : cLabel, text_size=size.small, width=10)
    table.cell(mobileDashboard, 2, 3, "YLD:" + (yieldFalling ? "?" : yieldRising ? "?" : "�"), text_color=yieldFalling ? cBull : yieldRising ? cBear : cLabel, text_size=size.small, width=14)
    table.cell(mobileDashboard, 3, 3, "EUR:" + (eurusdBull ? "?" : eurusdBear ? "?" : "�"), text_color=eurusdBull ? cBull : eurusdBear ? cBear : cLabel, text_size=size.small, width=10)

    table.cell(mobileDashboard, 0, 4, "DEST:" + liqDestPrimary, text_color=cLabel, text_size=size.small, width=18)
    table.cell(mobileDashboard, 1, 4, "PERS:" + str.tostring(structPersistBars, "0") + "b", text_color=structPersistBars >= 12 ? cBull : cRange, text_size=size.small, width=10)
    table.cell(mobileDashboard, 2, 4, "CORR:" + str.tostring(avgCorrHealth, "0"), text_color=avgCorrHealth >= 60 ? cBull : cRange, text_size=size.small, width=14)
    table.cell(mobileDashboard, 3, 4, "MTF:" + str.tostring(mtfConfluenceScore, "#"), text_color=mtfConfluenceScore >= 30 ? cBull : mtfConfluenceScore <= -30 ? cBear : cRange, text_size=size.small, width=10)

//=====================================================================
// VISUAL INDICATORS - Conditions
//=====================================================================

// ---- MSS (Market Structure Shift) ----
mssBull = showMSS and bullBOS and bearTrend[1] and displacementUp and highVolume and adxVal > adxThreshold
mssBear = showMSS and bearBOS and bullTrend[1] and displacementDown and highVolume and adxVal > adxThreshold

// ---- Internal Liquidity Sweeps ----
internalLiqSweepHigh = equalHighs and high > nz(swingHigh1) and close < nz(swingHigh1)
internalLiqSweepLow  = equalLows  and low  < nz(swingLow1)  and close > nz(swingLow1)

// ---- Asian Session Range ----
float asianLookbackSec = timeframe.in_seconds()
int   asianLookback    = int(asianLookbackSec >= 604800 ? 10 : asianLookbackSec >= 86400 ? 5 : math.max(5, math.round(25200 / asianLookbackSec)))
float asianSessionHigh = ta.highest(high, asianLookback)
float asianSessionLow  = ta.lowest(low,   asianLookback)
asianHighSweep = inLondon and high > asianSessionHigh[1] and close < asianSessionHigh[1]
asianLowSweep  = inLondon and low  < asianSessionLow[1]  and close > asianSessionLow[1]

// ---- Manipulation Signal ----
float asianRange     = asianSessionHigh - asianSessionLow
float asianRangeAvg  = ta.sma(asianRange, 10)
bool  manipVolume    = volume > volSma50 * manipThreshold
bool  manipRangeCond = asianRange < asianRangeAvg * 0.7
bool  manipWick      = (high > asianSessionHigh and close < asianSessionHigh) or (low < asianSessionLow and close > asianSessionLow)
int   manipScore     = (manipVolume ? 40 : 0) + (manipRangeCond ? 30 : 0) + (manipWick ? 30 : 0)
manipHigh = manipScore >= 70

//=====================================================================
// PLOTS
//=====================================================================

// ---- EMAs ----
plot(showEMAs and recentBars ? ema20 : na, "EMA 20", ema20Color, 1, plot.style_line, display=display.all)
plot(showEMAs and recentBars ? ema50 : na, "EMA 50", ema50Color, 1, plot.style_line, display=display.all)
plot(showEMAs and recentBars ? ema200 : na, "EMA 200", ema200Color, 1, plot.style_line, display=display.all)

// ---- VWAP ----
plot(showVWAP and recentBars ? vwapVal : na, "VWAP", color.new(#6B7280, 30), 1, plot.style_line, display=display.all)

// ---- ADX ----
plot(not perfMode and showADX and recentBars ? adxVal : na, "ADX", cAdxC, 2, plot.style_histogram, display=display.all)
hline(perfMode ? na : showADX ? adxThreshold : na, "ADX Thresh", color.new(#EF4444, 50), hline.style_dashed, display=display.none)

// ---- DI+ / DI- ----
plot(perfMode ? na : showADX ? diplus : na, "DI+", color.new(#22C55E, 60), 1, plot.style_line, display=display.none)
plot(perfMode ? na : showADX ? diminus : na, "DI-", color.new(#EF4444, 60), 1, plot.style_line, display=display.none)

// ---- Order Block Visuals ----
plot(obBullActive and showOB ? obBullLow : na, "Bull OB Low", color.new(#22C55E, 60), 1, plot.style_linebr, display=display.all)
plot(obBullActive and showOB ? obBullHigh : na, "Bull OB High", color.new(#22C55E, 30), 1, plot.style_linebr, display=display.all)
plot(obBearActive and showOB ? obBearLow : na, "Bear OB Low", color.new(#EF4444, 60), 1, plot.style_linebr, display=display.all)
plot(obBearActive and showOB ? obBearHigh : na, "Bear OB High", color.new(#EF4444, 30), 1, plot.style_linebr, display=display.all)

fill(plot(obBullActive and showOB ? obBullLow  : na, display=display.none),
     plot(obBullActive and showOB ? obBullHigh : na, display=display.none),
     color.new(#22C55E, 90), title="Bull OB Fill")
fill(plot(obBearActive and showOB ? obBearLow  : na, display=display.none),
     plot(obBearActive and showOB ? obBearHigh : na, display=display.none),
     color.new(#EF4444, 90), title="Bear OB Fill")

// ---- FVG Visuals ----
plot(fvgActive and showFVG ? fvgUpperLine : na, "FVG Upper", color.new(#FFD700, 40), 1, plot.style_linebr, display=display.all)
plot(fvgActive and showFVG ? fvgLowerLine : na, "FVG Lower", color.new(#FFD700, 40), 1, plot.style_linebr, display=display.all)
fill(plot(fvgActive and showFVG ? fvgUpperLine : na, display=display.none),
     plot(fvgActive and showFVG ? fvgLowerLine : na, display=display.none),
     color.new(#FFD700, 85), title="FVG Fill")

// ---- Liquidity Level Lines (PDH / PDL / PWH / PWL / EQH / EQL) ----
plot(showPDH and not na(poolPdH) and recentBars ? poolPdH : na, "PDH", color.new(#EF4444, 50), 1, plot.style_line, display=display.all)
plot(showPDL and not na(poolPdL) and recentBars ? poolPdL : na, "PDL", color.new(#22C55E, 50), 1, plot.style_line, display=display.all)
plot(showPWH and not na(poolPwH) and recentBars ? poolPwH : na, "PWH", color.new(#F59E0B, 50), 1, plot.style_line, display=display.all)
plot(showPWL and not na(poolPwL) and recentBars ? poolPwL : na, "PWL", color.new(#3B82F6, 50), 1, plot.style_line, display=display.all)
plot(showEQ and not na(poolEqH) and recentBars ? poolEqH : na, "EQH", color.new(#EF4444, 40), 1, plot.style_circles, display=display.all)
plot(showEQ and not na(poolEqL) and recentBars ? poolEqL : na, "EQL", color.new(#22C55E, 40), 1, plot.style_circles, display=display.all)

// ---- Support / Resistance from SR engine ----
plot(showSR and not na(resistanceLevel) and recentBars ? resistanceLevel : na, "Resistance", color.new(#EF4444, 30), 1, plot.style_line, display=display.all)
plot(showSR and not na(supportLevel) and recentBars ? supportLevel : na, "Support", color.new(#22C55E, 30), 1, plot.style_line, display=display.all)

// ---- Macro Strength Score as subplot ----
plot(showMacro and macroIntelValid and recentBars ? macroStrengthScore : na, "Macro", color.new(#A855F7, 50), 2, plot.style_histogram, display=display.all)

// ---- Corr Breakdown ----
plot(showCorrHealth and corrBreakdown and recentBars ? close : na, "Corr Break", color.new(#EF4444, 60), 3, plot.style_line, display=display.all)

// ---- SMT ----
plotshape(showSMT and smtBullPair and recentBars, style=shape.triangleup,   location=location.belowbar, color=color.new(#06B6D4, 0), size=size.small, title="SMT Bull")
plotshape(showSMT and smtBearPair and recentBars, style=shape.triangledown, location=location.abovebar, color=color.new(#8B5CF6, 0), size=size.small, title="SMT Bear")

// ---- Volume Climax ----
plotshape(climaxUp   and recentBars, style=shape.circle, location=location.abovebar, color=color.new(#3B82F6, 30), size=size.small, title="Climax Up")
plotshape(climaxDown and recentBars, style=shape.circle, location=location.belowbar, color=color.new(#F59E0B, 30), size=size.small, title="Climax Down")

// ---- MSS (Market Structure Shift) ----
plotshape(mssBull and recentBars and barstate.isconfirmed and not (perfMode and perfReduceVis), style=shape.flag, location=location.belowbar, color=#F97316, size=size.small, title="MSS Bull")
plotshape(mssBear and recentBars and barstate.isconfirmed and not (perfMode and perfReduceVis), style=shape.flag, location=location.abovebar, color=#F97316, size=size.small, title="MSS Bear")

// ---- Internal Liquidity Sweeps ----
plotshape(showIntExtLiq and recentBars and internalLiqSweepHigh and not (perfMode and perfReduceVis), style=shape.triangledown, location=location.abovebar, color=color.new(#8B5CF6, 30), size=size.tiny, title="Internal Liq Sweep High")
plotshape(showIntExtLiq and recentBars and internalLiqSweepLow  and not (perfMode and perfReduceVis), style=shape.triangleup,   location=location.belowbar, color=color.new(#06B6D4, 30), size=size.tiny, title="Internal Liq Sweep Low")

// ---- Asian Sweeps ----
plotshape(showAsian and recentBars and asianHighSweep and not (perfMode and perfReduceVis), style=shape.xcross, location=location.abovebar, color=color.new(#7C2D12, 0), size=size.tiny, title="Asian High Sweep")
plotshape(showAsian and recentBars and asianLowSweep  and not (perfMode and perfReduceVis), style=shape.xcross, location=location.belowbar, color=color.new(#14532D, 0), size=size.tiny, title="Asian Low Sweep")

// ---- Manipulation Signal ----
plotshape(showManipProb and recentBars and manipHigh and not (perfMode and perfReduceVis), style=shape.labeldown, location=location.abovebar, color=color.new(#64748B, 40), text="MANIP", textcolor=#F1F5F9, size=size.tiny, title="Manipulation Signal")

// ---- Correlation Breakdown Warning ----
plotshape(showCorrHealth and recentBars and corrBreakdown and not (perfMode and perfReduceVis), style=shape.xcross, location=location.abovebar, color=color.new(#F59E0B, 20), size=size.tiny, title="Correlation Breakdown Warning")

// ---- Signal Grade Icons ----
plotshape(shouldBuy and barstate.isconfirmed and not (perfMode and perfReduceVis), style=shape.triangleup, location=location.belowbar, color=#22C55E, size=size.small, title="Nexus Buy")
plotshape(shouldSell and barstate.isconfirmed and not (perfMode and perfReduceVis), style=shape.triangledown, location=location.abovebar, color=#EF4444, size=size.small, title="Nexus Sell")

//=====================================================================
// SMART ALERT FRAMEWORK - analysis only, no trade execution
//=====================================================================

alertcondition(shouldBuy,  title="Nexus Buy Signal",  message="XAUUSD: Buy signal @ {{close}} | Bias: {{biasLabel}} | Conf: {{regimeConfidence}}% | Session: {{sessionLabel}}")
alertcondition(shouldSell, title="Nexus Sell Signal", message="XAUUSD: Sell signal @ {{close}} | Bias: {{biasLabel}} | Conf: {{regimeConfidence}}% | Session: {{sessionLabel}}")

if shouldBuy and barstate.isconfirmed and not perfMode
    alert("XAUUSD NEXUS BUY @ " + str.tostring(close, "#.##"), alert.freq_once_per_bar)
if shouldSell and barstate.isconfirmed and not perfMode
    alert("XAUUSD NEXUS SELL @ " + str.tostring(close, "#.##"), alert.freq_once_per_bar)

alertcondition(showSignals and barstate.isconfirmed and bullBOS, "Bull BOS", "XAUUSD Bull BOS @ {{close}}")
alertcondition(showSignals and barstate.isconfirmed and bearBOS, "Bear BOS", "XAUUSD Bear BOS @ {{close}}")

//=====================================================================
// END OF INDICATOR
//=====================================================================
