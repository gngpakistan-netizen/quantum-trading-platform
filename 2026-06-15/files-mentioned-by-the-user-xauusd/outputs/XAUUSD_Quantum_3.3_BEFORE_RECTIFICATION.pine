oIsWr := __iw
oIsN := __in

// Normalize scores to sum 100% preserving bull/bear/range ratio
// Note: outputs are ordinal scores, not calibrated probabilities
normalizeScores(float b, float be, float r, float minFloor) =>
    float nb = math.min(b, 95.0)
    float nbe = math.min(be, 95.0)
    float nr = math.max(r, 0.0)
    float _total = nb + nbe + nr
    if _total > 100.0
        // Scale all three proportionally to sum 100
        float _rB = nb / _total
        float _rBe = nbe / _total
        nb := math.min(math.max(math.round(100.0 * _rB), minFloor), 95.0)
        nbe := math.min(math.max(math.round(100.0 * _rBe), minFloor), 95.0)
        nr := math.max(100.0 - nb - nbe, 0.0)
    else
        nb := math.max(nb, minFloor)
        nbe := math.max(nbe, minFloor)
        _total := nb + nbe + nr
        if _total > 100.0
            float _excess = _total - 100.0
            if nr >= _excess
                nr := nr - _excess
            else
                _excess -= nr
                nr := 0.0
                float _bRat = nb / math.max(nb + nbe, 1.0)
                float _beAdj = math.min(math.round(_excess * (1.0 - _bRat)), nbe)
                nb := nb - math.min(math.round(_excess * _bRat), nb)
                nbe := nbe - _beAdj
        else
            nr := math.max(100.0 - nb - nbe, 0.0)
    // Preserve range floor when range evidence was provided
    if r > 0 and nr < minFloor
        float _deficit = minFloor - nr
        float _bShare = math.round(_deficit * nb / math.max(nb + nbe, 1.0))
        nb := nb - _bShare
        nbe := nbe - (_deficit - _bShare)
        nr := minFloor
    if nr < 0
        nr := 0.0
    [nb, nbe, nr]

// Blend live 7-factor evidence scores with historical analogs (70/30 blend preserves live sensitivity)
if barstate.islast and showStatsEngine and oMatch >= 3
    float blendHist = 0.30
    bullScore := bullScore * (1.0 - blendHist) + oBull * blendHist
    bearScore := bearScore * (1.0 - blendHist) + oBear * blendHist
    float rangeHist = na(oRange) ? rangeScore : oRange
    rangeScore := rangeHist

//=====================================================================
// FORECAST ENGINE (Module 12)
// Unified forward projection combining:
//   Historical Analog   (30%)
//   Trend Persistence   (25%)
//   Liquidity Dest.     (25%)
//   Regime Persistence  (20%)
//=====================================================================

float fBullScore = 50.0
float fBearScore = 50.0
float fRngScore = 0.0

// 1) Historical Analog — best available source
if showStatsEngine and oMatch >= 3
    fBullScore := bullScore
    fBearScore := bearScore
    fRngScore := 100.0 - fBullScore - fBearScore
    if fRngScore < 0
        fRngScore := 0.0
else if histBullScore != 50.0
    fBullScore := histBullScore
    fBearScore := histBearScore
    fRngScore := 100.0 - fBullScore - fBearScore
    if fRngScore < 0
        fRngScore := 0.0

int momBars = 0
if barstate.islast
    // 2) Trend Persistence factor (±8% adjustment, ±12% after displacement)
    // Momentum score supplements oBosCont: consecutive bars × ADX strength (catches non-BOS trends)
    momBars := 0
    bool momUp = close > close[1]
    bool momDn = close < close[1]
    for momIdx = 1 to 5
        if momUp and close[momIdx] > close[momIdx+1]
            momBars += 1
        else if momDn and close[momIdx] < close[momIdx+1]
            momBars -= 1
        else
            break
    float momScore = math.abs(momBars) * 10.0 + (adxVal > 25 ? 15.0 : adxVal > 20 ? 8.0 : 0.0)
    float trendFactor = 0.0
    if showStatsEngine and oMatch >= 3 and (bullTrend or bearTrend)
        // Boost trend weight when recent displacement confirms momentum (3-bar window)
        bool recentDisp = (displacementUp or displacementDown) or (displacementUp[1] or displacementDown[1]) or (displacementUp[2] or displacementDown[2])
        float trendMult = recentDisp ? 0.24 : 0.16
        // Blend BOS continuation rate (oBosCont) with live momentum score
        float trendInput = (oBosCont * 0.60) + (momScore * 0.40)
        if bullTrend
            trendFactor := (trendInput - 50.0) * trendMult
        else
            trendFactor := -(trendInput - 50.0) * trendMult

    // 3) Liquidity Destination factor (±6% adjustment)
    float liqFactor = 0.0
    if liqMaxScore > 0
        bool destBull = liqDestLabel == "PDH" or liqDestLabel == "PWH" or liqDestLabel == "PMH" or liqDestLabel == "EQH"
        if destBull and bullTrend
            liqFactor := (liqReachScore - 50.0) * 0.12
        else if not destBull and bearTrend
            liqFactor := (liqReachScore - 50.0) * 0.12

    // 4) Regime Persistence factor (±5% adjustment)
    float regFactor = 0.0
    if showStatsEngine and oRegPer >= 40
        if bullTrend
            regFactor := (oRegPer - 50.0) * 0.10
        else if bearTrend
            regFactor := -(oRegPer - 50.0) * 0.10

    float fAdj = trendFactor + liqFactor + regFactor
    fBullScore := math.min(math.max(fBullScore + fAdj, 5.0), 95.0)
    fBearScore := 100.0 - fBullScore - fRngScore
    if fBearScore < 0
        fBearScore := 0.0
        fRngScore := 100.0 - fBullScore - fBearScore
        if fRngScore < 0
            fRngScore := 0.0
            float r = fBullScore / (fBullScore + fBearScore + 1)
            fBullScore := math.max(100.0 * r, 5.0)
            fBearScore := 100.0 - fBullScore

    // Write forecast engine output to display probabilities
    bullScore := fBullScore
    bearScore := fBearScore
    rangeScore := fRngScore
    // Single-pass normalization
    [nb2_, nbe2_, nr2_] = normalizeScores(bullScore, bearScore, rangeScore, 1.0)
    bullScore := nb2_
    bearScore := nbe2_
    rangeScore := nr2_

//=====================================================================
// V27 ENGINE 8: INSTITUTIONAL DASHBOARD — Titled metrics + breakdown
// Row 0:  Conf | Bull/Bear% | Target
// Row 1:  PDH→% / PDL→% / Hist PDH / Hist PDL
// Row 2:  PDH / PDL / PWH / PWL levels
// Row 3:  WHY breakdown — Struct | Liq | Macro | MR
// Row 4:  DXY | EUR | XAG | 10Y
// Color: White = info, Green = bull, Red = bear, Gray = neutral
//=====================================================================

color cInfo   = color.new(#F1F5F9, 0)
color cGray   = color.new(#A0A0A0, 0)
color cBgBox  = color.new(#0F172A, 92)

// Map level abbreviations to readable display names
string liqShortTarget = liqDestLabel == "PDH" ? "PrevDayHi" : liqDestLabel == "PDL" ? "PrevDayLo" : liqDestLabel == "PWH" ? "PrevWeekHi" : liqDestLabel == "PWL" ? "PrevWeekLo" : liqDestLabel == "PMH" ? "PrevMoHi" : liqDestLabel == "PML" ? "PrevMoLo" : liqDestLabel == "EQH" ? "EqualHi" : liqDestLabel == "EQL" ? "EqualLo" : liqDestLabel

// Direction labels for breakdown row
string mrStr  = mrComposite >= 60  ? "Overext" : (mrComposite >= 30 ? "Extended" : (mrComposite <= -60 ? "Overext" : (mrComposite <= -30 ? "Extended" : "Normal")))

// Regime label with Volatile (M9-A)
string regLabel = strongTrend ? (volRegime > 70 ? "Volatile" : "Trending") : moderateTrend ? (volRegime > 70 ? "Volatile" : "Ranging") : "Dead"

// Correlation directional magnitude — Strong/Moderate/Weak per asset
string dxyMag = "—"
string eurMag = "—"
string yldMag = "—"
string xagMag = "—"
if dxyValid and dxyEMAFast > 0
    float dxyDev = dxyBull or dxyBear ? math.abs(dxyClose - dxyEMAFast) / dxyEMAFast * 100.0 : 0.0
    dxyMag := dxyDev > 1.5 ? "Strong" : dxyDev > 0.5 ? "Moderate" : "Weak"
if eurusdValid and eurusdEMAFast > 0
    float eurDev = eurusdBull or eurusdBear ? math.abs(eurusdClose - eurusdEMAFast) / eurusdEMAFast * 100.0 : 0.0
    eurMag := eurDev > 1.0 ? "Strong" : eurDev > 0.3 ? "Moderate" : "Weak"
if yieldValid and yieldEMAFast > 0
    float yldDev = yieldRising or yieldFalling ? math.abs(yieldClose - yieldEMAFast) / yieldEMAFast * 100.0 : 0.0
    yldMag := yldDev > 5.0 ? "Strong" : yldDev > 1.5 ? "Moderate" : "Weak"
if silverValid and silverEMA > 0
    float xagDev = silverClose > silverEMA or silverClose < silverEMA ? math.abs(silverClose - silverEMA) / silverEMA * 100.0 : 0.0
    xagMag := xagDev > 2.0 ? "Strong" : xagDev > 0.7 ? "Moderate" : "Weak"

// Correlation health label (M10-A)
string corrHealthLabel = avgCorrHealth >= 60 ? "Supportive" : avgCorrHealth >= 40 ? "Neutral" : "Contradictory"

// Win rate display (M11-A)
string wrStr = "—"
string wrCIStr = ""
if showStatsEngine and oMatch >= 3
    float _wrR = oWr / 100.0
    float _wrDir = bearBiasScore > bullBiasScore ? (1.0 - _wrR) : _wrR
    float _wrCI95 = oMatch >= 30 ? 1.96 * math.sqrt(_wrDir * (1.0 - _wrDir) / oMatch) * 100.0 : 0.0
    wrStr := str.tostring(int(_wrDir * 100.0)) + "%"
    wrCIStr := _wrCI95 > 1.0 ? "+/-" + str.tostring(int(_wrCI95 + 0.5)) + "%" : ""

// Reliability label (L-007)
string relLbl = showStatsEngine and oMatch >= 3 ? (oMatch >= 300 ? "HI" : oMatch >= 100 ? "GD" : oMatch >= 30 ? "MD" : oMatch >= 10 ? "FR" : "LO") : "—"

// Feature gain range display (L-006)
string featRangeStr = "—"
if showStatsEngine and oMatch >= 3 and not na(oFeatStr) and not na(oFeatCor)
    float _fMin = math.min(math.min(math.min(math.min(math.abs(oFeatStr), math.abs(oFeatHtf)), math.abs(oFeatLiq)), math.abs(oFeatMr)), math.abs(oFeatCor))
    float _fMax = math.max(math.max(math.max(math.max(math.abs(oFeatStr), math.abs(oFeatHtf)), math.abs(oFeatLiq)), math.abs(oFeatMr)), math.abs(oFeatCor))
    featRangeStr := "FG " + str.tostring(int(_fMin)) + "~" + str.tostring(int(_fMax)) + "%"

// EV + N + Cal (shared by dashboard + bottom strip)
string evStr = "—"
color evCol = cGray
if not na(oEvLabel)
    evCol := oEvLabel > 0 ? #00D084 : oEvLabel < 0 ? #FF4D4D : cGray
    evStr := oEvLabel > 0 ? "+" + str.tostring(oEvVal, "#.#") : str.tostring(oEvVal, "#.#")
string nStr = showStatsEngine and oMatch >= 3 ? "N" + str.tostring(oMatch, "0") : "N—"
string calDisp = showStatsEngine and oMatch >= 3 ? oCalGrade + (oCalPct < 50 ? "!" : "") : "—"
color calC = showStatsEngine and oMatch >= 3 ? (oCalPct >= 75 ? #00D084 : oCalPct >= 50 ? #A0A0A0 : #FF4D4D) : cGray
string sharpeStr = not na(oSharpe) ? str.tostring(oSharpe, ".2") : "—"
color sharpeCol = not na(oSharpe) ? (oSharpe >= 0.15 ? #00D084 : oSharpe >= 0.05 ? #FF8C00 : #FF4D4D) : cGray
string ddStr = not na(oMaxDD) ? str.tostring(oMaxDD, ".1") + "%" : "—"
color ddCol = not na(oMaxDD) ? (oMaxDD < 20 ? #00D084 : oMaxDD < 40 ? #FF8C00 : #FF4D4D) : cGray
string pfStr = not na(oProfitFactor) ? str.tostring(oProfitFactor, ".2") : "—"
color pfCol = not na(oProfitFactor) ? (oProfitFactor >= 1.5 ? #00D084 : oProfitFactor >= 1.0 ? #FF8C00 : #FF4D4D) : cGray
string isWrStr = "IS " + (oIsN >= 30 ? str.tostring(int(oIsWr)) + "%" : "—")
string oosWrStr = "OOS " + (oOosN >= 10 ? str.tostring(int(oOosWr)) + "%" : "—")
string calBrierStr = not na(oCalBrier) ? "Br " + str.tostring(oCalBrier, ".3") : "—"

// Compact macro
color macro1Color = dxyValid ? (dxyBear ? cBull : dxyBull ? cBear : cGray) : cGray
color macro2Color = yieldValid ? (yieldFalling ? cBull : yieldRising ? cBear : cGray) : cGray
color macro3Color = eurusdValid ? (eurusdBull ? cBull : eurusdBear ? cBear : cGray) : cGray
color macro4Color = silverValid ? (not na(silverClose) and silverClose > silverEMA ? cBull : cBear) : cGray
// Correlation: impact arrows on XAUUSD — ▲▲/▲ (bullish), ▼▼/▼ (bearish), ≈ (neutral)
// Strong → double arrow, Moderate/Weak → single arrow
string _dxyArrow = dxyValid ? (dxyMag == "Strong" ? (dxyBear ? "▲▲" : "▼▼") : dxyMag == "—" ? "≈" : (dxyBear ? "▲" : "▼")) : "—"
string _yldArrow = yieldValid ? (yldMag == "Strong" ? (yieldFalling ? "▲▲" : "▼▼") : yldMag == "—" ? "≈" : (yieldFalling ? "▲" : "▼")) : "—"
string _eurArrow = eurusdValid ? (eurMag == "Strong" ? (eurusdBull ? "▲▲" : "▼▼") : eurMag == "—" ? "≈" : (eurusdBull ? "▲" : "▼")) : "—"
string _xagArrow = silverValid ? (xagMag == "Strong" ? (silverClose > silverEMA ? "▲▲" : "▼▼") : xagMag == "—" ? "≈" : (silverClose > silverEMA ? "▲" : "▼")) : "—"
string _spxArrow = spxValid ? (spxBull ? "▲" : spxBear ? "▼" : "≈") : "—"
string dxyC = dxyValid ? "DXY" + _dxyArrow : "—"
string yldC = yieldValid ? "10Y" + _yldArrow : "—"
string eurC = eurusdValid ? "EUR" + _eurArrow : "—"
string slvC = silverValid ? "XAG" + _xagArrow : "—"
string volTag = atrPercentile < 25 ? "LOW" : atrPercentile > 75 ? "HIGH" : "NORMAL"
float vdK = volDelta50 / 1000.0
string vdStr = "∆" + (vdK >= 0 ? "+" : "") + str.tostring(vdK, ".1") + "k"

var table tblA = na

// ══════════════════════════════════════════════════════════════════════
// BLOOMBERG TERMINAL DASHBOARD — 8-SECTION HORIZONTAL STRIP
// ── UI/UX REDESIGN ONLY. Zero trading logic modified. ──
//
// Architecture: 9 columns × 3 rows = 27 cells across full screen width
// Section layout (left → right):
//   [0] TICKER  [1] BIAS  [2] SIGNAL  [3] STRUCTURE  [4] LIQUIDITY
//   [5] PRICE   [6] MACRO [7] RISK    [8] DECISION
//
// Design principles:
//   · Single-question-per-section: each column answers exactly one of
//     the 5 key trading questions within 3 seconds
//   · 3 rows per section: header label (dim) | primary value | sub-value
//   · Color discipline: Green=Bull, Red=Bear, Yellow=Warning, Gray=Neutral
//   · Decision box (col 8) is the single most-prominent element
//   · All data values identical to prior layouts — only presentation changes
// ══════════════════════════════════════════════════════════════════════

f_size(string s) => s == "normal" ? size.normal : s == "tiny" ? size.tiny : size.small

renderDashboard() =>
    // ── [SHARED DATA] All values identical to prior layouts ──────────
    string _tfLabel  = timeframe.period
    string _symStr   = syminfo.ticker
    float _chgPct    = not na(close[1]) and close[1] != 0 ? (close - close[1]) / close[1] * 100.0 : 0.0
    string _chgStr   = (_chgPct >= 0 ? "+" : "") + str.tostring(_chgPct, ".2") + "%"
    color  _chgCol   = _chgPct >= 0 ? cBloomBull : cBloomBear

    // Direction / state
    string _dirLabel = bullScore >= bearScore and bullScore >= rangeScore ? "BUY" : bearScore >= bullScore and bearScore >= rangeScore ? "SELL" : "RNG"
    color  _dirCol   = _dirLabel == "BUY" ? cBloomBull : _dirLabel == "SELL" ? cBloomBear : cBloomNeut
    string _stateLabel = shouldBuy ? "LONG" : shouldSell ? "SHORT" : regimeRanging ? "RANGE" : "WAIT"
    color  _stateCol = shouldBuy ? cBloomBull : shouldSell ? cBloomBear : regimeRanging ? cBloomWarn : cBloomNeut

    // Bias score (ordinal)
    int  _bullPct  = int(bullScore)
    int  _bearPct  = int(bearScore)
    int  _rngPct   = int(rangeScore)
    bool _isBull   = _bullPct >= _bearPct and _bullPct >= _rngPct
    bool _isBear   = _bearPct > _bullPct and _bearPct >= _rngPct
    color _biasCol = _isBull ? cBloomBull : _isBear ? cBloomBear : cBloomWarn

    // Confidence / quality
    string _qualLabel = confidenceScore >= 60 ? "HIGH" : confidenceScore >= 40 ? "MED" : "LOW"
    color  _qualCol   = confidenceScore >= 60 ? cBloomBull : confidenceScore >= 40 ? cBloomWarn : cBloomBear
    int    _setupScore = math.min(math.max(int(confidenceScore / 20), 0), 5)

    // MTF alignment
    string _mtfDir = htfFullLong > htfFullShort ? "BULL" : htfFullShort > htfFullLong ? "BEAR" : "MIX"
    color  _mtfCol = htfFullLong > htfFullShort ? cBloomBull : htfFullShort > htfFullLong ? cBloomBear : cBloomNeut
    string _tfArrows = (htf5mBull ? "▲" : htf5mBear ? "▼" : "≈") + (htf15mBull ? "▲" : htf15mBear ? "▼" : "≈") + (htf1hBull ? "▲" : htf1hBear ? "▼" : "≈") + (htf4hBull ? "▲" : htf4hBear ? "▼" : "≈") + (htfDBull ? "▲" : htfDBear ? "▼" : "≈")

    // Structure
    string _bosStr   = bosLabelBull ? "BOS▲" : bosLabelBear ? "BOS▼" : "BOS—"
    color  _bosCol   = bosLabelBull ? cBloomBull : bosLabelBear ? cBloomBear : cBloomNeut
    string _chochStr = chochLabelBull ? "CHoCH▲" : chochLabelBear ? "CHoCH▼" : "CHoCH—"
    color  _chochCol = chochLabelBull ? cBloomBull : chochLabelBear ? cBloomBear : cBloomNeut
    string _mssStr   = mssLabelBull ? "MSS▲" : mssLabelBear ? "MSS▼" : "MSS—"
    color  _mssCol   = mssLabelBull ? cBloomBull : mssLabelBear ? cBloomBear : cBloomNeut
    string _structActive = mssLabelBull or mssLabelBear ? _mssStr : chochLabelBull or chochLabelBear ? _chochStr : _bosStr
    color  _structActiveCol = mssLabelBull or mssLabelBear ? _mssCol : chochLabelBull or chochLabelBear ? _chochCol : _bosCol

    // Liquidity — primary & secondary destination
    string _liqDest  = liqDestLabel != "—" ? liqDestLabel + (liqDestLabel == "PDH" or liqDestLabel == "PWH" or liqDestLabel == "PMH" or liqDestLabel == "EQH" ? "↑" : "↓") : "—"
    color  _liqCol   = liqDestLabel == "PDH" or liqDestLabel == "PWH" or liqDestLabel == "PMH" or liqDestLabel == "EQH" ? cBloomBear : liqDestLabel == "PDL" or liqDestLabel == "PWL" or liqDestLabel == "PML" or liqDestLabel == "EQL" ? cBloomBull : cBloomNeut
    string _poolH = (not na(poolPdH) ? "PDH " : "") + (not na(poolPwH) ? "PWH " : "") + (not na(poolPmH) ? "PMH" : "")
    string _poolL = (not na(poolPdL) ? "PDL " : "") + (not na(poolPwL) ? "PWL " : "") + (not na(poolPmL) ? "PML" : "")
    string _poolStr = _poolH == "" and _poolL == "" ? "—" : (_poolH != "" ? _poolH : "") + (_poolH != "" and _poolL != "" ? " │ " : "") + (_poolL != "" ? _poolL : "")

    // Price metrics
    string _priceStr = str.tostring(close, "#.##")
    string _vwapStr  = not na(vwapVal) ? str.tostring(vwapVal, "#.##") : "—"
    string _e200Str  = str.tostring(ema200, "#.##")
    color  _priceVwapCol = close >= nz(vwapVal) ? cBloomBull : cBloomBear

    // Macro engine — DXY, 10Y, corr health
    string _dxyStr = dxyValid ? "DXY" + _dxyArrow : "DXY—"
    color  _dxyCol = dxyValid ? (dxyBear ? cBloomBull : dxyBull ? cBloomBear : cBloomNeut) : cBloomNeut
    string _yldStr = yieldValid ? "10Y" + _yldArrow : "10Y—"
    color  _yldCol = yieldValid ? (yieldFalling ? cBloomBull : yieldRising ? cBloomBear : cBloomNeut) : cBloomNeut
    string _crStr  = "CORR " + str.tostring(int(avgCorrHealth))
    color  _crCol  = avgCorrHealth >= 60 ? cBloomBull : avgCorrHealth >= 40 ? cBloomWarn : cBloomBear
    string _macroLine2 = (eurusdValid ? "EUR" + _eurArrow : "EUR—") + " " + (silverValid ? "XAG" + _xagArrow : "XAG—") + " " + (spxValid ? "SPX" + _spxArrow : "SPX—")
    string _calDisp = calDisp
    color  _calCol = calC
    // Macro gold-direction colors: DXY↓+10Y↓=bullish gold→green, DXY↑+10Y↑=bearish gold→red
    int _macroVote = (dxyBear ? 1 : dxyBull ? -1 : 0) + (yieldFalling ? 1 : yieldRising ? -1 : 0)
    color _dxyYldCol = _macroVote >= 1 ? cBloomBull : _macroVote <= -1 ? cBloomBear : cBloomNeut
    int _macro2Vote = (eurusdBull ? 1 : eurusdBear ? -1 : 0) + (not na(silverClose) and silverClose > silverEMA ? 1 : not na(silverClose) and silverClose < silverEMA ? -1 : 0) + (spxBear ? 1 : spxBull ? -1 : 0)
    color _macro2Col = _macro2Vote >= 1 ? cBloomBull : _macro2Vote <= -1 ? cBloomBear : cBloomNeut

    // Risk framework
    string _rrStr   = "RR 1:" + str.tostring(tpRR1, ".1")
    color  _rrCol   = tpRR1 >= 2.0 ? cBloomBull : tpRR1 >= 1.5 ? cBloomWarn : cBloomBear
    string _regLbl  = regLabel
    color  _regCol  = strongTrend ? cBloomBull : moderateTrend ? cBloomWarn : cBloomNeut
    string _volLbl  = volTag
    color  _volCol  = atrPercentile > 75 ? cBloomWarn : atrPercentile < 25 ? cBloomBull : cBloomNeut
    string _ddStr   = ddStr
    color  _ddCol   = ddCol

    // Trade execution detail (sub-values for decision section)
    string _eStr    = str.tostring(tpEntry, "#.##")
    string _slStr   = str.tostring(tpSL, "#.##")
    string _tpStr   = str.tostring(tp1, "#.##")
    string _sessLbl = sessionLabel
    color  _sessCol = sessionLabel == "LONDON" or sessionLabel == "NY" ? cBloomBull : sessionLabel == "ASIAN" ? cBloomWarn : cBloomNeut

    // Session + WR sub-line
    string _evStr   = evStr != "—" ? "EV" + evStr : "EV—"
    color  _evCol   = evCol
    string _wrStr   = wrStr + " " + wrCIStr

    // ── RESPONSIVE RENDERING ──────────────────────────────────────────
    string _mode = dashMode == "Auto" ? "Desktop" : dashMode
    int _w = density == "Compact" ? 8 : density == "Spacious" ? 14 : 11
    int _w2 = density == "Compact" ? 7 : density == "Spacious" ? 12 : 9
    string _ts = textSize == "Auto" ? (_mode == "MobilePort" ? "tiny" : "small") : textSize == "Large" ? "normal" : textSize == "Small" ? "tiny" : "small"
    string _ts2 = textSize == "Auto" ? "tiny" : _ts == "normal" ? "small" : _ts

    if _mode == "MobilePort"
        // ── MOBILE PORTRAIT: 5 rows × 4 cols ──────────────────────────
        // Row 0: Market header
        table.cell(tblA, 0, 0, _symStr + " " + _tfLabel, text_color=cBloomVal, text_size=f_size(_ts), width=_w)
        table.cell(tblA, 1, 0, _sessLbl, text_color=_sessCol, text_size=f_size(_ts), width=_w)
        table.cell(tblA, 2, 0, _tfArrows + " " + _mtfDir, text_color=_mtfCol, text_size=f_size(_ts), width=_w)
        table.cell(tblA, 3, 0, _stateLabel, text_color=_stateCol, text_size=f_size(_ts), width=_w)
        // Row 1: BIAS / SIGNAL / STRUCTURE / LIQUIDITY primary
        table.cell(tblA, 0, 1, (_isBull ? "▲" : _isBear ? "▼" : "≈") + str.tostring(math.max(_bullPct, _bearPct)), text_color=_biasCol, text_size=f_size(_ts), width=_w)
        table.cell(tblA, 1, 1, "S" + str.tostring(_setupScore) + "/5 " + _qualLabel, text_color=_qualCol, text_size=f_size(_ts), width=_w)
        table.cell(tblA, 2, 1, _structActive, text_color=_structActiveCol, text_size=f_size(_ts), width=_w)
        table.cell(tblA, 3, 1, "→" + _liqDest, text_color=_liqCol, text_size=f_size(_ts), width=_w)
        // Row 2: BIAS / SIGNAL / STRUCTURE / LIQUIDITY sub
        table.cell(tblA, 0, 2, "▲" + str.tostring(_bullPct) + " ▼" + str.tostring(_bearPct) + " ≈" + str.tostring(_rngPct), text_color=_biasCol, text_size=f_size(_ts2), width=_w)
        table.cell(tblA, 1, 2, _evStr, text_color=_evCol, text_size=f_size(_ts2), width=_w)
        table.cell(tblA, 2, 2, _bosStr + " " + _chochStr, text_color=_structActiveCol, text_size=f_size(_ts2), width=_w)
        table.cell(tblA, 3, 2, _poolH + " " + _poolL, text_color=_liqCol, text_size=f_size(_ts2), width=_w)
        // Row 3: PRICE / MACRO / RISK / DECISION primary
        table.cell(tblA, 0, 3, _priceStr + " " + _chgStr, text_color=_chgCol, text_size=f_size(_ts), width=_w)
        table.cell(tblA, 1, 3, _dxyStr + " " + _yldStr, text_color=_dxyYldCol, text_size=f_size(_ts), width=_w)
        table.cell(tblA, 2, 3, _rrStr + " " + _regLbl, text_color=_rrCol, text_size=f_size(_ts), width=_w)
        table.cell(tblA, 3, 3, "E" + _eStr + " SL" + _slStr, text_color=cBloomLbl, text_size=f_size(_ts), width=_w)
        // Row 4: PRICE / MACRO / RISK / DECISION sub
        table.cell(tblA, 0, 4, "VWAP " + _vwapStr, text_color=_priceVwapCol, text_size=f_size(_ts2), width=_w)
        table.cell(tblA, 1, 4, _macroLine2 + " " + _calDisp, text_color=_macro2Col, text_size=f_size(_ts2), width=_w)
        table.cell(tblA, 2, 4, _volLbl + " " + _ddStr, text_color=_volCol, text_size=f_size(_ts2), width=_w)
        table.cell(tblA, 3, 4, "TP " + _tpStr, text_color=cBloomBull, text_size=f_size(_ts2), width=_w)

    else if _mode == "Tablet"
        // ── TABLET: 9 cols × 2 rows ────────────────────────────────────
        // ROW 0
        table.cell(tblA, 0, 0, _symStr + " " + _tfLabel, text_color=cBloomVal, text_size=f_size(_ts), width=_w2)
        table.cell(tblA, 1, 0, (_isBull ? "▲ " : _isBear ? "▼ " : "≈ ") + str.tostring(math.max(_bullPct, _bearPct)), text_color=_biasCol, text_size=f_size(_ts), width=_w2)
        table.cell(tblA, 2, 0, "SETUP " + str.tostring(_setupScore) + "/5", text_color=_qualCol, text_size=f_size(_ts), width=_w2)
        table.cell(tblA, 3, 0, _structActive, text_color=_structActiveCol, text_size=f_size(_ts), width=_w2)
        table.cell(tblA, 4, 0, "→" + _liqDest, text_color=_liqCol, text_size=f_size(_ts), width=_w2)
        table.cell(tblA, 5, 0, _priceStr + " " + _chgStr, text_color=_chgCol, text_size=f_size(_ts), width=_w2)
        table.cell(tblA, 6, 0, _dxyStr + " " + _yldStr, text_color=_dxyCol, text_size=f_size(_ts), width=_w2)
        table.cell(tblA, 7, 0, _rrStr + " " + _regLbl, text_color=_rrCol, text_size=f_size(_ts), width=_w2)
        table.cell(tblA, 8, 0, _stateLabel, text_color=_stateCol, text_size=f_size(_ts), width=_w2)
        // ROW 1
        table.cell(tblA, 0, 1, _sessLbl + " " + _wrStr, text_color=_sessCol, text_size=f_size(_ts2), width=_w2)
        table.cell(tblA, 1, 1, "MTF " + _mtfDir + " " + _tfArrows, text_color=_mtfCol, text_size=f_size(_ts2), width=_w2)
        table.cell(tblA, 2, 1, _evStr, text_color=_evCol, text_size=f_size(_ts2), width=_w2)
        table.cell(tblA, 3, 1, _bosStr + " " + _chochStr, text_color=_structActiveCol, text_size=f_size(_ts2), width=_w2)
        table.cell(tblA, 4, 1, _poolStr, text_color=_liqCol, text_size=f_size(_ts2), width=_w2)
        table.cell(tblA, 5, 1, "V" + _vwapStr + " E" + _e200Str, text_color=_priceVwapCol, text_size=f_size(_ts2), width=_w2)
        table.cell(tblA, 6, 1, _macroLine2 + " " + _calDisp, text_color=_macro2Col, text_size=f_size(_ts2), width=_w2)
        table.cell(tblA, 7, 1, featRangeStr + "  DD " + _ddStr, text_color=_ddCol, text_size=f_size(_ts2), width=_w2)
        table.cell(tblA, 8, 1, "E" + _eStr + " SL" + _slStr, text_color=cBloomLbl, text_size=f_size(_ts2), width=_w2)

    else if _mode == "MobileLand"
        // ── MOBILE LANDSCAPE: 6 cols × 3 rows ──────────────────────────
        int _wl = density == "Compact" ? 10 : density == "Spacious" ? 16 : 13
        // Row 0: SYMBOL+TF │ PRICE+CHG │ BIAS▲% │ SETUP X/5 │ RR │ STATE
        table.cell(tblA, 0, 0, _symStr + " " + _tfLabel, text_color=cBloomVal, text_size=f_size(_ts), width=_wl)
        table.cell(tblA, 1, 0, _priceStr + " " + _chgStr, text_color=_chgCol, text_size=f_size(_ts), width=_wl)
        table.cell(tblA, 2, 0, (_isBull ? "▲ " : _isBear ? "▼ " : "≈ ") + str.tostring(math.max(_bullPct, _bearPct)), text_color=_biasCol, text_size=f_size(_ts), width=_wl)
        table.cell(tblA, 3, 0, "S" + str.tostring(_setupScore) + "/5 " + _qualLabel, text_color=_qualCol, text_size=f_size(_ts), width=_wl)
        table.cell(tblA, 4, 0, _rrStr + " " + _regLbl, text_color=_rrCol, text_size=f_size(_ts), width=_wl)
        table.cell(tblA, 5, 0, _stateLabel, text_color=_stateCol, text_size=f_size(_ts), width=_wl)
        // Row 1: SESS │ MTF │ STRUCTURE │ LIQ→DEST │ EV │ BOS+CHOCH
        table.cell(tblA, 0, 1, _sessLbl + " " + _wrStr, text_color=_sessCol, text_size=f_size(_ts2), width=_wl)
        table.cell(tblA, 1, 1, "MTF" + _tfArrows + " " + _mtfDir, text_color=_mtfCol, text_size=f_size(_ts2), width=_wl)
        table.cell(tblA, 2, 1, _structActive, text_color=_structActiveCol, text_size=f_size(_ts2), width=_wl)
        table.cell(tblA, 3, 1, "→" + _liqDest, text_color=_liqCol, text_size=f_size(_ts2), width=_wl)
        table.cell(tblA, 4, 1, _evStr, text_color=_evCol, text_size=f_size(_ts2), width=_wl)
        table.cell(tblA, 5, 1, _bosStr + " " + _chochStr, text_color=_structActiveCol, text_size=f_size(_ts2), width=_wl)
        // Row 2: VWAP │ MACRO │ VOL+DD │ POOL │ E+SL+TP │ BULL/BEAR/RNG%
        table.cell(tblA, 0, 2, "V" + _vwapStr + " E" + _e200Str, text_color=_priceVwapCol, text_size=f_size(_ts2), width=_wl)
        table.cell(tblA, 1, 2, _macroLine2 + " " + _calDisp, text_color=_macro2Col, text_size=f_size(_ts2), width=_wl)
        table.cell(tblA, 2, 2, _volLbl + " " + _ddStr, text_color=_volCol, text_size=f_size(_ts2), width=_wl)
        table.cell(tblA, 3, 2, _poolStr, text_color=_liqCol, text_size=f_size(_ts2), width=_wl)
        table.cell(tblA, 4, 2, "E" + _eStr + " SL" + _slStr + " TP" + _tpStr, text_color=cBloomLbl, text_size=f_size(_ts2), width=_wl)
        table.cell(tblA, 5, 2, "▲" + str.tostring(_bullPct) + " ▼" + str.tostring(_bearPct) + " ≈" + str.tostring(_rngPct), text_color=_biasCol, text_size=f_size(_ts2), width=_wl)

    else
        // ── DESKTOP: 9 cols × 3 rows — complete Bloomberg strip ───────
        // Row 0: Section headers
        table.cell(tblA, 0, 0, "MARKET",    text_color=cBloomLbl, text_size=f_size(_ts2), width=_w)
        table.cell(tblA, 1, 0, "BIAS",      text_color=cBloomLbl, text_size=f_size(_ts2), width=_w2)
        table.cell(tblA, 2, 0, "SIGNAL",    text_color=cBloomLbl, text_size=f_size(_ts2), width=_w2)
        table.cell(tblA, 3, 0, "STRUCTURE", text_color=cBloomLbl, text_size=f_size(_ts2), width=_w)
        table.cell(tblA, 4, 0, "LIQUIDITY", text_color=cBloomLbl, text_size=f_size(_ts2), width=_w)
        table.cell(tblA, 5, 0, "PRICE",     text_color=cBloomLbl, text_size=f_size(_ts2), width=_w)
        table.cell(tblA, 6, 0, "MACRO",     text_color=cBloomLbl, text_size=f_size(_ts2), width=_w)
        table.cell(tblA, 7, 0, "RISK",      text_color=cBloomLbl, text_size=f_size(_ts2), width=_w)
        table.cell(tblA, 8, 0, "DECISION",  text_color=cBloomLbl, text_size=f_size(_ts2), width=_w2)
        // Row 1: Primary values
        table.cell(tblA, 0, 1, _symStr + " " + _tfLabel, text_color=cBloomVal, text_size=f_size(_ts), width=_w)
        string _biasLine1 = (_isBull ? "▲ BULL " : _isBear ? "▼ BEAR " : "≈ RANGE ") + str.tostring(math.max(_bullPct, _bearPct))
        table.cell(tblA, 1, 1, _biasLine1, text_color=_biasCol, text_size=f_size(_ts), width=_w2)
        table.cell(tblA, 2, 1, "SETUP " + str.tostring(_setupScore) + "/5  " + _qualLabel, text_color=_qualCol, text_size=f_size(_ts), width=_w2)
        table.cell(tblA, 3, 1, _structActive, text_color=_structActiveCol, text_size=f_size(_ts), width=_w)
        table.cell(tblA, 4, 1, "→ " + _liqDest, text_color=_liqCol, text_size=f_size(_ts), width=_w)
        table.cell(tblA, 5, 1, _priceStr + "  " + _chgStr, text_color=_chgCol, text_size=f_size(_ts), width=_w)
        table.cell(tblA, 6, 1, _dxyStr + "  " + _yldStr, text_color=_dxyYldCol, text_size=f_size(_ts), width=_w)
        table.cell(tblA, 7, 1, _rrStr + "  " + _regLbl, text_color=_rrCol, text_size=f_size(_ts), width=_w)
        table.cell(tblA, 8, 1, _stateLabel, text_color=_stateCol, text_size=f_size(_ts), width=_w2)
        // Row 2: Sub-values
        table.cell(tblA, 0, 2, _sessLbl + "  MTF" + _tfArrows, text_color=_sessCol, text_size=f_size(_ts2), width=_w)
        table.cell(tblA, 1, 2, "▲" + str.tostring(_bullPct) + " ▼" + str.tostring(_bearPct) + " ≈" + str.tostring(_rngPct), text_color=_biasCol, text_size=f_size(_ts2), width=_w2)
        table.cell(tblA, 2, 2, _evStr + "  Rel" + relLbl, text_color=_evCol, text_size=f_size(_ts2), width=_w2)
        table.cell(tblA, 3, 2, _bosStr + " " + _chochStr + " " + _mssStr, text_color=_structActiveCol, text_size=f_size(_ts2), width=_w)
        table.cell(tblA, 4, 2, _poolStr, text_color=_liqCol, text_size=f_size(_ts2), width=_w)
        table.cell(tblA, 5, 2, "VWAP " + _vwapStr + "  E200 " + _e200Str, text_color=_priceVwapCol, text_size=f_size(_ts2), width=_w)
        table.cell(tblA, 6, 2, _macroLine2 + "  CR" + str.tostring(int(avgCorrHealth)) + " " + _calDisp, text_color=_macro2Col, text_size=f_size(_ts2), width=_w)
        table.cell(tblA, 7, 2, featRangeStr + "  DD " + _ddStr, text_color=_volCol, text_size=f_size(_ts2), width=_w)
        table.cell(tblA, 8, 2, "E" + _eStr + " SL" + _slStr + " TP" + _tpStr, text_color=cBloomLbl, text_size=f_size(_ts2), width=_w2)

// Detect responsive mode for table creation and indicator visibility
var string _prevDashMode = "Desktop"
var int _respRows = 3
var int _respCols = 9

if showDashboard and barstate.islast
    // Determine mode
    string _mode2 = dashMode == "Auto" ? "Desktop" : dashMode
    // Set dimensions
    if _mode2 == "MobilePort"
        _respRows := 5
        _respCols := 4
    else if _mode2 == "MobileLand"
        _respRows := 3
        _respCols := 6
    else if _mode2 == "Tablet"
        _respRows := 2
        _respCols := 9
    else
        _respRows := 3
        _respCols := 9
    // Recreate table if mode changed
    if _mode2 != _prevDashMode
        if not na(tblA)
            table.delete(tblA)
            tblA := na
        _prevDashMode := _mode2
    if na(tblA)
        tblA := table.new(position.top_left, _respCols, _respRows, bgcolor=cBloomBg, border_width=0, frame_width=0)
    renderDashboard()

string _dashModeResp = dashMode == "Auto" ? "Desktop" : dashMode

//=====================================================================
// VISUAL INDICATORS - Conditions
//=====================================================================

// ---- Internal Liquidity Sweeps ----
internalLiqSweepHigh = equalHighs and high > nz(swingHigh1) and close < nz(swingHigh1)
internalLiqSweepLow  = equalLows  and low  < nz(swingLow1)  and close > nz(swingLow1)

// ---- Asian Session Range ----
float asianLookbackSec = timeframe.in_seconds()
int   asianLookback    = int(asianLookbackSec >= 604800 ? 10 : asianLookbackSec >= 86400 ? 5 : math.max(5, math.round(25200 / asianLookbackSec)))
float asianSessionHigh = ta.highest(high, asianLookback)
float asianSessionLow  = ta.lowest(low,   asianLookback)
bool asianHighSweep = inLondon and high > asianSessionHigh[1] and close < asianSessionHigh[1]
bool asianLowSweep  = inLondon and low  < asianSessionLow[1]  and close > asianSessionLow[1]

// ---- Manipulation Signal ----
manipBearCandle = high > high[1] and close < close[1] and (high - math.max(open, close)) > bodySize * 0.5
manipBullCandle = low < low[1] and close > close[1] and (math.min(open, close) - low) > bodySize * 0.5
manipVolume = not na(volume) and volume > volSma20 * 1.5
manipRangeCond = candleRange > adaptiveATR * manipThreshold
manipScore = (manipBearCandle or manipBullCandle ? 35 : 0) + (manipVolume ? 35 : 0) + (manipRangeCond ? 30 : 0)
manipHigh = manipScore >= 60 and (manipBearCandle or manipBullCandle) and adxVal > 15

// ---- Signal Quality Label Filters ----

// BOS qualified: engine BOS already requires penetration > 0.15 ATR natively
bosQualifiedBull = bullBOS
bosQualifiedBear = bearBOS

// CHOCH qualified: suppress in ranging regime
chochQualifiedBull = chochLabelBull and not regimeRanging
chochQualifiedBear = chochLabelBear and not regimeRanging

// MSS qualified: liq sweep + displacement + MSS + HTF >= 3/5
mssQualifiedBull = mssLabelBull and displacementUp and (liqSweepBull or internalLiqSweepLow) and (htfFullLong >= 3 or htfFullShort >= 3)
mssQualifiedBear = mssLabelBear and displacementDown and (liqSweepBear or internalLiqSweepHigh) and (htfFullLong >= 3 or htfFullShort >= 3)

// Displacement qualified: vol > 1.5x SMA20, bodyPct > 70%
dispQualifiedUp = displacementUp and not na(volume) and volume > volSma20 * 1.5 and bodyPct > 70
dispQualifiedDown = displacementDown and not na(volume) and volume > volSma20 * 1.5 and bodyPct > 70

// EQH/EQL qualified: dist <= 0.15 ATR, hide after sweep, min 5-bar separation
var int minBarsBetweenEQ = 5
var bool eqhSwept = false
var bool eqlSwept = false
if not na(swingHigh1) and high > swingHigh1
    eqhSwept := true
if not na(swingLow1) and low < swingLow1
    eqlSwept := true
bool eqhMinBars = swingHigh1Bar >= 0 and swingHigh2Bar >= 0 and (swingHigh1Bar - swingHigh2Bar) >= minBarsBetweenEQ
bool eqlMinBars = swingLow1Bar >= 0 and swingLow2Bar >= 0 and (swingLow1Bar - swingLow2Bar) >= minBarsBetweenEQ
eqhQualified = equalHighs and math.abs(swingHigh1 - swingHigh2) <= adaptiveATR * 0.15 and not eqhSwept and eqhMinBars
eqlQualified = equalLows and math.abs(swingLow1 - swingLow2) <= adaptiveATR * 0.15 and not eqlSwept and eqlMinBars
if not equalHighs
    eqhSwept := false
if not equalLows
    eqlSwept := false

// Global filters
globalFilterSuppressBOS = adxVal < 15 or rangeScore > 60
globalFilterSuppressCHOCH = adxVal < 15 or rangeScore > 60
globalFilterSuppressMSS = adxVal < 15 or rangeScore > 60
globalFilterLowConf = htfFullLong < 3 and htfFullShort < 3

//=====================================================================
// PLOTS
//=====================================================================

// ---- EMAs ----
plot(showEMAs and recentBars and not cleanInstitutional ? ema20 : na, "EMA 20", ema20Color, 1, plot.style_line, display=display.all)
plot(showEMAs and recentBars and not cleanInstitutional ? ema100 : na, "EMA 100", ema100Color, 1, plot.style_line, display=display.all)
plot(showEMAs and recentBars and not cleanInstitutional ? ema200 : na, "EMA 200", ema200Color, 1, plot.style_line, display=display.all)

// ---- VWAP ----
plot(showVWAP and recentBars and not cleanInstitutional ? vwapVal : na, "VWAP", color.new(cVwap, 40), 1, plot.style_line, display=display.all)

// ---- ADX (minimal opacity) ----
plot(not perfMode and showADX and recentBars and not cleanInstitutional and not professionalMode ? adxVal : na, "ADX", cAdxC, 1, plot.style_histogram, display=display.all)
hline(perfMode ? na : showADX and not cleanInstitutional ? adxThreshold : na, "ADX Thresh", color.new(#FF4D4D, 50), hline.style_dashed, display=display.none)

// ---- Order Block Visuals (phase 1) ----
var line bullOBLowLine  = na
var line bullOBHighLine = na
var line bearOBLowLine  = na
var line bearOBHighLine = na
var label bullOBLabel = na
var label bearOBLabel = na
bool obVisible = showOB and not cleanInstitutional
if barstate.islast
    if obBullActive and obVisible
        if na(bullOBLowLine)
            bullOBLowLine  := line.new(na, na, na, na, color=color.new(#00D084, 30), width=1, style=line.style_solid, xloc=xloc.bar_index, extend=extend.none)
        if na(bullOBHighLine)
            bullOBHighLine := line.new(na, na, na, na, color=color.new(#00D084, 30), width=1, style=line.style_solid, xloc=xloc.bar_index, extend=extend.none)
        if na(bullOBLabel)
            bullOBLabel := label.new(na, na, "", style=label.style_label_left, color=color.new(#0F172A, 100), textcolor=color.new(#00D084, 70), size=size.tiny, textalign=text.align_left, xloc=xloc.bar_index)
        if _dashModeResp == "Desktop" or _dashModeResp == "Tablet"
            label.set_size(bullOBLabel, size.normal)
            label.set_color(bullOBLabel, color.new(#0F172A, 30))
            line.set_width(bullOBLowLine, 2)
            line.set_width(bullOBHighLine, 2)
        int obStart = math.max(obBullBar, 0)
        line.set_xy1(bullOBLowLine, obStart, obBullLow)
        line.set_xy2(bullOBLowLine, bar_index, obBullLow)
        line.set_xy1(bullOBHighLine, obStart, obBullHigh)
        line.set_xy2(bullOBHighLine, bar_index, obBullHigh)
        label.set_xy(bullOBLabel, bar_index, obBullHigh)
        label.set_text(bullOBLabel, "BULL OB " + str.tostring(obBullHigh, "#.##"))
    else
        if not na(bullOBLowLine)
            line.delete(bullOBLowLine)
            bullOBLowLine := na
        if not na(bullOBHighLine)
            line.delete(bullOBHighLine)
            bullOBHighLine := na
        if not na(bullOBLabel)
            label.delete(bullOBLabel)
            bullOBLabel := na
    if obBearActive and obVisible
        if na(bearOBLowLine)
            bearOBLowLine  := line.new(na, na, na, na, color=color.new(#FF4D4D, 30), width=1, style=line.style_solid, xloc=xloc.bar_index, extend=extend.none)
        if na(bearOBHighLine)
            bearOBHighLine := line.new(na, na, na, na, color=color.new(#FF4D4D, 30), width=1, style=line.style_solid, xloc=xloc.bar_index, extend=extend.none)
        if na(bearOBLabel)
            bearOBLabel := label.new(na, na, "", style=label.style_label_left, color=color.new(#0F172A, 100), textcolor=color.new(#FF4D4D, 70), size=size.tiny, textalign=text.align_left, xloc=xloc.bar_index)
        if _dashModeResp == "Desktop" or _dashModeResp == "Tablet"
            label.set_size(bearOBLabel, size.normal)
            label.set_color(bearOBLabel, color.new(#0F172A, 30))
            line.set_width(bearOBLowLine, 2)
            line.set_width(bearOBHighLine, 2)
        int obStart = math.max(obBearBar, 0)
        line.set_xy1(bearOBLowLine, obStart, obBearLow)
        line.set_xy2(bearOBLowLine, bar_index, obBearLow)
        line.set_xy1(bearOBHighLine, obStart, obBearHigh)
        line.set_xy2(bearOBHighLine, bar_index, obBearHigh)
        label.set_xy(bearOBLabel, bar_index, obBearHigh)
        label.set_text(bearOBLabel, "BEAR OB " + str.tostring(obBearHigh, "#.##"))
    else
        if not na(bearOBLowLine)
            line.delete(bearOBLowLine)
            bearOBLowLine := na
        if not na(bearOBHighLine)
            line.delete(bearOBHighLine)
            bearOBHighLine := na
        if not na(bearOBLabel)
            label.delete(bearOBLabel)
            bearOBLabel := na

fill(plot(obBullActive and showOB and not cleanInstitutional ? obBullLow  : na, display=display.none),
     plot(obBullActive and showOB and not cleanInstitutional ? obBullHigh : na, display=display.none),
     color.new(#00D084, 90), title="Bull OB Fill")
fill(plot(obBearActive and showOB and not cleanInstitutional ? obBearLow  : na, display=display.none),
     plot(obBearActive and showOB and not cleanInstitutional ? obBearHigh : na, display=display.none),
     color.new(#FF4D4D, 90), title="Bear OB Fill")

// ---- FVG Quality Filter (max 3 active) ----
var int fvgActiveCount = 0
if fvgDetected and not fvgActive[1]
    fvgActiveCount += 1
if fvgMitigated and fvgActive[1]
    fvgActiveCount := math.max(0, fvgActiveCount - 1)
bool fvgShowQuality = fvgActiveCount <= 3 or not showFVG

// ---- FVG Visuals (quality-filtered) ----
bool fvgPlotOk = fvgActive and showFVG and fvgShowQuality and not cleanInstitutional
var line fvgUpperLineObj = na
var line fvgLowerLineObj = na
var label fvgLabel = na
if barstate.islast and fvgPlotOk
    if na(fvgUpperLineObj)
        fvgUpperLineObj := line.new(na, na, na, na, color=color.new(#00C2FF, 20), width=1, style=line.style_solid, xloc=xloc.bar_index, extend=extend.none)
    if na(fvgLowerLineObj)
        fvgLowerLineObj := line.new(na, na, na, na, color=color.new(#00C2FF, 20), width=1, style=line.style_solid, xloc=xloc.bar_index, extend=extend.none)
    if na(fvgLabel)
        fvgLabel := label.new(na, na, "", style=label.style_label_left, color=color.new(#0F172A, 100), textcolor=color.new(#00C2FF, 70), size=size.tiny, textalign=text.align_left, xloc=xloc.bar_index)
    if _dashModeResp == "Desktop" or _dashModeResp == "Tablet"
        label.set_size(fvgLabel, size.normal)
        label.set_color(fvgLabel, color.new(#0F172A, 30))
        line.set_width(fvgUpperLineObj, 2)
        line.set_width(fvgLowerLineObj, 2)
    int fvgStart = math.max(fvgBarIndex, 0)
    line.set_xy1(fvgUpperLineObj, fvgStart, fvgUpperLine)
    line.set_xy2(fvgUpperLineObj, bar_index, fvgUpperLine)
    line.set_xy1(fvgLowerLineObj, fvgStart, fvgLowerLine)
    line.set_xy2(fvgLowerLineObj, bar_index, fvgLowerLine)
    label.set_xy(fvgLabel, bar_index, fvgUpperLine)
    label.set_text(fvgLabel, "FVG " + str.tostring(fvgUpperLine, "#.##") + "/" + str.tostring(fvgLowerLine, "#.##"))
else if barstate.islast
    if not na(fvgUpperLineObj)
        line.delete(fvgUpperLineObj)
        fvgUpperLineObj := na
    if not na(fvgLowerLineObj)
        line.delete(fvgLowerLineObj)
        fvgLowerLineObj := na
    if not na(fvgLabel)
        label.delete(fvgLabel)
        fvgLabel := na
fill(plot(fvgPlotOk ? fvgUpperLine : na, display=display.none),
     plot(fvgPlotOk ? fvgLowerLine : na, display=display.none),
     color.new(#00C2FF, 88), title="FVG Fill")


// ---- Macro Strength Score as subplot ----
plot(showMacro and macroIntelValid and recentBars and showMacroPanel and not cleanInstitutional and not professionalMode ? macroStrengthScore : na, "Macro", color.new(#FF8C00, 50), 2, plot.style_histogram, display=display.all)

// ---- Corr Breakdown ----
plot(showCorrHealth and corrBreakdown and recentBars and not cleanInstitutional and not professionalMode ? close : na, "Corr Break", color.new(#FF4D4D, 60), 3, plot.style_line, display=display.all)

// ---- Signal Quality Labels (standardized: red/coral=HIGH, amber=MED, gray=LOW) ----
var label[] bosLabels = array.new_label()
var int[] bosLabelBars = array.new_int()
var int lastBOSBar = -1
var label[] chochLabels = array.new_label()
var int[] chochLabelBars = array.new_int()
var int lastCHOCHBar = -1
var label[] mssLabels = array.new_label()
var int[] mssLabelBars = array.new_int()
var int lastMSSBar = -1
var label[] displabels = array.new_label()
var int[] dispLabelBars = array.new_int()
var int lastDispBar = -1
var label[] eqhLabels = array.new_label()
var int[] eqhLabelBars = array.new_int()
var int lastEQHBar = -1
var label[] eqlLabels = array.new_label()
var int[] eqlLabelBars = array.new_int()
var int lastEQLBar = -1
var label[] manipLabels = array.new_label()
var int[] manipLabelBars = array.new_int()
var int lastManipBar = -1
var label[] smtLabels = array.new_label()
var int[] smtLabelBars = array.new_int()
var int lastSMTBar = -1

// Shared label cleaner helper
cleanLabels(label[] arr, int[] bars, int maxAge) =>
    if array.size(arr) > 0
        for i = array.size(arr) - 1 to 0
            if bar_index - array.get(bars, i) >= maxAge
                label.delete(array.get(arr, i))
                array.remove(arr, i)
                array.remove(bars, i)

// Min bar spacing between same SMC label type
int minSMCSpacing = 5

// ---- BOS (HIGH priority — red/coral, medium size, max 3 concurrent) ----
if barstate.isconfirmed
    cleanLabels(bosLabels, bosLabelBars, 15)
    if showSignals and recentBars and (bosQualifiedBull or bosQualifiedBear) and not globalFilterSuppressBOS and not globalFilterLowConf and bar_index > lastBOSBar + minSMCSpacing
        if array.size(bosLabels) >= 3
            label.delete(array.get(bosLabels, 0))
            array.remove(bosLabels, 0)
            array.remove(bosLabelBars, 0)
        label nl = label.new(bar_index, bosQualifiedBull ? low - adaptiveATR * 0.3 : high + adaptiveATR * 0.3, "BOS", style=label.style_label_center, color=color.new(bosQualifiedBull ? #FF6B6B : #FF4D4D, 50), textcolor=#FFFFFF, size=size.normal, textalign=text.align_center, xloc=xloc.bar_index)
        array.push(bosLabels, nl)
        array.push(bosLabelBars, bar_index)
        lastBOSBar := bar_index

// ---- CHOCH (HIGH priority — amber, medium size, max 3 concurrent) ----
if barstate.isconfirmed
    cleanLabels(chochLabels, chochLabelBars, 15)
    if showSignals and recentBars and (chochQualifiedBull or chochQualifiedBear) and not globalFilterSuppressCHOCH and not globalFilterLowConf and bar_index > lastCHOCHBar + minSMCSpacing
        if array.size(chochLabels) >= 3
            label.delete(array.get(chochLabels, 0))
            array.remove(chochLabels, 0)
            array.remove(chochLabelBars, 0)
        label nl = label.new(bar_index, chochQualifiedBull ? low - adaptiveATR * 0.3 : high + adaptiveATR * 0.3, "CHOCH", style=label.style_label_center, color=color.new(#FF8C00, 55), textcolor=#FFFFFF, size=size.normal, textalign=text.align_center, xloc=xloc.bar_index)
        array.push(chochLabels, nl)
        array.push(chochLabelBars, bar_index)
        lastCHOCHBar := bar_index

// ---- MSS (MEDIUM priority — amber, small size, max 3 concurrent) ----
if barstate.isconfirmed
    cleanLabels(mssLabels, mssLabelBars, 18)
    if showSignals and recentBars and (mssQualifiedBull or mssQualifiedBear) and not globalFilterSuppressMSS and bar_index > lastMSSBar + minSMCSpacing
        if array.size(mssLabels) >= 3
            label.delete(array.get(mssLabels, 0))
            array.remove(mssLabels, 0)
            array.remove(mssLabelBars, 0)
        label nl = label.new(bar_index, mssQualifiedBull ? low - adaptiveATR * 0.4 : high + adaptiveATR * 0.4, "MSS", style=label.style_label_center, color=color.new(mssQualifiedBull ? #FFB84D : #FF8C00, 60), textcolor=#FFFFFF, size=size.small, textalign=text.align_center, xloc=xloc.bar_index)
        array.push(mssLabels, nl)
        array.push(mssLabelBars, bar_index)
        lastMSSBar := bar_index

// ---- SMT Divergence (amber, small size, max 3 concurrent) ----
if barstate.isconfirmed
    cleanLabels(smtLabels, smtLabelBars, 15)
    if showSignals and recentBars and (smtBullPair or smtBearPair) and bar_index > lastSMTBar + minSMCSpacing
        if array.size(smtLabels) >= 3
            label.delete(array.get(smtLabels, 0))
            array.remove(smtLabels, 0)
            array.remove(smtLabelBars, 0)
        string smtText = smtBullPair ? "SMT+" : "SMT−"
        float smtY = smtBullPair ? low - adaptiveATR * 0.4 : high + adaptiveATR * 0.4
        label nl = label.new(bar_index, smtY, smtText, style=label.style_label_center, color=color.new(#FF8C00, 60), textcolor=#FFFFFF, size=size.small, textalign=text.align_center, xloc=xloc.bar_index)
        array.push(smtLabels, nl)
        array.push(smtLabelBars, bar_index)
        lastSMTBar := bar_index

// ---- Liquidity Sweep (MEDIUM priority — amber, small size, min 5-bar gap) ----
var label liqSweepLabel = na
var int liqSweepBar = -999
if (liqSweepBear or liqSweepBull) and barstate.isconfirmed and bar_index > liqSweepBar + minSMCSpacing and not cleanInstitutional and not professionalMode
    string swpText = "Liq Sweep"
    color  swpCol  = liqSweepBear ? #FFB84D : #FF8C00
    float  swpY    = liqSweepBear ? low - adaptiveATR * 0.5 : high + adaptiveATR * 0.5
    if not na(liqSweepLabel)
        label.delete(liqSweepLabel)
    liqSweepLabel := label.new(bar_index, swpY, swpText, style=label.style_label_center, color=color.new(swpCol, 70), textcolor=#FFFFFF, size=size.small, textalign=text.align_center, xloc=xloc.bar_index)
    liqSweepBar := bar_index
if not liqSweepBear and not liqSweepBull and not na(liqSweepLabel) and bar_index > liqSweepBar + 5
    label.delete(liqSweepLabel)
    liqSweepLabel := na

// ---- Asian Sweep Labels (min 5-bar gap) ----
var label asianSweepLabel = na
var int asianSweepBar = -999
if showAsianSweeps and (asianHighSweep or asianLowSweep) and barstate.isconfirmed and bar_index > asianSweepBar + minSMCSpacing
    string asiText = "Asia Sweep"
    color  asiCol  = asianHighSweep ? #FF4D4D : #00D084
    float  asiY    = asianHighSweep ? high + adaptiveATR * 0.3 : low - adaptiveATR * 0.3
    if not na(asianSweepLabel)
        label.delete(asianSweepLabel)
    asianSweepLabel := label.new(bar_index, asiY, asiText, style=label.style_label_center, color=color.new(asiCol, 70), textcolor=#FFFFFF, size=size.small, textalign=text.align_center, xloc=xloc.bar_index)
    asianSweepBar := bar_index
if not asianHighSweep and not asianLowSweep and not na(asianSweepLabel) and bar_index > asianSweepBar + 5
    label.delete(asianSweepLabel)
    asianSweepLabel := na

// ---- Displacement Labels (amber, small, max 3 concurrent) ----
if barstate.isconfirmed
    cleanLabels(displabels, dispLabelBars, 15)
    if recentBars and (dispQualifiedUp or dispQualifiedDown) and bar_index > lastDispBar + minSMCSpacing
        if array.size(displabels) >= 3
            label.delete(array.get(displabels, 0))
            array.remove(displabels, 0)
            array.remove(dispLabelBars, 0)
        label nl = label.new(bar_index, dispQualifiedUp ? low - adaptiveATR * 0.3 : high + adaptiveATR * 0.3, "Disp", style=label.style_label_center, color=color.new(dispQualifiedUp ? #00D084 : #FF4D4D, 50), textcolor=#FFFFFF, size=size.small, textalign=text.align_center, xloc=xloc.bar_index)
        array.push(displabels, nl)
        array.push(dispLabelBars, bar_index)
        lastDispBar := bar_index

// ---- Equal High / Low Labels (amber, small, max 5 concurrent each) ----
if barstate.isconfirmed
    cleanLabels(eqhLabels, eqhLabelBars, 15)
    if recentBars and eqhQualified and bar_index > lastEQHBar + minSMCSpacing
        if array.size(eqhLabels) >= 5
            label.delete(array.get(eqhLabels, 0))
            array.remove(eqhLabels, 0)
            array.remove(eqhLabelBars, 0)
        label nl = label.new(bar_index, high + adaptiveATR * 0.25, "EQH", style=label.style_label_center, color=color.new(#FF8C00, 50), textcolor=#FFFFFF, size=size.small, textalign=text.align_center, xloc=xloc.bar_index)
        array.push(eqhLabels, nl)
        array.push(eqhLabelBars, bar_index)
        lastEQHBar := bar_index
    cleanLabels(eqlLabels, eqlLabelBars, 15)
    if recentBars and eqlQualified and bar_index > lastEQLBar + minSMCSpacing
        if array.size(eqlLabels) >= 5
            label.delete(array.get(eqlLabels, 0))
            array.remove(eqlLabels, 0)
            array.remove(eqlLabelBars, 0)
        label nl = label.new(bar_index, low - adaptiveATR * 0.25, "EQL", style=label.style_label_center, color=color.new(#FF8C00, 50), textcolor=#FFFFFF, size=size.small, textalign=text.align_center, xloc=xloc.bar_index)
        array.push(eqlLabels, nl)
        array.push(eqlLabelBars, bar_index)
        lastEQLBar := bar_index

// ---- Manipulation Labels (LOW priority — gray, small, max 2 concurrent) ----
if barstate.isconfirmed
    cleanLabels(manipLabels, manipLabelBars, 14)
    if showManipulation and recentBars and manipHigh and bar_index > lastManipBar + minSMCSpacing
        if array.size(manipLabels) >= 2
            label.delete(array.get(manipLabels, 0))
            array.remove(manipLabels, 0)
            array.remove(manipLabelBars, 0)
        label nl = label.new(bar_index, manipBearCandle ? high + adaptiveATR * 0.3 : low - adaptiveATR * 0.3, "Manip", style=label.style_label_center, color=color.new(#A0A0A0, 70), textcolor=#FFFFFF, size=size.small, textalign=text.align_center, xloc=xloc.bar_index)
        array.push(manipLabels, nl)
        array.push(manipLabelBars, bar_index)
        lastManipBar := bar_index

//=====================================================================
// KEY LEVELS — PDH/PDL (amber, 40%) + PWH/PWL (purple, 40%)
// Lines span period start → current bar. Label once at right end.
//=====================================================================

// Period start bars — NY session based (computed on every bar)
int nyDayBarsSince = nz(ta.barssince(crossedNYDay), 0)
int nyDayStartBar = bar_index - nyDayBarsSince
int nyWeekBarsSince = nz(ta.barssince(crossedNYWeek), 0)
int nyWeekStartBar = bar_index - nyWeekBarsSince
int monthBarsSince = nz(ta.barssince(timeframe.change("M")), 0)
int monthStartBar = bar_index - monthBarsSince

// CDH / CDL dashed lines (update on every bar, not just islast)
var line cdhLine = na
var line cdlLine = na
var label cdhLabel = na
var label cdlLabel = na
if barstate.islast and showKeyLevels and showLiqPools and not cleanInstitutional
    if na(cdhLine)
        cdhLine := line.new(na, na, na, na, color=color.new(#60A5FA, 70), width=1, style=line.style_dashed, xloc=xloc.bar_index, extend=extend.none)
    if na(cdlLine)
        cdlLine := line.new(na, na, na, na, color=color.new(#60A5FA, 70), width=1, style=line.style_dashed, xloc=xloc.bar_index, extend=extend.none)
    if na(cdhLabel)
        cdhLabel := label.new(na, na, "", style=label.style_label_left, color=color.new(#0F172A, 100), textcolor=#60A5FA, size=size.tiny, textalign=text.align_left, xloc=xloc.bar_index)
    if na(cdlLabel)
        cdlLabel := label.new(na, na, "", style=label.style_label_left, color=color.new(#0F172A, 100), textcolor=#60A5FA, size=size.tiny, textalign=text.align_left, xloc=xloc.bar_index)
    if _dashModeResp == "Desktop" or _dashModeResp == "Tablet"
        label.set_size(cdhLabel, size.normal)
        label.set_color(cdhLabel, color.new(#0F172A, 30))
        line.set_width(cdhLine, 2)
        label.set_size(cdlLabel, size.normal)
        label.set_color(cdlLabel, color.new(#0F172A, 30))
        line.set_width(cdlLine, 2)
    line.set_xy1(cdhLine, nyDayStartBar, cdh)
    line.set_xy2(cdhLine, bar_index, cdh)
    line.set_xy1(cdlLine, nyDayStartBar, cdl)
    line.set_xy2(cdlLine, bar_index, cdl)
    label.set_xy(cdhLabel, bar_index, cdh)
    label.set_text(cdhLabel, "CDH • " + str.tostring(cdh, "#.##"))
    label.set_xy(cdlLabel, bar_index, cdl)
    label.set_text(cdlLabel, "CDL • " + str.tostring(cdl, "#.##"))
else if barstate.islast
    if not na(cdhLine)
        line.delete(cdhLine)
        cdhLine := na
    if not na(cdlLine)
        line.delete(cdlLine)
        cdlLine := na
    if not na(cdhLabel)
        label.delete(cdhLabel)
        cdhLabel := na
    if not na(cdlLabel)
        label.delete(cdlLabel)
        cdlLabel := na

// Min spacing for key level labels to prevent overlap
float minKeyDist = ta.atr(14) * 0.15

// Helper: apply vertical offset bidirectionally (push up OR down, whichever is closer to base)
f_offsetLabel(baseY, ref1, ref2, ref3, dist) =>
    float yyUp = baseY
    if not na(ref1) and math.abs(yyUp - ref1) < dist
        yyUp := yyUp + dist
    if not na(ref2) and math.abs(yyUp - ref2) < dist
        yyUp := yyUp + dist
    if not na(ref3) and math.abs(yyUp - ref3) < dist
        yyUp := yyUp + dist
    float yyDn = baseY
    if not na(ref1) and math.abs(yyDn - ref1) < dist
        yyDn := yyDn - dist
    if not na(ref2) and math.abs(yyDn - ref2) < dist
        yyDn := yyDn - dist
    if not na(ref3) and math.abs(yyDn - ref3) < dist
        yyDn := yyDn - dist
    math.abs(yyDn - baseY) < math.abs(yyUp - baseY) ? yyDn : yyUp

if barstate.islast
    // Current price line + label (always visible)
    var priceLine  = line.new(na, na, na, na, color=color.new(#F1F5F9, 70), width=1, style=line.style_dotted, xloc=xloc.bar_index, extend=extend.right)
    var priceLabel = label.new(na, na, "", style=label.style_label_right, color=color.new(#0F172A, 100), textcolor=#F1F5F9, size=size.small, textalign=text.align_left, xloc=xloc.bar_index)
    line.set_xy1(priceLine, bar_index - 2, close)
    line.set_xy2(priceLine, bar_index, close)
    label.set_xy(priceLabel, bar_index, close)
    label.set_text(priceLabel, str.tostring(close, "#.##"))

    // EMA overlay lines + labels
    if showEMAs and not cleanInstitutional
        var ema20Line  = line.new(na, na, na, na, color=color.new(cEma20, 70), width=1, style=line.style_dotted, xloc=xloc.bar_index, extend=extend.right)
        var ema20Label = label.new(na, na, "", style=label.style_label_right, color=color.new(#0F172A, 100), textcolor=cEma20, size=size.small, textalign=text.align_left, xloc=xloc.bar_index)
        var ema100Line  = line.new(na, na, na, na, color=color.new(cEma100, 70), width=1, style=line.style_dotted, xloc=xloc.bar_index, extend=extend.right)
        var ema100Label = label.new(na, na, "", style=label.style_label_right, color=color.new(#0F172A, 100), textcolor=cEma100, size=size.small, textalign=text.align_left, xloc=xloc.bar_index)
        var ema200Line  = line.new(na, na, na, na, color=color.new(cEma200, 80), width=2, style=line.style_dotted, xloc=xloc.bar_index, extend=extend.right)
        var ema200Label = label.new(na, na, "", style=label.style_label_right, color=color.new(#0F172A, 100), textcolor=cEma200, size=size.small, textalign=text.align_left, xloc=xloc.bar_index)
        line.set_xy1(ema20Line, bar_index - 2, ema20)
        line.set_xy2(ema20Line, bar_index, ema20)
        label.set_xy(ema20Label, bar_index, ema20)
        label.set_text(ema20Label, "EMA20 " + str.tostring(ema20, "#.##"))
        line.set_xy1(ema100Line, bar_index - 2, ema100)
        line.set_xy2(ema100Line, bar_index, ema100)
        label.set_xy(ema100Label, bar_index, ema100)
        label.set_text(ema100Label, "EMA100 " + str.tostring(ema100, "#.##"))
        line.set_xy1(ema200Line, bar_index - 2, ema200)
        line.set_xy2(ema200Line, bar_index, ema200)
        label.set_xy(ema200Label, bar_index, ema200)
        label.set_text(ema200Label, "EMA200 " + str.tostring(ema200, "#.##"))

    // VWAP overlay line + label
    if showVWAP and not cleanInstitutional
        var vwapLine  = line.new(na, na, na, na, color=color.new(cVwap, 60), width=1, style=line.style_dotted, xloc=xloc.bar_index, extend=extend.right)
        var vwapLabel = label.new(na, na, "", style=label.style_label_right, color=color.new(#0F172A, 100), textcolor=cVwap, size=size.small, textalign=text.align_left, xloc=xloc.bar_index)
        line.set_xy1(vwapLine, bar_index - 2, vwapVal)
        line.set_xy2(vwapLine, bar_index, vwapVal)
        label.set_xy(vwapLabel, bar_index, vwapVal)
        label.set_text(vwapLabel, "VWAP " + str.tostring(vwapVal, "#.##"))

    // Trade plan horizontal levels (chart lines only — values in Table B)
    if showTradePlan
        var entryLine = line.new(na, na, na, na, color=color.new(#3B82F6, 70), width=1, style=line.style_dashed, xloc=xloc.bar_index, extend=extend.right)
        var stopLine  = line.new(na, na, na, na, color=color.new(#EF4444, 60), width=1, style=line.style_dashed, xloc=xloc.bar_index, extend=extend.right)
        var tpLine    = line.new(na, na, na, na, color=color.new(#22C55E, 70), width=1, style=line.style_dashed, xloc=xloc.bar_index, extend=extend.right)
        line.set_xy1(entryLine, bar_index - 2, tpEntry)
        line.set_xy2(entryLine, bar_index, tpEntry)
        line.set_xy1(stopLine, bar_index - 2, tpSL)
        line.set_xy2(stopLine, bar_index, tpSL)
        line.set_xy1(tpLine, bar_index - 2, tp1)
        line.set_xy2(tpLine, bar_index, tp1)

// Key level line/label objects (declared outside conditional for proper scoping)
var pdhLine  = line.new(na, na, na, na, color=color.new(#FF8C00, 60), width=1, style=line.style_dotted, xloc=xloc.bar_index, extend=extend.right)
var pdhLabel = label.new(na, na, "", style=label.style_label_left, color=color.new(#0F172A, 100), textcolor=#FF8C00, size=size.tiny, textalign=text.align_left, xloc=xloc.bar_index)
var pdlLine  = line.new(na, na, na, na, color=color.new(#FF8C00, 60), width=1, style=line.style_dotted, xloc=xloc.bar_index, extend=extend.right)
var pdlLabel = label.new(na, na, "", style=label.style_label_left, color=color.new(#0F172A, 100), textcolor=#FF8C00, size=size.tiny, textalign=text.align_left, xloc=xloc.bar_index)
var pwhLine  = line.new(na, na, na, na, color=color.new(#A855F7, 60), width=1, style=line.style_dotted, xloc=xloc.bar_index, extend=extend.right)
var pwhLabel = label.new(na, na, "", style=label.style_label_left, color=color.new(#0F172A, 100), textcolor=#A855F7, size=size.tiny, textalign=text.align_left, xloc=xloc.bar_index)
var pwlLine  = line.new(na, na, na, na, color=color.new(#A855F7, 60), width=1, style=line.style_dotted, xloc=xloc.bar_index, extend=extend.right)
var pwlLabel = label.new(na, na, "", style=label.style_label_left, color=color.new(#0F172A, 100), textcolor=#A855F7, size=size.tiny, textalign=text.align_left, xloc=xloc.bar_index)
var pmhLine  = line.new(na, na, na, na, color=color.new(#00C2FF, 60), width=1, style=line.style_dotted, xloc=xloc.bar_index, extend=extend.right)
var pmhLabel = label.new(na, na, "", style=label.style_label_left, color=color.new(#0F172A, 100), textcolor=#00C2FF, size=size.tiny, textalign=text.align_left, xloc=xloc.bar_index)
var pmlLine  = line.new(na, na, na, na, color=color.new(#00C2FF, 60), width=1, style=line.style_dotted, xloc=xloc.bar_index, extend=extend.right)
var pmlLabel = label.new(na, na, "", style=label.style_label_left, color=color.new(#0F172A, 100), textcolor=#00C2FF, size=size.tiny, textalign=text.align_left, xloc=xloc.bar_index)

if barstate.islast and showKeyLevels and showLiqPools and not cleanInstitutional
    // Collect values for collision detection
    float rawPdh = na(poolPdH) ? na : poolPdH
    float rawPdl = na(poolPdL) ? na : poolPdL
    float rawPwh = na(poolPwH) ? na : poolPwH
    float rawPwl = na(poolPwL) ? na : poolPwL
    float rawPmh = na(poolPmH) ? na : poolPmH
    float rawPml = na(poolPmL) ? na : poolPmL

    if _dashModeResp == "Desktop" or _dashModeResp == "Tablet"
        // Enhanced chart labels for Desktop and Tablet layouts
        label.set_size(pdhLabel, size.normal)
        label.set_color(pdhLabel, color.new(#0F172A, 30))
        line.set_width(pdhLine, 2)
        label.set_size(pdlLabel, size.normal)
        label.set_color(pdlLabel, color.new(#0F172A, 30))
        line.set_width(pdlLine, 2)
        label.set_size(pwhLabel, size.normal)
        label.set_color(pwhLabel, color.new(#0F172A, 30))
        line.set_width(pwhLine, 2)
        label.set_size(pwlLabel, size.normal)
        label.set_color(pwlLabel, color.new(#0F172A, 30))
        line.set_width(pwlLine, 2)
        label.set_size(pmhLabel, size.normal)
        label.set_color(pmhLabel, color.new(#0F172A, 30))
        line.set_width(pmhLine, 2)
        label.set_size(pmlLabel, size.normal)
        label.set_color(pmlLabel, color.new(#0F172A, 30))
        line.set_width(pmlLine, 2)
    // PDH — amber, 40% (daily)
    if showPDH and not na(rawPdh)
        float pdhOff = f_offsetLabel(rawPdh, rawPdl, rawPwh, rawPwl, minKeyDist)
        line.set_xy1(pdhLine, nyDayStartBar, rawPdh)
        line.set_xy2(pdhLine, bar_index, rawPdh)
        label.set_xy(pdhLabel, bar_index, pdhOff)
        label.set_text(pdhLabel, "PDH • " + str.tostring(rawPdh, "#.##"))
    // PDL — amber, 40% (daily)
    if showPDL and not na(rawPdl)
        float pdlOff = f_offsetLabel(rawPdl, rawPdh, rawPwh, rawPwl, minKeyDist)
        line.set_xy1(pdlLine, nyDayStartBar, rawPdl)
        line.set_xy2(pdlLine, bar_index, rawPdl)
        label.set_xy(pdlLabel, bar_index, pdlOff)
        label.set_text(pdlLabel, "PDL • " + str.tostring(rawPdl, "#.##"))

    // PWH — purple, 40% (weekly)
    if showPWH and not na(rawPwh)
        float pwhOff = f_offsetLabel(rawPwh, rawPdh, rawPdl, rawPwl, minKeyDist)
        line.set_xy1(pwhLine, nyWeekStartBar, rawPwh)
        line.set_xy2(pwhLine, bar_index, rawPwh)
        label.set_xy(pwhLabel, bar_index, pwhOff)
        label.set_text(pwhLabel, "PWH • " + str.tostring(rawPwh, "#.##"))
    // PWL — purple, 40% (weekly)
    if showPWL and not na(rawPwl)
        float pwlOff = f_offsetLabel(rawPwl, rawPdh, rawPdl, rawPwh, minKeyDist)
        line.set_xy1(pwlLine, nyWeekStartBar, rawPwl)
        line.set_xy2(pwlLine, bar_index, rawPwl)
        label.set_xy(pwlLabel, bar_index, pwlOff)
        label.set_text(pwlLabel, "PWL • " + str.tostring(rawPwl, "#.##"))

    // PMH — cyan, 40% (monthly)
    if not na(rawPmh)
        float pmhOff = f_offsetLabel(rawPmh, rawPml, rawPwh, rawPwl, minKeyDist)
        line.set_xy1(pmhLine, monthStartBar, rawPmh)
        line.set_xy2(pmhLine, bar_index, rawPmh)
        label.set_xy(pmhLabel, bar_index, pmhOff)
        label.set_text(pmhLabel, "PMH • " + str.tostring(rawPmh, "#.##"))
    // PML — cyan, 40% (monthly)
    if not na(rawPml)
        float pmlOff = f_offsetLabel(rawPml, rawPmh, rawPwh, rawPwl, minKeyDist)
        line.set_xy1(pmlLine, monthStartBar, rawPml)
        line.set_xy2(pmlLine, bar_index, rawPml)
        label.set_xy(pmlLabel, bar_index, pmlOff)
        label.set_text(pmlLabel, "PML • " + str.tostring(rawPml, "#.##"))

    // Resolve cross-pool label collisions (daily vs monthly)
    for i = 1 to 3
        float _mid = na
        float _y1 = na
        float _y2 = na
        if not na(rawPdh) and not na(rawPmh)
            _y1 := label.get_y(pdhLabel)
            _y2 := label.get_y(pmhLabel)
            if not na(_y1) and not na(_y2) and math.abs(_y1 - _y2) < minKeyDist
                _mid := (_y1 + _y2) / 2
                label.set_xy(pdhLabel, bar_index, _mid + minKeyDist * 0.51)
                label.set_xy(pmhLabel, bar_index, _mid - minKeyDist * 0.51)
        if not na(rawPdl) and not na(rawPml)
            _y1 := label.get_y(pdlLabel)
            _y2 := label.get_y(pmlLabel)
            if not na(_y1) and not na(_y2) and math.abs(_y1 - _y2) < minKeyDist
                _mid := (_y1 + _y2) / 2
                label.set_xy(pdlLabel, bar_index, _mid - minKeyDist * 0.51)
                label.set_xy(pmlLabel, bar_index, _mid + minKeyDist * 0.51)

//=====================================================================
// SMART ALERT FRAMEWORK - analysis only, no trade execution
//=====================================================================

alertcondition(shouldBuy,  title="Nexus Buy Signal",  message="XAUUSD: Buy signal @ {{close}} | Bias: {{biasLabel}} | Conf: {{regimeConfidence}}% | Session: {{sessionLabel}}")
alertcondition(shouldSell, title="Nexus Sell Signal", message="XAUUSD: Sell signal @ {{close}} | Bias: {{biasLabel}} | Conf: {{regimeConfidence}}% | Session: {{sessionLabel}}")

if shouldBuy and barstate.isconfirmed and not perfMode
    alert("XAUUSD NEXUS BUY @ " + str.tostring(close, "#.##"), alert.freq_once_per_bar)
if shouldSell and barstate.isconfirmed and not perfMode
    alert("XAUUSD NEXUS SELL @ " + str.tostring(close, "#.##"), alert.freq_once_per_bar)

alertcondition(showSignals and barstate.isconfirmed and bullBOS, "Bull BOS", "XAUUSD Bull BOS @ {{close}}")
alertcondition(showSignals and barstate.isconfirmed and bearBOS, "Bear BOS", "XAUUSD Bear BOS @ {{close}}")

//=====================================================================
// PREMIUM / DISCOUNT ZONE SHADING
// Premium = above intraday dealing range midpoint (bearish zone)
// Discount = below midpoint (bullish zone)
// Shown only on recent bars with subtle transparency
//=====================================================================
float dealingRangeMid = (ta.highest(high, 20) + ta.lowest(low, 20)) / 2
color premiumColor = color.new(#FF4D4D, 95)
color discountColor = color.new(#00D084, 95)

var line premiumLine = na
var line discountLine = na
var box premiumBox = na
var box discountBox = na
var label premiumLabel = na
var label discountLabel = na
float chartTopRaw = ta.highest(high, 100)
float chartBotRaw = ta.lowest(low, 100)
if showPremiumDisc and barstate.islast and recentBars and not cleanInstitutional and not professionalMode
    if na(premiumLine)
        premiumLine := line.new(na, na, na, na, color=premiumColor, width=1, style=line.style_solid, xloc=xloc.bar_index, extend=extend.none)
    if na(discountLine)
        discountLine := line.new(na, na, na, na, color=discountColor, width=1, style=line.style_solid, xloc=xloc.bar_index, extend=extend.none)
    if na(premiumLabel)
        premiumLabel := label.new(na, na, "", style=label.style_label_left, color=color.new(#0F172A, 100), textcolor=color.new(#FF4D4D, 95), size=size.tiny, textalign=text.align_left, xloc=xloc.bar_index)
    if na(discountLabel)
        discountLabel := label.new(na, na, "", style=label.style_label_left, color=color.new(#0F172A, 100), textcolor=color.new(#00D084, 95), size=size.tiny, textalign=text.align_left, xloc=xloc.bar_index)
    if na(premiumBox)
        premiumBox := box.new(na, na, na, na, bgcolor=premiumColor, border_color=na, xloc=xloc.bar_index, extend=extend.none)
    if na(discountBox)
        discountBox := box.new(na, na, na, na, bgcolor=discountColor, border_color=na, xloc=xloc.bar_index, extend=extend.none)
    float chartTop = chartTopRaw * 1.02
    float chartBot = chartBotRaw * 0.98
    line.set_xy1(premiumLine, bar_index - 5, dealingRangeMid)
    line.set_xy2(premiumLine, bar_index, dealingRangeMid)
    label.set_xy(premiumLabel, bar_index, dealingRangeMid)
    label.set_text(premiumLabel, "PREM " + str.tostring(dealingRangeMid, "#.##"))
    line.set_xy1(discountLine, bar_index - 5, dealingRangeMid)
    line.set_xy2(discountLine, bar_index, dealingRangeMid)
    label.set_xy(discountLabel, bar_index, dealingRangeMid - minKeyDist)
    label.set_text(discountLabel, "DISC " + str.tostring(dealingRangeMid, "#.##"))
    box.set_lefttop(premiumBox, bar_index - 5, chartTop)
    box.set_rightbottom(premiumBox, bar_index, dealingRangeMid)
    box.set_lefttop(discountBox, bar_index - 5, dealingRangeMid)
    box.set_rightbottom(discountBox, bar_index, chartBot)
else if barstate.islast
    if not na(premiumLine)
        line.delete(premiumLine)
        premiumLine := na
    if not na(discountLine)
        line.delete(discountLine)
        discountLine := na
    if not na(premiumLabel)
        label.delete(premiumLabel)
        premiumLabel := na
    if not na(discountLabel)
        label.delete(discountLabel)
        discountLabel := na
    if not na(premiumBox)
        box.delete(premiumBox)
        premiumBox := na
    if not na(discountBox)
        box.delete(discountBox)
        discountBox := na

//=====================================================================
// FORECAST CONE — M12-powered projection with confidence bands
// Combines Historical Analog + Trend Persistence + Liq Destination + Regime
//=====================================================================

if barstate.islast and showForecastCone and not cleanInstitutional and not professionalMode
    // Determine cone direction from M12 forecast probabilities
    string coneLabel = "RNG"
    float coneDir = 0.0
    float coneScore = fRngScore
    if fBullScore >= fBearScore and fBullScore >= fRngScore
        coneLabel := "BULL"
        coneDir := 1.0
        coneScore := fBullScore
    else if fBearScore >= fBullScore and fBearScore >= fRngScore
        coneLabel := "BEAR"
        coneDir := -1.0
        coneScore := fBearScore
    // Slope magnitude scales with probability conviction and ATR
    float coneSlope = adaptiveATR * (coneScore - 50.0) / 100.0 * coneDir * 0.5
    float centerEnd = close + coneSlope * forecastBars
    float startBand = math.max(adaptiveATR, atr) * forecastZ
    float endBand   = startBand * math.sqrt(math.max(forecastBars, 1))

    var line fcCenter = line.new(na, na, na, na, color=color.new(#00C2FF, 70), width=1, style=line.style_solid, xloc=xloc.bar_index, extend=extend.none)
    var line fcUpper  = line.new(na, na, na, na, color=color.new(#00C2FF, 30), width=1, style=line.style_dashed, xloc=xloc.bar_index, extend=extend.none)
    var line fcLower  = line.new(na, na, na, na, color=color.new(#00C2FF, 30), width=1, style=line.style_dashed, xloc=xloc.bar_index, extend=extend.none)
    var label fcLabel = label.new(na, na, "", style=label.style_label_center, color=color.new(#0F172A, 100), textcolor=#00C2FF, size=size.tiny, textalign=text.align_center, xloc=xloc.bar_index)

    line.set_xy1(fcCenter, bar_index, close)
    line.set_xy2(fcCenter, bar_index + forecastBars, centerEnd)
    line.set_xy1(fcUpper, bar_index, close + startBand)
    line.set_xy2(fcUpper, bar_index + forecastBars, centerEnd + endBand)
    line.set_xy1(fcLower, bar_index, close - startBand)
    line.set_xy2(fcLower, bar_index + forecastBars, centerEnd - endBand)
    label.set_xy(fcLabel, bar_index + forecastBars + 1, centerEnd)
    label.set_text(fcLabel, coneLabel + " " + str.tostring(int(coneScore)) + "%")

//=====================================================================
// END OF INDICATOR
//=====================================================================
