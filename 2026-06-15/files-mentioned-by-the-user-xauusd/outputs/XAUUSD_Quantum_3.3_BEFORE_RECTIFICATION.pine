        _cMaxAdverseATR := oMaxAdverseATR_
        _cSharpe := oSharpe_
        _cMaxDD := oMaxDD_
        _cOosWr := oOosWr_
        _cOosN := oOosN_
        _cIsWr := oIsWr_
        _cIsN := oIsN_
        [oBull_, oBear_, oRange_, oMatch_, oPdh1stPct_, oPdl1stPct_, oEvVal_, oEvLabel_, oWr_, oAvgW_, oAvgL_, oCalPct_, oCalGrade_, oCalBrier_, oCalDetail_, oBosCont_, oBosFail_, oRegPer_, oFeatStr_, oFeatHtf_, oFeatLiq_, oFeatMr_, oFeatCor_, oProfitFactor_, oMaxAdverseATR_, oSharpe_, oMaxDD_, oOosWr_, oOosN_, oIsWr_, oIsN_]

[__b, __be, __r, __m, __p1, __p2, __ev, __el, __wr, __aw, __al, __cp, __cg, __cb, __cd, __bc, __bf, __rp, __fs, __fh, __fl, __fm, __fc, __pf, __ma, __sh, __md, __ow, __on, __iw, __in] = runStatsEngines()
