# ============================================================
# Cloud-Native Configuration
# ============================================================

# Database (Supabase)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-service-role-key
# Also works with direct PostgreSQL connection
DATABASE_URL=postgresql://user:pass@localhost:5432/quantum

# Cache (Cloudflare KV or Redis)
REDIS_URL=redis://localhost:6379/0
CLOUDFLARE_KV_NAMESPACE=

# API
API_KEY=dev-api-key-change-in-production
API_PORT=8000
API_HOST=0.0.0.0
LOG_LEVEL=DEBUG
ENVIRONMENT=development

# Engine Control
ENABLE_VALIDATION_ENGINE=true
ENABLE_AUDIT_ENGINE=true
ENABLE_FORECAST_ENGINE=false
ENABLE_LEARNING_ENGINE=false

# Trading
ACCOUNT_SIZE=100000
MAX_POSITION_PCT=0.05
DEFAULT_RISK_PERCENT=1.0
MAX_PORTFOLIO_HEAT=0.50
MAX_DAILY_LOSS=-500
MAX_WEEKLY_LOSS=-1500
MAX_DRAWDOWN=-0.15

# Market
XAUUSD_TYPICAL_SPREAD=0.3
COMMISSION_PER_100K=5.0
DEFAULT_SLIPPAGE_PIPS=0.5
